<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
@keyframes fadeIn{to{opacity:1;}}
@keyframes droplet{0%{transform:scale(1);border-radius:50%}50%{transform:scale(1.05);border-radius:60% 40% 60% 40%}100%{transform:scale(1);border-radius:50%}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

body{
  background: linear-gradient(135deg, #f5f0f6 0%, #e8dff0 50%, #f0e5f5 100%);
  background-attachment: fixed;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Segoe UI',sans-serif;
  color:#6f2b67;
  padding:20px;
  position: relative;
  overflow: hidden;
}

body::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    url("data:image/svg+xml,%3Csvg width='400' height='400' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3ClinearGradient id='book1' x1='0%25' y1='0%25' x2='100%25' y2='0%25'%3E%3Cstop offset='0%25' style='stop-color:%23ff9a9e;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23fecfef;stop-opacity:1' /%3E%3C/linearGradient%3E%3ClinearGradient id='book2' x1='0%25' y1='0%25' x2='100%25' y2='0%25'%3E%3Cstop offset='0%25' style='stop-color:%23a8edea;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23fed6e3;stop-opacity:1' /%3E%3C/linearGradient%3E%3ClinearGradient id='book3' x1='0%25' y1='0%25' x2='0%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23ffecd2;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23fcb69f;stop-opacity:1' /%3E%3C/linearGradient%3E%3ClinearGradient id='book4' x1='0%25' y1='0%25' x2='0%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23a1c4fd;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23c2e9fb;stop-opacity:1' /%3E%3C/linearGradient%3E%3ClinearGradient id='book5' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23d299c2;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23fef9d7;stop-opacity:1' /%3E%3C/linearGradient%3E%3ClinearGradient id='book6' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' style='stop-color:%23fddb92;stop-opacity:1' /%3E%3Cstop offset='100%25' style='stop-color:%23d1fdff;stop-opacity:1' /%3E%3C/linearGradient%3E%3C/defs%3E%3Cg opacity='0.28'%3E%3C!-- Open Book Top Left --%3E%3Cg transform='translate(40,50) rotate(-15)'%3E%3Cpath d='M0,0 Q20,-8 40,0 L40,50 Q20,42 0,50 Z' fill='url(%23book1)' stroke='%23ff6b9d' stroke-width='1.5'/%3E%3Cpath d='M40,0 Q60,-8 80,0 L80,50 Q60,42 40,50 Z' fill='url(%23book2)' stroke='%23a8d8ea' stroke-width='1.5'/%3E%3Cline x1='40' y1='0' x2='40' y2='50' stroke='%23e91e63' stroke-width='2'/%3E%3Cpath d='M8,12 L32,12 M8,20 L32,20 M8,28 L30,28 M8,36 L32,36' stroke='%23ff6b9d' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3Cpath d='M48,12 L72,12 M48,20 L72,20 M48,28 L70,28 M48,36 L72,36' stroke='%23a8d8ea' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3C/g%3E%3C!-- Stack Books Top Right --%3E%3Cg transform='translate(280,40)'%3E%3Cg%3E%3Crect x='0' y='0' width='80' height='15' rx='2' fill='url(%23book3)' stroke='%23ff9a76' stroke-width='1.5'/%3E%3Cpath d='M5,7 L75,7' stroke='white' stroke-width='1' opacity='0.4'/%3E%3Crect x='3' y='3' width='3' height='9' fill='%23fc8d62' rx='1'/%3E%3C/g%3E%3Cg transform='translate(0,18)'%3E%3Crect x='0' y='0' width='80' height='15' rx='2' fill='url(%23book4)' stroke='%237ec8e3' stroke-width='1.5'/%3E%3Cpath d='M5,7 L75,7' stroke='white' stroke-width='1' opacity='0.4'/%3E%3Crect x='3' y='3' width='3' height='9' fill='%235dade2' rx='1'/%3E%3C/g%3E%3Cg transform='translate(0,36)'%3E%3Crect x='0' y='0' width='80' height='15' rx='2' fill='url(%23book5)' stroke='%23c284b9' stroke-width='1.5'/%3E%3Cpath d='M5,7 L75,7' stroke='white' stroke-width='1' opacity='0.4'/%3E%3Crect x='3' y='3' width='3' height='9' fill='%23a569bd' rx='1'/%3E%3C/g%3E%3C/g%3E%3C!-- Standing Books Bottom Left --%3E%3Cg transform='translate(50,280)'%3E%3Cg transform='rotate(-5 20 60)'%3E%3Crect x='0' y='0' width='25' height='80' rx='2' fill='url(%23book6)' stroke='%23f8b500' stroke-width='1.5'/%3E%3Cpath d='M12,8 L12,72' stroke='%23f39c12' stroke-width='1.5' opacity='0.5'/%3E%3Crect x='3' y='3' width='19' height='5' fill='white' opacity='0.3' rx='1'/%3E%3C/g%3E%3Cg transform='translate(30,0) rotate(3 20 60)'%3E%3Crect x='0' y='0' width='25' height='85' rx='2' fill='url(%23book1)' stroke='%23ff6b9d' stroke-width='1.5'/%3E%3Cpath d='M12,8 L12,77' stroke='%23e91e63' stroke-width='1.5' opacity='0.5'/%3E%3Crect x='3' y='3' width='19' height='5' fill='white' opacity='0.3' rx='1'/%3E%3C/g%3E%3Cg transform='translate(60,0) rotate(-4 20 60)'%3E%3Crect x='0' y='0' width='25' height='78' rx='2' fill='url(%23book4)' stroke='%237ec8e3' stroke-width='1.5'/%3E%3Cpath d='M12,8 L12,70' stroke='%235dade2' stroke-width='1.5' opacity='0.5'/%3E%3Crect x='3' y='3' width='19' height='5' fill='white' opacity='0.3' rx='1'/%3E%3C/g%3E%3C/g%3E%3C!-- Open Book Bottom Right --%3E%3Cg transform='translate(260,270) rotate(12)'%3E%3Cpath d='M0,0 Q25,-10 50,0 L50,60 Q25,50 0,60 Z' fill='url(%23book5)' stroke='%23c284b9' stroke-width='1.5'/%3E%3Cpath d='M50,0 Q75,-10 100,0 L100,60 Q75,50 50,60 Z' fill='url(%23book3)' stroke='%23ff9a76' stroke-width='1.5'/%3E%3Cline x1='50' y1='0' x2='50' y2='60' stroke='%23a569bd' stroke-width='2'/%3E%3Cpath d='M10,15 L40,15 M10,25 L40,25 M10,35 L38,35 M10,45 L40,45' stroke='%23c284b9' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3Cpath d='M60,15 L90,15 M60,25 L90,25 M60,35 L88,35 M60,45 L90,45' stroke='%23ff9a76' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3C/g%3E%3C!-- Closed Book Center --%3E%3Cg transform='translate(180,150) rotate(-8)'%3E%3Crect x='0' y='0' width='60' height='45' rx='3' fill='url(%23book2)' stroke='%23a8d8ea' stroke-width='1.5'/%3E%3Crect x='5' y='5' width='50' height='35' rx='2' fill='white' opacity='0.2'/%3E%3Cpath d='M30,5 L30,40' stroke='%237ec8e3' stroke-width='2' opacity='0.6'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  background-size: 450px 450px;
  pointer-events: none;
  z-index: 0;
}


.logo-circle{
  position:relative;
  width:50px;
  height:50px;
  border-radius:50%;
  border:2px solid #6f2b67;
  background:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  margin:0 auto 8px;
  animation:float 3s ease-in-out infinite;
  box-shadow:0 3px 12px rgba(111,43,103,0.2);
}
.book-logo{width:28px;filter:brightness(0) saturate(100%) invert(21%) sepia(47%) saturate(1789%) hue-rotate(285deg) brightness(85%) contrast(92%);}
.logo-text{
  position:absolute;
  bottom:3px;
  font-size:6px;
  font-weight:800;
  color:#6f2b67;
  letter-spacing:0.6px;
  text-transform:uppercase;
}
.tagline{
  position:absolute;
  bottom:0px;
  font-size:3px;
  font-weight:600;
  color:#6f2b67;
  letter-spacing:0.4px;
  text-transform:uppercase;
  opacity:0.85;
}

.container-box{
  max-width:520px;
  width:100%;
  border:2px solid #6f2b67;
  border-radius:16px;
  padding:20px 24px;
  box-shadow:0 8px 30px rgba(111,43,103,0.18);
  background:#fff;
}

.title{
  font-size:18px;
  font-weight:700;
  margin-bottom:8px;
  text-align:center;
  margin-top:3px;
  color:#6f2b67;
}
.title-animated{
  display:inline-block;
  opacity:0;
  animation:fadeIn 0.5s forwards;
}

.sub{
  color:#8e4a86;
  margin-bottom:15px;
  text-align:center;
  font-size:12px;
}

.form-control{
  background:#fff;
  border:2px solid #d8b5d8;
  color:#6f2b67;
  border-radius:50px;
  padding:6px 16px;
  height:32px;
  font-size:12px;
  transition:all 0.3s;
}
.form-control::placeholder{color:#b89eb8;}
.form-control:focus{
  box-shadow:0 0 0 0.25rem rgba(111,43,103,0.12);
  border-color:#6f2b67;
  background:#fff;
  color:#6f2b67;
  outline:none;
}
.error{
  font-size:10px;
  color:#dc3545;
  height:12px;
  margin-top:2px;
  margin-left:10px;
}

.btn-purple{
  background:#6f2b67;
  color:#fff;
  border:none;
  font-weight:600;
  border-radius:50px;
  height:38px;
  font-size:13px;
  box-shadow:0 4px 12px rgba(111,43,103,0.25);
  transition:all 0.3s;
  animation:droplet 3s infinite;
  width:100%;
}
.btn-purple:hover{
  background:#8e4a86;
  transform:translateY(-2px);
  box-shadow:0 5px 16px rgba(111,43,103,0.35);
}
.btn-purple:disabled{
  background:#d8b5d8;
  cursor:not-allowed;
  color:#fff;
}

.password-wrapper{position:relative;}
.eye-icon{
  position:absolute;
  right:16px;
  top:50%;
  transform:translateY(-50%);
  cursor:pointer;
  color:#6f2b67;
  font-size:14px;
  transition:all 0.3s;
}
.eye-icon:hover{
  color:#8e4a86;
  transform:translateY(-50%) scale(1.1);
}

.back-link{font-size:13px;font-weight:700;color:#0d0000;text-align:center;margin-top:12px;}
.back-link a{color:#6f2b67;text-decoration:none;font-weight:900;text-transform:uppercase;margin-left:4px;border-bottom:2px solid transparent;transition:all .3s;}
.back-link a:hover{border-bottom:2px solid #6f2b67;}

.right-img{
  display:flex;
  justify-content:center;
  align-items:center;
}
.right-img img{
  width:180px;
  max-width:100%;
  filter:drop-shadow(0 3px 12px rgba(111,43,103,0.2));
}

.mb-2{margin-bottom:8px!important;}
.mt-2{margin-top:8px!important;}

@media(max-width:768px){
  .right-img{display:none;}
  .container-box{padding:18px 20px;max-width:420px;}
}
@media(max-width:480px){
  .container-box{max-width:360px;padding:16px 18px;}
  .logo-circle{width:45px;height:45px;}
  .book-logo{width:25px;}
  .title{font-size:16px;}
  .sub{font-size:11px;}
}
</style>
</head>

<body>

<div class="container-box">
  <div class="row align-items-center g-0">

  <!-- LEFT FORM -->
  <div class="col-md-6">

     <div class="logo-circle">
        <img src="https://cdn-icons-png.flaticon.com/512/2702/2702134.png" class="book-logo" alt="Book">
        <div class="logo-text">LitHeaven</div>
        <div class="tagline">Your Literary Escape</div>
    </div>
    
    <div class="title mb-1" id="animatedTitle"></div>
    <div class="sub">Enter your email to reset password</div>
    
    <form id="resetForm">

      <div class="mb-2">
        <input type="email" id="email" class="form-control" placeholder="Email Address">
        <div class="error" id="emailErr"></div>
      </div>

      <button type="submit" id="resetBtn" class="btn btn-purple mt-2">
        RESET PASSWORD
      </button>

      <div class="back-link">
          Remembered your password? <a href="/login">Login</a>
      </div>

    </form>
  </div>

  <!-- RIGHT IMAGE -->
  <div class="col-md-6 right-img">
    <img src="/images/pngtree-cute-stylish-teen-girl-t.png" alt="Girl Reading Book">
  </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

 function showGooglePopup() {
  Swal.fire({
    icon: 'info',
    title: 'Google Account Detected',
    html: `
      <div style="font-size:14px;line-height:1.6;color:#555">
        This email is linked with a
        <b style="color:#6f2b67">Google Sign-In</b> account.<br><br>
        Password reset is not required.<br>
        Please login using Google.
      </div>

      <div style="margin-top:16px;display:flex;justify-content:center">
        <img
          src="https://developers.google.com/identity/images/g-logo.png"
          alt="Google"
          style="width:36px;height:36px"
        />
      </div>
    `,
    confirmButtonText: 'Continue with Google',
    confirmButtonColor: '#6f2b67',   
    showCancelButton: true,
    cancelButtonText: 'Cancel',
    cancelButtonColor: '#d6c3d3',
    reverseButtons: true,
   
  }).then(r => {
    if (r.isConfirmed) {
      window.location.href = '/auth/google';
    }
  });
}

function showErrorPopup(msg) {
  Swal.fire({
    icon: "error",
    title: "Error",
    text: msg || "Something went wrong",
    confirmButtonColor:"#6f2b67"
  });
}


const titleText="Forgot Password";
const titleEl=document.getElementById("animatedTitle");
titleText.split("").forEach((char,i)=>{
  const span=document.createElement("span");
  span.className="title-animated";
  span.style.animationDelay=`${i*0.1}s`;
  span.textContent=char===" "?"\u00A0":char;
  titleEl.appendChild(span);
});

const resetForm=document.getElementById("resetForm");
const emailField=document.getElementById("email");
const emailErr=document.getElementById("emailErr");
const resetBtn=document.getElementById("resetBtn");

resetForm.addEventListener("submit",async(e)=>{
  e.preventDefault();
  
  const email=emailField.value.trim();
  const emailRegex=/^[a-z0-9._%*+-]+@[a-z0-9.-]+\.[a-z]{2,}$/;
  
  if(email===""){
    emailErr.textContent="Email is required";
    return;
  }else if(!emailRegex.test(email)){
    emailErr.textContent="Invalid email format";
    return;
  }else{
    emailErr.textContent="";
  }


  resetBtn.disabled = true;
  resetBtn.innerText = "Sending OTP...";
  
  try{
    const res=await fetch("/forgot-password",{
      method:"POST",
      headers:{
        "Content-Type":"application/json"
      },
      body:JSON.stringify({email})
    });
    
    const result=await res.json();
    
    if (!res.ok) {
  if (result.message?.toLowerCase().includes("google")) {
    showGooglePopup();   
  } else {
    showErrorPopup(result.message); 
  }

  resetBtn.disabled = false;
  resetBtn.innerText = "RESET PASSWORD";
  return;
}

    
  window.location.href = result.redirect;
    
  }catch(err){
    Swal.fire({
      icon:"error",
      title:"Server Error",
      text:"Something went wrong. Try again later.",
      confirmButtonColor:"#6f2b67"
    });

    resetBtn.disabled = false;
    resetBtn.innerText = "RESET PASSWORD";
  }
});

emailField.addEventListener("input",()=>{
  const emailRegex=/^[a-z0-9._%*+-]+@[a-z0-9.-]+\.[a-z]{2,}$/;
  if(emailField.value.trim()===""){
    emailErr.textContent="Email is required";
  }else if(!emailRegex.test(emailField.value)){
    emailErr.textContent="Invalid email format";
  }else{
    emailErr.textContent="";
  }
});
</script>

</body>
</html>