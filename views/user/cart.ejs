  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    /* ═══════════════════════════════════════════
       CART DATA
    ═══════════════════════════════════════════ */
   

    let cartItems = []

async function loadCart() {

  const res = await fetch("/get-cart")
  const data = await res.json()

  cartItems = data.items || []

  renderCart()

  handleEmptyCart() 
  updateSummary()
}
function handleEmptyCart() {

  const emptyCart = document.getElementById("emptyCart")
  const table = document.querySelector(".cart-card")

  const summary = document.getElementById("summarySection")
  const emptyBtn = document.getElementById("emptyCartBtn")

  
  if (!cartItems || cartItems.length === 0) {

    emptyCart.style.display = "block"
    table.style.display = "none"

    summary.style.display = "none"
    emptyBtn.style.display = "none"

  } else {

    emptyCart.style.display = "none"
    table.style.display = "block"

    summary.style.display = "block"
    emptyBtn.style.display = "flex"
  }
}
  
    function fmt(n){ return '₹' + n.toLocaleString('en-IN'); }
    function discPct(item){ return Math.round(((item.mrp - item.price) / item.mrp) * 100); }

    /* ═══════════════════════════════════════════
       RENDER TABLE — called only ONCE on load
       and again only when a row is removed
    ═══════════════════════════════════════════ */
    function renderCart() {
  const tbody = document.getElementById("cartBody")
  tbody.innerHTML = ""

  cartItems.forEach((item, index) => {

    const product = item.productId
    const isOut = item.stock === 0

    //FIND CORRECT VARIANT
    const variant = product?.variants?.find(
      v => v.language?._id?.toString() === item.languageId?._id?.toString()
    )

    const formatData = variant?.formats?.find(
      f => f.format === item.format
    )

    const image = variant?.thumbnail?.url || "/images/default.jpg"
    const title = product?.title || "No Title"
    const author = product?.author?.name || "Unknown"
    const price = formatData?.price || 0
    const qty = item.quantity || 1

    const total = price * qty

    const tr = document.createElement("tr")

    tr.innerHTML = `
      <td>
        <div class="item-num">${index + 1}</div>
      </td>

      <td class="td-product">
        <div class="item-product">
          <img src="${image}" class="item-thumb">

          <div>
            <div class="item-title">${title}</div>
            <div class="item-author">By: ${author}</div>
            <span class="item-format">${item.format}</span>
            ${isOut ? `
              <span style="color:red;font-size:12px;font-weight:bold;margin-left:6px;white-space:nowrap;">
               🚫 Out of Stock
              </span>
              ` : ''}
          </div>
        </div>
      </td>

      <td>
        <div class="price-new">₹${price}</div>
      </td>

      <td>
        <div class="qty-ctrl">
        <button class="qty-btn" ${isOut ? 'disabled' : ''} onclick="changeQty('${item._id}', -1)">−</button>
          <span class="qty-num" id="qty-${item._id}">${qty}</span>
        <button class="qty-btn" ${isOut ? 'disabled' : ''} onclick="changeQty('${item._id}', 1)">+</button>
        </div>
      </td>

      <td>
        <div class="total-val" id="total-${item._id}">₹${total}</div>
      </td>

      
      <td data-label="Actions">
        <div class="action-cell">
            <button class="btn-wish"
                onclick="moveToWishlist('${item.productId._id}','${item.languageId._id}','${item.format}')">
                <i class="fa-regular fa-heart"></i> Wishlist
            </button>
          <button class="btn-del" onclick="removeItem('${item.productId._id}', '${item.languageId._id}', '${item.format}')">
            🗑 Remove
          </button>
        </div>
      </td>
    `

    tbody.appendChild(tr)
  })
}

function changeQty(id, delta) {

 const item = cartItems.find(i => i._id.toString() === id.toString())

   console.log("ITEM 👉", item) 

  if (!item) return
         const product = item.productId   // ✅ FIRST define

  console.log("PRODUCT 👉", product)

   console.log("VARIANTS 👉", product?.variants) 
  
  let newQty = item.quantity + delta

  // ✅ LIMIT
  if (newQty < 1) newQty = 1
  if (newQty > 8) {
  Swal.fire({
  icon: "error",
  title: "Limit Reached 🚫",
  text: "Maximum 8 items allowed"
})
    return
  }

  item.quantity = newQty

  // ✅ UPDATE UI
  document.getElementById(`qty-${id}`).innerText = newQty


  const variant = product?.variants?.find(
    v => v.language?._id?.toString() === item.languageId?._id?.toString()
  )

  const formatData = variant?.formats?.find(
    f => f.format === item.format
  )

  const price = formatData?.price || 0
  const total = price * newQty

  document.getElementById(`total-${id}`).innerText = "₹" + total

  updateSummary()
}
    /* ═══════════════════════════════════════════
       ✅ CHANGE QTY — NO PAGE REFRESH
       Only updates the 3 elements that changed:
         1. qty number span
         2. − / + button disabled state
         3. row total
       Then calls updateSummary() for the panel
    ═══════════════════════════════════════════ */
    async function moveToWishlist(productId, languageId, format){

  // 1️ Add to wishlist
  const res = await fetch('/wishlist/toggle',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ productId, languageId, format })
  })

  const data = await res.json()

  if(data.status === "added"){

    // 2️ Remove from cart
    await fetch('/remove-cart-item',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ productId, languageId, format })
    })
      loadWishlistCount()


    // 3 UI update
    cartItems = cartItems.filter(item =>
      !(item.productId._id === productId &&
        item.languageId._id === languageId &&
        item.format === format)
    )

    renderCart()
    updateSummary()
    handleEmptyCart()
  

    // 4️ toast
    Swal.fire({
      toast:true,
      position:'top-end',
      icon:'success',
      title:'Moved to Wishlist ❤️',
      timer:2000,
      showConfirmButton:false
    })
  }
}
    /* ═══════════════════════════════════════════
       UPDATE SUMMARY PANEL ONLY
    ═══════════════════════════════════════════ */
  function updateSummary() {

  let totalPrice = 0
  let totalQty = 0

  cartItems.forEach(item => {

    const product = item.productId

    const variant = product?.variants?.find(
      v => v.language?._id?.toString() === item.languageId?._id?.toString()
    )

    const formatData = variant?.formats?.find(
      f => f.format === item.format
    )

    const price = formatData?.price || 0

    totalPrice += price * item.quantity
    totalQty += item.quantity
  })

  // UI UPDATE
  document.getElementById("summaryMRP").innerText = "₹" + totalPrice
  document.getElementById("finalAmt").innerText = totalPrice
  document.getElementById("summaryItemLbl").innerText = `Subtotal (${totalQty} items)`
  document.getElementById("topbarCount").innerText = totalQty + " items"
  document.getElementById("cartBadge").innerText = totalQty
}
  

    /* ═══════════════════════════════════════════
       WISHLIST TOGGLE
    ═══════════════════════════════════════════ */
    function toggleWish(btn) {
      const on = btn.classList.toggle('wishlisted');
      btn.innerHTML = on
        ? '<i class="fa-solid fa-heart"></i> Wishlisted'
        : '<i class="fa-regular fa-heart"></i> Wishlist';
    }

    /* ═══════════════════════════════════════════
       REMOVE ITEM
    ═══════════════════════════════════════════ */
   async function removeItem(productId, languageId, format) {

  Swal.fire({
    title: "Remove this item? 🗑️",
    text: "This product will be removed from your cart",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, Remove",
    cancelButtonText: "Cancel",
    confirmButtonColor: "#e53935",
    cancelButtonColor: "#6f2b67",
    background: "linear-gradient(135deg,#f6eef6,#efe3f0)"
  }).then(async (result) => {

    //  Cancel
    if (!result.isConfirmed) return

    //  Proceed delete
    const res = await fetch("/remove-cart-item", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ productId, languageId, format })
    })

    const data = await res.json()

    if (data.status === "removed") {

      // UI remove
      cartItems = cartItems.filter(item =>
        !(
          item.productId._id === productId &&
          item.languageId._id === languageId &&
          item.format === format
        )
      )

      renderCart()
      updateSummary()
      handleEmptyCart()
      //  success popup
      Swal.fire({
        icon: "success",
        title: "Removed!",
        text: "Item removed from cart",
        timer: 1500,
        showConfirmButton: false
      })
    }

  })
}
    /* ═══════════════════════════════════════════
       EMPTY CART
    ═══════════════════════════════════════════ */
   function confirmEmptyCart() {

  Swal.fire({
    title: "Empty Cart? 🛒",
    text: "All items will be removed!",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, Clear All",
    cancelButtonText: "Cancel",
    confirmButtonColor: "#e53935",
    cancelButtonColor: "#6f2b67",
    background: "linear-gradient(135deg,#f6eef6,#efe3f0)"
  }).then(async (result) => {

    if (!result.isConfirmed) return

    const res = await fetch("/clear-cart", {
      method: "POST"
    })

    const data = await res.json()

    if (data.status === "cleared") {

      // CLEAR UI
      cartItems = []

      renderCart()
      updateSummary()
      handleEmptyCart()

      Swal.fire({
        icon: "success",
        title: "Cart Cleared!",
        text: "All items removed successfully",
        timer: 1500,
        showConfirmButton: false
      })
    }

  })
}
    /* ═══════════════════════════════════════════
       MOBILE MENU
    ═══════════════════════════════════════════ */
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    menuToggle?.addEventListener('click', function () {
      mobileMenu.classList.toggle('open');
      const icon = this.querySelector('i');
      icon.classList.toggle('fa-bars');
      icon.classList.toggle('fa-xmark');
    });
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        const icon = menuToggle?.querySelector('i');
        if (icon) { icon.classList.add('fa-bars'); icon.classList.remove('fa-xmark'); }
      });
    });
    document.addEventListener('click', function(e) {
      if (mobileMenu && menuToggle && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
        mobileMenu.classList.remove('open');
        const icon = menuToggle.querySelector('i');
        if (icon) { icon.classList.add('fa-bars'); icon.classList.remove('fa-xmark'); }
      }
    });

    async function loadWishlistCount() {

  try {
    const res = await fetch("/wishlist-data")
    const data = await res.json()

    const count = data.totalItems || 0

    const badge = document.getElementById("wishlistBadge")

    if (count > 0) {
      badge.style.display = "flex"
      badge.innerText = count
    } else {
      badge.style.display = "none"
    }

  } catch (err) {
    console.log(err)
  }
}

async function refreshCartStock() {

  try {
    const res = await fetch("/get-cart")
    const data = await res.json()

    const newItems = data.items || []

    // compare stock changes
    newItems.forEach(newItem => {

      const oldItem = cartItems.find(i =>
        i.productId._id === newItem.productId._id &&
        i.languageId._id === newItem.languageId._id &&
        i.format === newItem.format
      )

      if (!oldItem) return

      // 🚨 STOCK CHANGED
      if (oldItem.stock !== newItem.stock) {

        // update local
        oldItem.stock = newItem.stock

        //  UPDATE UI ONLY THAT ROW
        const qtyMinus = document.querySelector(`button[onclick*="${oldItem._id}"][onclick*="-1"]`)
        const qtyPlus  = document.querySelector(`button[onclick*="${oldItem._id}"][onclick*="1"]`)

        if (newItem.stock === 0) {

          // disable qty
          qtyMinus?.setAttribute("disabled", true)
          qtyPlus?.setAttribute("disabled", true)

          // show OUT OF STOCK
          const row = qtyMinus.closest("tr")

          if (!row.innerHTML.includes("Out of Stock")) {
            row.querySelector(".item-format").insertAdjacentHTML("afterend", `
              <span style="color:red;font-size:12px;font-weight:bold;margin-left:6px;">
                🚫 Out of Stock
              </span>
            `)
          }

        } else {
          // enable again
          qtyMinus?.removeAttribute("disabled")
          qtyPlus?.removeAttribute("disabled")
        }
      }
    })

  } catch (err) {
    console.log("Stock refresh error", err)
  }
}

    /* ── LOGOUT ── */
    document.getElementById('logoutBtn')?.addEventListener('click', function(e) {
      e.preventDefault();
      Swal.fire({
        title: "<span style='color:#6f2b67;font-weight:700'>Logout?</span>",
        html: `<p style="font-size:14px;color:#555;margin-bottom:8px">Are you sure you want to logout? 💜</p>
               <p style="font-size:13px;color:#888">You can login again anytime.</p>`,
        showCancelButton: true,
        confirmButtonText: "🚪 Logout",
        cancelButtonText: "Stay Here",
        confirmButtonColor: "#6f2b67",
        cancelButtonColor: "#d6c3d3",
        reverseButtons: true,
        background: "linear-gradient(135deg, #f6eef6, #efe3f0)",
      }).then(r => { if (r.isConfirmed) window.location.href = "/logout"; });
    });



    /* ── INIT ── */
   loadCart()
   loadWishlistCount() 

   setInterval(() => {
  refreshCartStock()
}, 5000)
  </script>
