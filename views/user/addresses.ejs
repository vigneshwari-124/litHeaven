<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>LitHeaven - My Addresses</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
:root{--purple:#6f2b67;--light:#8e4a86}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Segoe UI",Roboto,Arial;background:linear-gradient(135deg,#f5f0f6 0%,#e8dff0 50%,#f0e5f5 100%);color:#6f2b67;overflow-x:hidden;max-width:100vw}

@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
@keyframes droplet{0%{transform:scale(1);border-radius:50%}50%{transform:scale(1.1);border-radius:60% 40% 60% 40%}100%{transform:scale(1);border-radius:50%}}


header.navbar-area{background:var(--purple);color:#fff;padding:12px 0}
.navbar-container{max-width:100%;padding:0 15px;margin:0 auto}
.nav-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:15px}
.brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#fff}
.logo-circle{width:60px;height:60px;border-radius:50%;border:2px solid #fff;display:flex;align-items:center;justify-content:center;animation:float 3s ease-in-out infinite;position:relative}
.book-logo{width:35px;filter:brightness(0)invert(1)}
.logo-text{position:absolute;bottom:5px;font-size:7px;font-weight:800;color:#fff;letter-spacing:.8px;text-transform:uppercase}
.tagline{position:absolute;bottom:0;font-size:3.5px;font-weight:600;color:#fff;letter-spacing:.5px;text-transform:uppercase;opacity:.85}
.brand .txt{font-weight:800;font-size:20px;letter-spacing:.6px}
.main-nav{display:flex;gap:20px}
.main-nav .nav-link{color:#fff;font-weight:600;padding:8px 12px;transition:all .3s;text-decoration:none}
.main-nav .nav-link:hover{color:#f3dff1;transform:translateY(-2px)}
.header-icons{display:flex;gap:16px;align-items:center}
.icon-btn{color:#fff;font-size:20px;cursor:pointer;transition:all .3s;position:relative}
.icon-btn:hover{transform:scale(1.2)}
.icon-badge{position:absolute;top:-6px;right:-8px;background:#fff;color:var(--purple);font-weight:700;font-size:11px;width:18px;height:18px;display:flex;align-items:center;justify-content:center;border-radius:50%;animation:pulse 2s infinite}


.fancy-header{display:flex;align-items:center;justify-content:space-between;padding:10px 0;margin-bottom:30px;}
.header-left{display:flex;align-items:center;gap:14px;}
.header-icon{font-size:22px;color:#6f2b67;}
.fancy-header h2{margin:0;font-size:26px;font-weight:800;color:#6f2b67;}
.header-subtitle{margin:2px 0 0;font-size:13px;color:#8e4a86;}
.btn-header{animation:none;box-shadow:none;}

.search-wrap{display:flex;justify-content:center;padding:30px 15px;background:#fff}
.search-box{width:100%;max-width:600px;background:#fff;border-radius:50px;padding:12px 24px;display:flex;gap:12px;align-items:center;box-shadow:0 6px 20px rgba(111,43,103,.15);border:1px solid #702767}
.search-box input{flex:1;border:0;background:0 0;outline:0;color:#702767;font-size:15px}
.search-box input::placeholder{color:#702767}
.search-box .btn-search{background:#702767;border:0;color:#fff;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;padding:0;transition:all .3s}
.search-box .btn-search:hover{transform:rotate(90deg)scale(1.1)}


.empty-address{  min-height: 300px;  display: flex;  flex-direction: column;  align-items: center;justify-content: center;  }
/* .empty-address h4{ margin:2px 0 4px;} */
.empty-address-img{width:220px; max-width:100%;opacity:1;}
.empty-address p{  margin:0;  font-size:14px;  color:#8e4a86;}
.main-container{max-width:1200px;margin:30px auto;padding:0 20px;display:flex;gap:20px}

.sidebar{width:240px;background:#fff;border:2px solid #6f2b67;border-radius:16px;padding:15px;height:fit-content;position:sticky;top:20px}
.sidebar-nav{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:6px}
.sidebar-link{display:flex;align-items:center;gap:12px;padding:12px 15px;color:#6f2b67;text-decoration:none;font-weight:600;font-size:14px;border-radius:10px;transition:all .3s;border:2px solid transparent}
.sidebar-link:hover{background:#f5f0f6;border-color:#d8b5d8}
.sidebar-link.active{background:#6f2b67;color:#fff}
.sidebar-link i{font-size:16px;width:20px}

.content{flex:1}
.addresses-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px}
.addresses-header h2{font-size:28px;font-weight:700;color:#6f2b67}
.btn-add{background:#6f2b67;color:#fff;border:none;padding:11px 28px;border-radius:50px;font-weight:600;font-size:14px;cursor:pointer;transition:all .3s;animation:droplet 3s infinite;box-shadow:0 4px 12px rgba(111,43,103,.25)}
.btn-add:hover{background:#8e4a86;transform:translateY(-2px)}

.center-heading{  justify-content: center;text-align: center;}
.center-heading h2{width:100%;}

.address-grid{display: flex;flex-direction: column;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.address-card{background:#fff;border:2px solid #6f2b67;border-radius:16px;padding:18px 24px;transition:all .3s;display: flex;align-items: center;justify-content: space-between;gap: 20px;}
.address-left{display:flex; align-items: center; gap: 20px; flex: 1;}
.address-card:hover{box-shadow:0 8px 24px rgba(111,43,103,.15);transform:translateY(-2px)}
.address-type{display:inline-flex;align-items:center;gap:6px;background:#f5f0f6;color:#6f2b67;padding:8px 16px;border-radius:20px;font-size:13px;font-weight:600;white-space: nowrap;min-width: 100px;justify-content: center;}
.address-type i{font-size:14px}
.address-details{color:#555;font-size:14px;line-height:1.6;margin:0; display: flex; flex-wrap: wrap; gap: 8px;align-items: center;}
.address-details strong{color: #6f2b67 ; margin-right: 8px;}
.address-actions{display:flex;gap:10px; margin-left:auto;}
.btn-action{padding:9px 20px;border-radius:30px;font-weight:600;font-size:13px;cursor:pointer;border:2px solid #6f2b67;background:#fff;color:#6f2b67;transition:.2s; white-space: nowrap;}
.btn-action:hover{background:#6f2b67;color:#fff}
.btn-edit{background:#6f2b67;color:#fff}
.btn-edit:hover{background:#8e4a86}
.btn-delete{background:#fff;color:#8e4a86;border:2px solid #8e4a86}
.btn-delete:hover{background:#8e4a86;color:#fff}
.primary-badge {margin-left: 8px;font-size: 10px;background: #6f2b67;color: #fff;padding: 4px 12px;border-radius: 20px;font-weight: 600;}
.modal{display:none;position:fixed;z-index:10000;left:0;top:0;width:100%;height:100%;background:rgba(0,0,0,.6);overflow:hidden;padding:20px;align-items:center;justify-content:center;}
body.modal-open {overflow:hidden;position:fixed;width:100%;height:100%;}
.sidebar{position:relative;z-index:1;}
.modal-content{background:#fff;margin:0;padding:0;width:90%;max-width:450px;border-radius:16px;border:2px solid #6f2b67;max-height:85vh;display:flex;flex-direction:column}
.modal-header{padding:18px 22px;border-bottom:2px solid #d8b5d8;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.modal-title{font-size:18px;font-weight:700;color:#6f2b67;margin:0}
.close{color:#6f2b67;font-size:26px;font-weight:700;cursor:pointer;border:none;background:none}
.close:hover{color:#8e4a86}
.modal-body{padding:18px;overflow-y:auto;flex:1}

.form-group{margin-bottom:16px;position: relative;}
.form-label{display:block;font-weight:600;color:#6f2b67;margin-bottom:6px;font-size:13px}
.form-control{width:100%;background:#fff;border:2px solid #d8b5d8;color:#6f2b67;border-radius:50px;padding:10px 18px;font-size:14px;transition:all .3s}
.form-control:focus{outline:none;border-color:#6f2b67}
.form-control.input-error { border-color: #dc3545;background: #fff5f5;}
.form-control.input-success {border-color: #28a745;background: #f5fff5;}
.error-text {
  display: none;
  color: #dc3545;
  font-size: 12px;
  font-weight: 500;
  margin-top: 4px;
  padding-left: 18px;
}

.form-control.input-error + .error-text {
  display: block;
}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.radio-group{display:flex;gap:15px;margin-top:8px}
.radio-option{display:flex;align-items:center;gap:8px;cursor:pointer}
.radio-option input{width:18px;height:18px;cursor:pointer}
.radio-option label{cursor:pointer;font-size:14px}
.btn-group{display:flex;gap:12px;margin-top:20px;justify-content:center}
.btn{padding:11px 30px;border-radius:50px;font-weight:600;font-size:14px;border:none;cursor:pointer;transition:all .3s;}
.btn-primary{background:#6f2b67;color:#fff;border:2px solid #6f2b67}
.btn-primary:hover{background:#8e4a86;border-color:#8e4a86;color:#fff}
.btn-primary:focus, .btn-primary:focus-visible, .btn-primary:active{ outline:none !important; box-shadow:0 0 0 3px rgba(111,43,103,.3) !important; border-color:#6f2b67 !important; background:#6f2b67 !important; color:#fff !important; }



.btn-secondary{background:#fff;color:#6f2b67;border:2px solid #6f2b67}
.btn-secondary:hover{background:#f5f0f6}

.swal-cancel-purple{background:#fff!important;color:#6f2b67!important;border:2px solid #6f2b67!important;box-shadow:none!important}
.swal-cancel-purple:hover{background:#6f2b67!important;color:#fff!important}

.logout-btn{width:100%;background:none;border:#6f2b67;text-align:left;display:flex;align-items:center;gap:12px;padding:12px 15px;font-weight:600;font-size:14px;color:#6f2b67;border-radius:10px;transition:all .3s;border-top:1px solid #a75ea7;}
.logout-btn i{font-size:16px;width:20px;color:#6f2b67;}
.logout-btn:hover{background:#d8b5d8;transform:translateX(3px);}

footer{background:#6f2b67;color:#fff;padding:25px 20px;margin-top:50px}
.footer-content{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:25px}
.footer-section h5{font-size:15px;font-weight:700;margin-bottom:12px}
.footer-section p,.footer-section a{font-size:13px;color:#d8b5d8;text-decoration:none;display:block;margin-bottom:6px}
.footer-section a:hover{color:#fff}
.footer-bottom{text-align:center;margin-top:15px;padding-top:15px;border-top:1px solid rgba(255,255,255,.2);font-size:12px}

@media(max-width:768px){
  .main-container{flex-direction:column}
  .sidebar{width:100%;position:static}
  .sidebar-nav{flex-direction:row;flex-wrap:wrap}
  .sidebar-nav li{flex:1;min-width:140px}
  .main-nav{display:none}
  .nav-row{flex-wrap:wrap;gap:10px}
  .search-wrap{padding:20px 15px}
  .addresses-header{flex-direction:column;gap:15px;align-items:flex-start}
  .btn-add{width:100%}
  .address-grid{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .brand .txt{font-size:18px}
  .logo-circle{width:50px;height:50px}
  .book-logo{width:28px}
  .address-card {flex-direction: column;align-items: flex-start;padding: 16px;}
  .address-left {  flex-direction: column; align-items: flex-start; width: 100%; gap: 12px;}
  .address-actions { width: 100%;margin-left: 0;}
  .btn-action {flex: 1;}
  
}

@media(max-width:414px){
  .sidebar-link{font-size:12px;padding:10px 12px}
  .sidebar-link i{font-size:14px}
  .modal-content{width:95%;max-height:calc(100vh - 20px)}
  .navbar-container{padding:0 10px}
  .logo-text{font-size:6px}
  .brand .txt{font-size:16px}
  .logo-circle{width:45px;height:45px}
  .book-logo{width:25px}
  .search-wrap{padding:15px 10px}
  .addresses-header h2{font-size:22px}
  .modal{padding:10px}
}
</style>
</head>
<body>

<header class="navbar-area">
  <div class="navbar-container">
    <div class="nav-row">
      <a class="brand" href="/">
        <div class="logo-circle">
          <img src="https://cdn-icons-png.flaticon.com/512/2702/2702134.png" class="book-logo" alt="Book">
          <div class="logo-text">LitHeaven</div>
          <div class="tagline">Your Literary Escape</div>
        </div>
        <div class="txt">LitHeaven</div>
      </a>
      <nav class="main-nav d-none d-lg-flex">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/shop">Shop</a>
        <a class="nav-link" href="/about">About</a>
        <a class="nav-link" href="/contact">Contact</a>
      </nav>
      <div class="header-icons">
        <div class="icon-btn"><i class="fa-regular fa-heart"></i></div>
        <div class="icon-btn">
          <i class="fa-solid fa-cart-shopping"></i>
          <div class="icon-badge">2</div>
        </div>
       <a href="/profile" class="icon-btn"><i class="fa-regular fa-user"></i></a>
      </div>
    </div>
  </div>
</header>

<div class="search-wrap">
  <div class="search-box">
    <input type="text" placeholder="What are you looking for?">
    <button class="btn-search"><i class="fa-solid fa-magnifying-glass"></i></button>
  </div>
</div>

<div class="main-container">

 
  <aside class="sidebar">
    <ul class="sidebar-nav">
      <li>
        <a href="#" class="sidebar-link">
          <i class="fa-solid fa-box"></i><span>My Orders</span>
        </a>
      </li>

      <li>
        <a href="/profile" class="sidebar-link">
          <i class="fa-solid fa-gear"></i><span>Settings</span>
        </a>
      </li>

      <li>
        <a href="/addresses" class="sidebar-link active">
          <i class="fa-solid fa-location-dot"></i><span>Addresses</span>
        </a>
      </li>

      <li>
        <a href="/wallet" class="sidebar-link">
          <i class="fa-solid fa-wallet"></i><span>Wallet</span>
        </a>
      </li>

      <li>
        <a href="/reviews" class="sidebar-link">
          <i class="fa-solid fa-star"></i><span>My Reviews</span>
        </a>
      </li>

      <li>
        <a href="/coupons" class="sidebar-link">
          <i class="fa-solid fa-ticket"></i><span>My Coupons</span>
        </a>
      </li>

      <li class="mt-2">
        <button type="button" id="logoutBtn" class="sidebar-link logout-btn">
          <i class="fa-solid fa-right-from-bracket"></i>
          <span>Logout</span>
        </button>
      </li>
    </ul>
  </aside>

  
  <div class="content">

    
   <div class="addresses-header fancy-header
  <%= addresses.length %>">

  <div class="header-left">
    <div class="header-icon">
      <i class="fa-solid fa-location-dot"></i>
    </div>

    <div>
      <h2>My Addresses</h2>
      <p class="header-subtitle">
        Manage your saved delivery locations
      </p>
    </div>
  </div>

  <% if (addresses.length > 0) { %>
    <button class="btn-add btn-header" onclick="openAddModal()">
      <i class="fa-solid fa-plus"></i> Add Address
    </button>
  <% } %>

</div>

    <% if (addresses.length === 0) { %>

      <div class="empty-address">
        <img src="/images/addyouaddress.png" alt="No address"  class="empty-address-img">
        <h4>No address added yet</h4>
        <p>Add an address to get started</p>

        <button class="btn-add" style="margin-top:15px" onclick="openAddModal()"> Add Address</button>
      </div>

    <% } else { %>

    <div class="address-grid">
      <% addresses.forEach(addr => { %>

        <div class="address-card">

          
    <div class="address-left">
          <div class="address-type">
  <i class="fa-solid 
    <%= addr.type === 'Home' ? 'fa-house' : addr.type === 'Office' ? 'fa-briefcase' : 'fa-map-pin' %>">
  </i>

  <%= addr.type %>

  
   <% if (addr.isPrimary) { %>
    <span class="primary-badge">Primary</span>
  <% } %>
</div>


          <div class="address-details">
            <strong><%= addr.fullName %></strong><br>
            <span>|</span>
            <%= addr.addressLine1 %>, <%= addr.addressLine2 %><br>
            <span>|</span>
            <%= addr.city %> - <%= addr.zip %><br>
            <span>|</span>
            <%= addr.country %>
          </div>
        </div>

          <div class="address-actions">
          
     <button class="btn-action btn-edit"
  data-id="<%= addr._id %>"
  data-name="<%= addr.fullName %>"
  data-line1="<%= addr.addressLine1 %>"
  data-line2="<%= addr.addressLine2 || '' %>"
  data-city="<%= addr.city %>"
  data-state="<%= addr.state %>"
  data-zip="<%= addr.zip %>"
  data-country="<%= addr.country %>"
  data-type="<%= addr.type %>"
  onclick="openEditModalFromBtn(this)">
  <i class="fa-solid fa-pen"></i> Edit
</button>
            <button class="btn-action btn-delete"
              onclick="deleteAddress('<%= addr._id %>')">
               <i class="fa-solid fa-trash"></i> Delete
            </button>
          </div>

        </div>

      <% }) %>
    </div>

    <% } %>

  </div> 

</div> 
<div id="addressModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title" id="modalTitle">Add Address</h3>
      <button class="close" onclick="closeModal()">&times;</button>
    </div>
    <div class="modal-body">
      <form onsubmit="saveAddress(event)">
        <div class="form-group">
          <label class="form-label">Full Name <span style="color:red">*</span></label>
          <input type="text" class="form-control" id="name" placeholder="Enter name">
          <small class="error-text">Enter Full Name</small>
        </div>
        
        <div class="form-group">
          <label class="form-label">Address 1  <span style="color:red">*</span></label>
          <input type="text" class="form-control" id="address1" placeholder="Door No" >
          <small class="error-text">Enter Address1</small>
        </div>

        <div class="form-group">
          <label class="form-label">Address 2</label>
          <input type="text" class="form-control" id="address2" placeholder="Street Name">
          <small class="error-text">Enter Address2</small>
        </div>
        
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">City  <span style="color:red">*</span> </label>
            <input type="text" class="form-control" id="city" placeholder="City" >
            <small class="error-text">Enter City</small>
          </div>
          
          <div class="form-group">
            <label class="form-label">State <span style="color:red">*</span></label>
            <input type="text" class="form-control" id="state" placeholder="State">
            <small class="error-text">Enter State</small>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Zip  <span style="color:red">*</span></label>
            <input type="text" class="form-control" id="zip" placeholder="6-digit code" 
              maxlength="6"
              oninput="this.value = this.value.replace(/[^0-9]/g, '')" >
            <small class="error-text">Enter Zip</small>
          </div>
          
          <div class="form-group">
            <label class="form-label">Country <span style="color:red">*</span></label>
            <input type="text" class="form-control" id="country" placeholder="Country" >
            <small class="error-text">Enter Country</small>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Address Type <span style="color:red">*</span></label>
          <div class="radio-group">
            <div class="radio-option">
              <input type="radio" id="typeHome" name="addressType" value="home" checked>
              <label for="typeHome"><i class="fa-solid fa-house"></i> Home</label>
            </div>
            <div class="radio-option">
              <input type="radio" id="typeOffice" name="addressType" value="office">
              <label for="typeOffice"><i class="fa-solid fa-briefcase"></i> Office</label>
            </div>
            <div class="radio-option">
              <input type="radio" id="typeOther" name="addressType" value="other">
              <label for="typeOther"><i class="fa-solid fa-map-pin"></i> Other</label>
            </div>
          </div>
        </div>

        <div class="btn-group" style="justify-content:center;">
        <button type="submit" class="btn btn-primary">Save Address</button>
        </div>
      </form>
    </div>
  </div>
</div>


<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h5>Get In Touch</h5>
      <p>LitHeaven Company<br>Gandhipuram road<br>Coimbatore - 641018</p>
      <p>support@litheaven.com</p>
    </div>
    <div class="footer-section">
      <h5>Quick Links</h5>
      <a href="/">Home</a>
      <a href="/shop">Shop Books</a>
      <a href="/about">About Us</a>
    </div>
    <div class="footer-section">
      <h5>LitHeaven</h5>
      <p>Read, learn, and enjoy stories that inspire every reader.</p>
    </div>
  </div>
  <div class="footer-bottom">© 2025 LITHEAVEN. All Rights Reserved.</div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
let editIndex=-1;
let  editAddressId = null;
let editAddressData = null;

function openAddModal() {
  editAddressId = null;
  editAddressData = null;
  
  document.getElementById('modalTitle').textContent = 'Add Address';
  document.getElementById('name').value = '';
  document.getElementById('address1').value = '';
  document.getElementById('address2').value = '';
  document.getElementById('city').value = '';
  document.getElementById('state').value = '';
  document.getElementById('zip').value = '';
  document.getElementById('country').value = '';
  document.getElementById('typeHome').checked = true;
  
  clearValidations();
  document.getElementById('addressModal').style.display = 'flex';
  document.body.classList.add('modal-open');

  sessionStorage.setItem('modalOpen', 'true');
  sessionStorage.setItem('modalMode', 'add');
}

function openEditModalFromBtn(btn) {
  const id = btn.dataset.id;
  const fullName = btn.dataset.name;
  const line1 = btn.dataset.line1;
  const line2 = btn.dataset.line2;
  const city = btn.dataset.city;
  const state = btn.dataset.state;
  const zip = btn.dataset.zip;
  const country = btn.dataset.country;
  const type = btn.dataset.type;

  openEditModal(id, fullName, line1, line2, city, state, zip, country, type);
}

function openEditModal(id, fullName, line1, line2, city, state, zip, country, type) {
  editAddressId = id;
  editAddressData = { fullName, line1, line2, city, state, zip, country, type };
  
  document.getElementById('modalTitle').textContent = 'Edit Address';
  document.getElementById('name').value = fullName;
  document.getElementById('address1').value = line1;
  document.getElementById('address2').value = line2 || '';
  document.getElementById('city').value = city;
  document.getElementById('state').value = state;
  document.getElementById('zip').value = zip;
  document.getElementById('country').value = country;
  
  const addressType = type.toLowerCase();
  if (addressType === 'home') document.getElementById('typeHome').checked = true;
  else if (addressType === 'office') document.getElementById('typeOffice').checked = true;
  else document.getElementById('typeOther').checked = true;
  
  clearValidations();
  document.getElementById('addressModal').style.display = 'flex';
  document.body.classList.add('modal-open');

 sessionStorage.setItem('modalOpen', 'true');
  sessionStorage.setItem('modalMode', 'edit');
  sessionStorage.setItem('editData', JSON.stringify({ id, fullName, line1, line2, city, state, zip, country, type }));
}

function clearValidations() {
  const inputs = document.querySelectorAll('.form-control');
  inputs.forEach(input => {
    input.classList.remove('input-error', 'input-success');
    const error = input.nextElementSibling;
    if (error && error.classList.contains('error-text')) {
      error.style.display = 'none';
    }
  });
}

function closeModal() {
  document.getElementById('addressModal').style.display = 'none';
  document.body.classList.remove('modal-open');
  clearValidations();

  sessionStorage.removeItem('modalOpen');
  sessionStorage.removeItem('modalMode');
  sessionStorage.removeItem('editData');
}




async function saveAddress(e){
  e.preventDefault();

   let isValid = true;
   const fields = [
    { id:'name', msg:'Enter Name' },
    { id:'address1', msg:'Enter Address Line 1' },
    { id:'city', msg:'Enter City' },
    { id:'state', msg:'Enter State' },
    { id:'country', msg:'Enter Country' },
    { id:'zip', msg:'Enter valid 6-digit Zip Code', zip:true }
  ];

   fields.forEach(f => {
    const input = document.getElementById(f.id);
    const error = input.nextElementSibling;

    input.classList.remove('input-error','input-success');
    if (error && error.classList.contains('error-text')) {
      error.style.display = 'none';
    }

    if(!input.value.trim()){
      input.classList.add('input-error');
      if (error) {
        error.textContent = f.msg;
        error.style.display = 'block';
      }
      isValid = false;
    }
    else if(f.zip && !/^\d{6}$/.test(input.value)){
      input.classList.add('input-error');
      if (error) {
        error.textContent = 'Zip code must be exactly 6 digits';
        error.style.display = 'block';
      }
      isValid = false;
    }
    else{
      input.classList.add('input-success');
    }
  });

  if(!isValid) return;

   const data = {
    fullName: document.getElementById('name').value.trim(),
    addressLine1: document.getElementById('address1').value.trim(),
    addressLine2: document.getElementById('address2').value.trim() || '', 
    city: document.getElementById('city').value.trim(),
    state: document.getElementById('state').value.trim(),
    zip: document.getElementById('zip').value.trim(),
    country: document.getElementById('country').value.trim(),
    type: document.querySelector('input[name="addressType"]:checked')
        .value
        .charAt(0).toUpperCase() +
      document.querySelector('input[name="addressType"]:checked')
        .value
        .slice(1)

  };

  try {
    let res;
   if (editAddressId) {
      res = await fetch(`/addresses/edit/${editAddressId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
    } else {
      res = await fetch('/addresses/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
    }

    const result = await res.json();

if(result.success){
      Swal.fire({
        icon:'success',
        title: editAddressId ? 'Address Updated!' : 'Address Added!',
        text: editAddressId ? 'Your address has been updated successfully.' : 'Your address has been saved successfully.',
        confirmButtonColor:'#6f2b67',
        timer:1500
      }).then(() => {
        window.location.href = '/addresses'; 
      });
    } else {
      Swal.fire('Error', result.message, 'error');
    }

  }catch(err){
    console.log(err)
     Swal.fire({
  icon:"error",
  title:"Server Error",
  text:"Something went wrong. Try again later.",
  confirmButtonColor:"#6f2b67"

    })
  }
  closeModal();
}

async function deleteAddress(addressId){
  Swal.fire({
  title: 'Delete Address?',
  text: 'Are you sure you want to delete this address?',
  icon: 'warning',
  showCancelButton: true,
  confirmButtonColor: '#6f2b67',
  confirmButtonText: 'Yes',
  cancelButtonText: 'Cancel',
  customClass: {
    cancelButton: 'swal-cancel-purple'
    }
  }).then(async(result)=>{
   if(result.isConfirmed){
    try{
      const res=await fetch(`/addresses/delete/${addressId}`,{
        method:'DELETE',
        credentials: 'same-origin' 
      })
      const data=await res.json()

      if(data.success){
      Swal.fire({
        icon:'success',
        title:'Deleted!',
        text:'Address has been deleted.',
        confirmButtonColor:'#6f2b67',
        timer:1500
      }).then(()=>{
        window.location.href='/addresses'
      })
    }else{
      Swal.fire('Error', data.message, 'error');
    }
    }catch(err){
       console.error(err);
       Swal.fire('Error', 'Failed to delete address', 'error');
    }
   }    
  });
}



