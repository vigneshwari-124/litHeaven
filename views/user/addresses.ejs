function setupLiveValidation() {
  const inputs = document.querySelectorAll('.form-control');

  inputs.forEach(input => {
    input.addEventListener('input', () => {
      const error = input.nextElementSibling;

      if (input.value.trim()) {
        input.classList.remove('input-error');
        input.classList.add('input-success');

        if (error && error.classList.contains('error-text')) {
          error.style.display = 'none';
        }
      }
    });
  });
}


window.addEventListener('load', () => {
  setupLiveValidation();
  
  // Page refresh ஆனதும் modal state check செய்யுங்கள்
  const modalOpen = sessionStorage.getItem('modalOpen');
  const modalMode = sessionStorage.getItem('modalMode');
  
  if (modalOpen === 'true') {
    if (modalMode === 'edit') {
      const editData = JSON.parse(sessionStorage.getItem('editData'));
      if (editData) {
        openEditModal(
          editData.id,
          editData.fullName,
          editData.line1,
          editData.line2,
          editData.city,
          editData.state,
          editData.zip,
          editData.country,
          editData.type
        );
      }
    } else if (modalMode === 'add') {
      openAddModal();
    }
  }
});

window.onclick=(e)=>{if(e.target.classList.contains('modal'))closeModal()}
