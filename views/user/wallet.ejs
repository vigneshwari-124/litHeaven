<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

/* ── ADD MONEY MODAL ── */
function openAddMoneyModal(){
  document.getElementById('addAmount').value = '';
  document.getElementById('amountErr').style.display = 'none';
  document.getElementById('addMoneyModal').classList.add('show');
  document.body.classList.add('modal-open');
}
function closeAddMoneyModal(){
  document.getElementById('addMoneyModal').classList.remove('show');
  document.body.classList.remove('modal-open');
}
document.getElementById('addMoneyModal').addEventListener('click', function(e){
  if(e.target === this) closeAddMoneyModal();
});

function addMoneyToWallet(){
  const amountInput = document.getElementById('addAmount');
  const amountErr   = document.getElementById('amountErr');
  const amount = parseFloat(amountInput.value);
  amountErr.style.display = 'none';
  if(!amountInput.value || isNaN(amount) || amount < 1){
    amountErr.style.display = 'block';
    return;
  }
  // Replace below with your actual fetch/API call
  Swal.fire({
    icon:'success',
    title:'Money Added!',
    text:`₹${amount} has been added to your wallet.`,
    confirmButtonColor:'#6f2b67',
    timer:1800
  }).then(()=>{
    closeAddMoneyModal();
    // Update balance display (demo)
    const current = parseFloat(document.getElementById('walletBalance').textContent) || 0;
    document.getElementById('walletBalance').textContent = current + amount;
  });
}

/* ── FILTER ── */
function filterTransactions(){
  const val = document.getElementById('txnFilter').value;
  document.querySelectorAll('.transaction-item').forEach(item => {
    const type = item.dataset.type;
    if(val === 'all') item.style.display = 'flex';
    else if(val === 'credit' && type === 'credit') item.style.display = 'flex';
    else if(val === 'debit'  && type === 'debit')  item.style.display = 'flex';
    else item.style.display = 'none';
  });
}

/* ── LOGOUT ── */
document.getElementById('logoutBtn')?.addEventListener('click', function(e){
  e.preventDefault();
  Swal.fire({
    title:"<span style='color:#6f2b67;font-weight:700'>Logout?</span>",
    html:`<p style="font-size:14px;color:#555;margin-bottom:8px">Are you sure you want to logout? 💜</p><p style="font-size:13px;color:#888">You can login again anytime.</p>`,
    imageUrl:"https://cdn-icons-png.flaticon.com/512/1828/1828479.png",
    imageWidth:100,imageHeight:100,imageAlt:"Logout",
    showCancelButton:true,
    confirmButtonText:"🚪 Logout",cancelButtonText:"Stay Here",
    confirmButtonColor:"#6f2b67",cancelButtonColor:"#d6c3d3",
    reverseButtons:true,
    background:"linear-gradient(135deg,#f6eef6,#efe3f0)",
    backdrop:"rgba(0,0,0,0.6)"
  }).then(r=>{ if(r.isConfirmed) window.location.href="/logout"; });
});

/* ── HAMBURGER ── */
const menuToggleP = document.getElementById('menuToggleP');
const mobileMenuP = document.getElementById('mobileMenuP');
menuToggleP?.addEventListener('click', function(){
  mobileMenuP.classList.toggle('open');
  const icon = this.querySelector('i');
  icon.classList.toggle('fa-bars');
  icon.classList.toggle('fa-xmark');
});
document.addEventListener('click', function(e){
  if(mobileMenuP && menuToggleP &&
     !mobileMenuP.contains(e.target) &&
     !menuToggleP.contains(e.target)){
    mobileMenuP.classList.remove('open');
    const icon = menuToggleP.querySelector('i');
    if(icon){ icon.classList.add('fa-bars'); icon.classList.remove('fa-xmark'); }
  }
});

/* ── FAB DRAWER ── */
function openProfileFilter(){
  document.getElementById('profileFilterDrawer').classList.add('open');
  document.getElementById('profileFilterOverlay').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeProfileFilter(){
  document.getElementById('profileFilterDrawer').classList.remove('open');
  document.getElementById('profileFilterOverlay').classList.remove('show');
  document.body.style.overflow = '';
}
document.getElementById('logoutBtnDrawer')?.addEventListener('click', function(e){
  e.preventDefault();
  closeProfileFilter();
  document.getElementById('logoutBtn')?.click();
});
</script>
</body>
