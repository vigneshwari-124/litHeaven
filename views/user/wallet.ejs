      <li><a href="/wallet" class="sidebar-link active"><i class="fa-solid fa-wallet"></i><span>Wallet</span></a></li>
      <li><a href="/coupons" class="sidebar-link"><i class="fa-solid fa-ticket"></i><span>My Coupons</span></a></li>
      <li class="mt-2">
        <button type="button" id="logoutBtnDrawer" class="sidebar-link logout-btn" style="width:100%">
          <i class="fa-solid fa-right-from-bracket"></i><span>Logout</span>
        </button>
