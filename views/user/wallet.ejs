<!-- ═══════════ ADD MONEY MODAL ═══════════ -->
<div class="modal-overlay" id="addMoneyModal">
  <div class="modal-box">
    <div class="modal-head">
      <h3>Add money to wallet</h3>
      <button class="modal-close" onclick="closeAddMoneyModal()">&times;</button>
    </div>
    <div class="modal-body-inner">
      <label class="form-label-m">Enter Amount</label>
      <input type="number" class="form-input-m" id="addAmount" placeholder="Enter Amount" min="1">
      <div class="error-msg" id="amountErr">Please enter a valid amount (minimum ₹1)</div>
      <button class="btn-modal-add" onclick="addMoneyToWallet()">Add Money</button>
    </div>
  </div>
</div>

<!-- ═══════════ FAB + DRAWER (mobile) ═══════════ -->
<button class="profile-filter-fab" onclick="openProfileFilter()">
