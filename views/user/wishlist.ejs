      if (!btn) return
      const rect = btn.getBoundingClientRect()
      const bubble = document.createElement('span')
      bubble.classList.add('bubble')
      bubble.style.left = (e.clientX - rect.left) + 'px'
      bubble.style.top  = (e.clientY - rect.top)  + 'px'
      btn.appendChild(bubble)
      bubble.addEventListener('animationend', () => bubble.remove())
    })

async function loadWishlist(page=1) {
  const res  = await fetch(`/wishlist-data?page=${page}`)
  const data = await res.json()

  const grid      = document.getElementById("wishGrid")
  const empty     = document.getElementById("emptyWishlist")
  const countEl   = document.getElementById("wishCountDisplay")
    

  // 🔥 NEW
  const gridWrap  = document.getElementById("wishGridWrap")
  const topbar    = document.getElementById("wishTopbar")

  const badge = document.getElementById("wishlistBadge")

if (badge) {
  if (data.totalItems > 0) {
    badge.style.display = "flex"
    badge.textContent = data.totalItems
  } else {
    badge.style.display = "none"
  }
}
  grid.innerHTML = ""

  
  if (!data.items || data.items.length === 0) {
    empty.style.display = "block"

    
    gridWrap.style.display = "none"
    topbar.style.display   = "none"

     document.getElementById("pagination").style.display = "none"
    if (countEl) countEl.textContent = "0"
    return
  }

  // ✅ HAS ITEMS
  empty.style.display = "none"

  // 🔥 SHOW AGAIN
  gridWrap.style.display = "block"
  topbar.style.display   = "flex"

  document.getElementById("pagination").style.display = "flex"

  if (countEl) countEl.textContent = data.totalItems

  data.items.forEach((item, index) => {
    const product    = item.productId
    const variant    = product.variants.find(
      v => v.language._id.toString() === item.languageId._id.toString()
    )

    const format     = variant?.formats.find(f => f.format === item.format)

    const image      = variant?.thumbnail?.url || "/images/default.jpg"
    const title      = product.title
    const price      = format?.price || 0
    const isOut      = item.stock === 0
    const author     = product.author?.name || "Unknown"
    const language   = variant?.language?.languageName || "N/A"
    const formatType = item.format || "N/A"

    const card = `
      <div class="wish-card ${isOut ? 'out' : ''}" id="wcard-${item._id}">
        <div class="wish-card-inner-clip">
          <div class="wish-card-img-wrap">
            <img src="${image}" class="wish-card-img">
            <button class="btn-card-del" onclick="removeWish('${item._id}')">
              <i class="fa-solid fa-xmark"></i>
            </button>
            <button class="btn-add-cart"
               onclick="moveToCart('${product._id}', '${item.languageId._id}', '${item.format}', '${item._id}')"
               ${isOut ? 'disabled style="opacity:0.5;cursor:not-allowed"' : ''}
               >
               <i class="fa-solid fa-cart-plus"></i> Add to Cart
            </button>
          </div>

          <div class="wish-card-body">
            <div class="wc-genre">${language} • ${formatType}</div>
            <div class="wc-title">${title}</div>
            <div class="wc-author">${author}</div>

            <div class="wc-price-row">
              <span class="wc-price-new">₹${price}</span>
            </div>
            ${isOut ? `
               <span class="out-badge">Out of Stock</span>
            ` : ''}
          </div>
        </div>
      </div>
    `

    grid.innerHTML += card
  })

   renderPagination(data.totalPages, data.currentPage)
}

async function removeWish(id) {
  await fetch(`/remove-wishlist/${id}`, { method: "DELETE" })

  document.getElementById("wcard-" + id)?.remove()

  // 🔥 RELOAD DATA (BEST WAY)
  loadWishlist(1)
}

async function confirmEmptyWish() {

  const confirmDelete = confirm("Are you sure you want to clear wishlist?")

  if (!confirmDelete) return

  await fetch("/clear-wishlist", {
    method: "DELETE"
  })

document.getElementById("wishGrid").innerHTML = ""
document.getElementById("emptyWishlist").style.display = "block"

document.getElementById("wishGridWrap").style.display = "none"
document.getElementById("wishTopbar").style.display = "none"
}
   
function confirmEmptyWish() {
  Swal.fire({
    title: "Clear Wishlist?",
    text: "All items will be removed 💔",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, clear it",
    cancelButtonText: "Cancel",
    confirmButtonColor: "#6f2b67"
  }).then(async (result) => {
    if (result.isConfirmed) {

      await fetch("/clear-wishlist", {
        method: "DELETE"
      })

      // 🔥 CLEAR GRID
      document.getElementById("wishGrid").innerHTML = ""

      // ✅ SHOW EMPTY MESSAGE
      document.getElementById("emptyWishlist").style.display = "block"

      // 🔥 HIDE EVERYTHING ELSE
      document.getElementById("wishGridWrap").style.display = "none"
      document.getElementById("wishTopbar").style.display = "none"
      document.getElementById("pagination").innerHTML = ""

      // 🔥 RESET COUNT
      const countEl = document.getElementById("wishCountDisplay")
      if (countEl) countEl.textContent = "0"

      Swal.fire("Cleared!", "Your wishlist is empty.", "success")
    }
  })
}

function renderPagination(totalPages, currentPage) {
  const pagination = document.getElementById("pagination")
  pagination.innerHTML = ""

  // 🔥 ALWAYS show PREV
  pagination.innerHTML += `
    <button class="pg-btn ${currentPage === 1 ? 'disabled' : ''}"
      onclick="${currentPage > 1 ? `loadWishlist(${currentPage - 1})` : ''}">
      ‹
    </button>
  `

  // 🔢 Pages
  for (let i = 1; i <= totalPages; i++) {
    pagination.innerHTML += `
      <button class="pg-btn ${i === currentPage ? 'active' : ''}"
        onclick="loadWishlist(${i})">
        ${i}
      </button>
    `
  }

  // 🔥 ALWAYS show NEXT
  pagination.innerHTML += `
    <button class="pg-btn ${currentPage === totalPages ? 'disabled' : ''}"
      onclick="${currentPage < totalPages ? `loadWishlist(${currentPage + 1})` : ''}">
      ›
    </button>
  `
}
    window.addEventListener("DOMContentLoaded", ()=>{
    loadWishlist(1),
    loadCartCount() 
    })


async function moveToCart(productId, languageId, format, wishlistId) {


  const res = await fetch("/move-to-cart", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      productId,
      languageId,
      format,
      wishlistId
    })
  })

  const data = await res.json()

  await Swal.fire({
    icon: data.status === "added" ? "success" :
          data.status === "already" ? "info" : "error",
    title: data.message,
    timer: 1500,
    showConfirmButton: false
  })

  document.getElementById("wcard-" + wishlistId)?.remove()

  loadCartCount() 
  
  loadWishlist(1)
}

async function loadCartCount() {
  try {
    const res = await fetch("/get-cart")
    const data = await res.json()

    const badge = document.getElementById("cartBadge")

    if (!badge) return

    const count = data.items?.length || 0

    if (count > 0) {
      badge.style.display = "flex"
      badge.textContent = count
    } else {
      badge.style.display = "none"
    }

  } catch (err) {
    console.log(err)
  }
}
    
    const menuToggle = document.getElementById('menuToggle')
    const mobileMenu = document.getElementById('mobileMenu')
    menuToggle?.addEventListener('click', function () {
      mobileMenu.classList.toggle('open')
      const icon = this.querySelector('i')
      icon.classList.toggle('fa-bars'); icon.classList.toggle('fa-xmark')
    })
    document.addEventListener('click', function (e) {
      if (mobileMenu && menuToggle && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
        mobileMenu.classList.remove('open')
        const icon = menuToggle.querySelector('i')
        if (icon) { icon.classList.add('fa-bars'); icon.classList.remove('fa-xmark') }
      }
    })
