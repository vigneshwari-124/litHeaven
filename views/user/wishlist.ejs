             <a class="icon-btn position-relative" href="/cart" title="Cart">
              <i class="fa-solid fa-cart-shopping"></i>
              <div class="icon-badge" id="cartBadge">0</div>
            </a>
            <div class="dropdown">
              <div class="icon-btn dropdown-toggle" id="profileMenu" data-bs-toggle="dropdown">
                <i class="fa-regular fa-user"></i>
              </div>
              <ul class="dropdown-menu dropdown-menu-end p-2">
                <li><a class="dropdown-item d-flex align-items-center gap-2" href="/profile"><i class="fa-regular fa-id-badge"></i> Profile</a></li>
                <li><a href="#" id="logoutBtn" class="dropdown-item d-flex align-items-center gap-2"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></li>
