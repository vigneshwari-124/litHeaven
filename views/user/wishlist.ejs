  </header>

  <div id="mobileMenu" class="mobile-menu d-lg-none">
    <a class="mobile-nav-link" href="/"><i class="fa-solid fa-house"></i> Home</a>
    <a class="mobile-nav-link" href="/shop"><i class="fa-solid fa-store"></i> Shop</a>
