<script>
/* ════ DEMO DATA ════ */
let orders = [];

async function loadOrders() {
  try {
    const search = document.getElementById("searchInput").value;
    const status = activeFilter;

    const res = await fetch(
      `/api/orders?search=${search}&status=${status}`
    );

    const data = await res.json();

    orders = data.orders;

    renderOrders();

  } catch (err) {
    console.log(err);
  }
}

function handleSearch(){
  clearTimeout(window.searchTimer);

  window.searchTimer = setTimeout(()=>{
    loadOrders();
  }, 400); // debounce
}

/* ════ STATE ════ */
let activeFilter='all', pendingAction=null, currentDetailId=null;

window.onload = () => {
  loadOrders(); 
};
/* ════ BADGE HELPERS ════ */
function orderBadge(s){
  const cls={Processing:'sb-processing',Shipped:'sb-shipped',Delivered:'sb-delivered',Cancelled:'sb-cancelled',Returned:'sb-returned', 'Return Requested':'sb-returned'};
  const ico={Processing:'⏳',Shipped:'🚚',Delivered:'✅',Cancelled:'❌',Returned:'↩️', 'Return Requested':'🕒'};
  return `<span class="sbadge ${cls[s]||'sb-processing'}">${ico[s]||'📦'} ${s}</span>`;
}
function payBadge(s){
  const cls={COD:'pb-cod',Pending:'pb-pending',Paid:'pb-paid',Failed:'pb-failed',Refunded:'pb-refund'};
  const lbl={COD:'💵 COD',Pending:'⏳ Pending',Paid:'✅ Paid',Failed:'❌ Failed',Refunded:'↩️ Refunded'};
  return `<span class="pbadge ${cls[s]||'pb-pending'}">${lbl[s]||s}</span>`;
}
function itemBadge(s){
  const cls={Processing:'sb-processing',Shipped:'sb-shipped',Delivered:'sb-delivered',Cancelled:'sb-cancelled',Returned:'sb-returned', 'Return Requested':'sb-returned'};
  const ico={Processing:'⏳',Shipped:'🚚',Delivered:'✅',Cancelled:'❌',Returned:'↩️','Return Requested':'🕒'};
  return `<span class="sbadge ${cls[s]||'sb-processing'}" style="font-size:10px;padding:3px 9px">${ico[s]||'📦'} ${s}</span>`;
}


function renderOrders(){
  const wrap=document.getElementById('tableWrap');

  if(!orders.length){
    wrap.innerHTML=`<div class="empty-state">
      <img src="https://cdn-icons-png.flaticon.com/512/6897/6897039.png">
      <h4>No orders found</h4>
      <p>No matching orders</p>
      <a href="/shop" class="btn-shop-now">
        <i class="fa-solid fa-store"></i> Browse Books
      </a>
    </div>`;
    return;
  }

  wrap.innerHTML=`
    <table class="ord-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Order ID</th>
          <th>Date</th>
          <th>Order Status</th>
          <th>Payment Status</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>${orders.map(buildRow).join('')}</tbody>
    </table>`;
}

function buildRow(o){
  const first=o.items[0];
  const extra=o.items.length-1;
  const d=new Date(o.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  return `
    <tr>
      <td><div class="prod-cell">
        <img src="${first.image}" class="prod-thumb" onerror="this.src='https://via.placeholder.com/44x56/f3e8f2/6f2b67?text=📖'">
        <div>
          <div class="prod-name">${first.name}</div>
          ${extra>0?`<div class="prod-more">+${extra} more item${extra>1?'s':''}</div>`:''}
        </div>
      </div></td>
      <td><div class="oid-cell">${o.orderId}</div></td>
      <td><div class="date-cell">${d}</div></td>
      <td>${orderBadge(o.orderStatus)}</td>
      <td>
  ${payBadge(o.paymentStatus)}

  ${
    o.paymentStatus === "Failed"
      ? `<br>
         <button class="btn-details mt-1" onclick="retryPayment('${o._id}')">
           🔁 Retry
         </button>`
      : ""
  }
</td>

<td><div class="total-cell">₹${o.totalAmount}</div></td>

<td>
  <button class="btn-details" onclick="openDetail('${o._id}')">
    <i class="fa-solid fa-eye me-1"></i>Details
  </button>
</td>
    </tr>`;
}

/* ════ FILTER ════ */
function setFilter(f,el){
  activeFilter=f;
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
 loadOrders(); 
}

/* ════ OPEN DETAIL MODAL ════ */
function openDetail(id){
  const o=orders.find(x=>x._id===id);
  if(!o)return;
  currentDetailId=id;

 
  document.getElementById('dmTopTitle').textContent=`Order ${o.orderId}`;

  const d=new Date(o.createdAt).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});

  const orderCanCancel=o.orderStatus==='Processing'||o.orderStatus==='Shipped';

 const orderCanReturn =
  o.orderStatus === 'Delivered' &&
  o.items.some(it => it.status === 'Delivered');

 const prodRows = o.items.map(it => {
  const isCancelled = it.status === 'Cancelled';
  const isReturned  = it.status === 'Returned';
  const canReturn   = it.status === 'Delivered';  
  const isReturnRequested =it.status === 'Return Requested';
  const canCancel   = ['Processing', 'Shipped'].includes(o.orderStatus) && 
                      !['Cancelled', 'Returned'].includes(it.status);

  
  let rightEl = '';
if (isReturnRequested) {

 rightEl = `
 <div class="returned-tag">
   ⏳ Return Requested
 </div>
 `;

}
else if (isReturned) {

 rightEl = `
 <div class="returned-tag">
   ↩️ Returned
 </div>
 `;

}
else if (isCancelled) {

 rightEl = `
 <div class="cancelled-tag">
   ❌ Cancelled
 </div>
 `;

}

else if (canReturn) {

 rightEl = `
 <button class="btn-prod-return"
 onclick="openReturnModal('${o._id}','${it._id}')">
 Return
 </button>
 `;

}else if (canCancel) {

 rightEl = `
 <button class="btn-prod-cancel"
 onclick="openCancelModal('${o._id}','${it._id}')">
 Cancel
 </button>
 `;
}
  return `
    <div class="dm-product" style="${isCancelled || isReturned ? 'opacity:.55' : ''}">
      <img 
        src="${it.image}" 
        class="dm-prod-img" 
        onerror="this.src='https://via.placeholder.com/52x64/f3e8f2/6f2b67?text=📖'"
        style="${isCancelled ? 'filter:grayscale(1)' : ''}"
      >
      <div class="dm-prod-info">
        <div class="dm-prod-name">${it.name}</div>
        <div class="dm-prod-meta">
          ${it.author || ''} 
          ${it.format ? '· ' + it.format : ''} 
          · Qty: ${it.quantity}
        </div>
        <div class="dm-prod-price">₹${it.price * it.quantity}</div>
      </div>
      ${rightEl}
    </div>`;
}).join('');

  document.getElementById('dmContent').innerHTML=`
    <!-- Order Info -->
    <div class="dm-section">
      <div class="dm-section-title"><span class="dm-section-title-icon">🧾</span> Order Info</div>
      <div class="dm-info-row"><span class="dm-info-label">Order ID</span><span class="dm-info-val">${o.orderId}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Payment Method</span><span class="dm-info-val">${o.paymentMethod}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Order Status</span><span class="dm-info-val">${orderBadge(o.orderStatus)}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Payment Status</span><span class="dm-info-val">${payBadge(o.paymentStatus)}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Total Amount</span><span class="dm-info-val" style="color:var(--purple);font-size:14px">₹${o.totalAmount}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Discount</span><span class="dm-info-val" style="color:var(--success)">−₹${o.discount}</span></div>
      <div class="dm-info-row"><span class="dm-info-label">Date</span><span class="dm-info-val">${d}</span></div>
      ${o.cancelReason?`<div class="dm-info-row"><span class="dm-info-label">Cancel Reason</span><span class="dm-info-val" style="color:#c62828">${o.cancelReason}</span></div>`:''}
      ${o.returnReason ?`<div class="dm-info-row"><span class="dm-info-label">Return Reason</span><span class="dm-info-val" style="color:#6a1b9a">${o.returnReason}</span></div>`:''}
    </div>

    <!-- Products -->
    <div class="dm-section">
      <div class="dm-section-title"><span class="dm-section-title-icon">📦</span> Products</div>
      ${prodRows}
    </div>

    <!-- Shipping Address -->
    <div class="dm-section">
      <div class="dm-section-title"><span class="dm-section-title-icon">🏠</span> Shipping Address</div>
      <div class="dm-addr-name">${o.address.fullName}</div>
      <div class="dm-addr-line">${o.address.addressLine1}<br>${o.address.city}, ${o.address.state} – ${o.address.zip}<br>${o.address.country}</div>
    </div>`;

  /* ── footer buttons ── */
  let footerHtml='';

  if (o.paymentStatus === "Failed") {
  footerHtml += `
    <button class="btn-dm-cancel-order" onclick="retryPayment('${o._id}')">
      🔁 Retry Payment
    </button>`;
}

  if(orderCanCancel)
    footerHtml+=`<button class="btn-dm-cancel-order" onclick="openCancelModal('${o._id}',null)"><i class="fa-solid fa-xmark"></i> Cancel Order</button>`;
  if(orderCanReturn)
    footerHtml+=`<button class="btn-dm-return-order" onclick="openReturnModal('${o._id}',null)"><i class="fa-solid fa-rotate-left"></i> Return Order</button>`;
  footerHtml+=`<button class="btn-dm-invoice" onclick="downloadInvoice('${o._id}')"><i class="fa-solid fa-file-pdf"></i> Download Invoice</button>`;
  footerHtml+=`<button class="btn-dm-close" onclick="closeDetail()">Close</button>`;
  document.getElementById('dmFooter').innerHTML=footerHtml;

  document.getElementById('detailOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeDetail(){
  document.getElementById('detailOverlay').classList.remove('open');
  document.body.style.overflow='';
  currentDetailId=null;
}
function closeDetailIfBg(e){
  if(e.target===document.getElementById('detailOverlay'))closeDetail();
}

async function retryPayment(orderId) {
  try {

    const res = await fetch(`/retry-payment/${orderId}`, {
      method: "POST"
    });

    const data = await res.json();

    if (!data.success) {
      return Swal.fire({
        icon: "error",
        title: "Error",
        text: data.message || "Unable to start payment"
      });
    }

    const options = {
      key: data.razorpayKey,
      amount: data.razorpayOrder.amount,
      currency: data.razorpayOrder.currency,
      name: "LitHeaven",
      description: "Order Payment Retry",
      order_id: data.razorpayOrder.id,

      handler: async function (response) {

        const verifyRes = await fetch("/verify-payment", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            orderId: data.orderId,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_order_id: response.razorpay_order_id,
            razorpay_signature: response.razorpay_signature
          })
        });

        const verifyData = await verifyRes.json();

        if (!verifyData.success) {
          return Swal.fire({
            icon: "error",
            title: "Verification Failed",
            text: "Payment verification failed."
          });
        }

        await Swal.fire({
          icon: "success",
          title: "Payment Successful 🎉",
          text: "Your payment has been completed successfully.",
          confirmButtonColor: "#6f2b67"
        });

        await Swal.fire({
          icon: "success",
          title: "Order Confirmed 📦",
          text: "Thank you for shopping with LitHeaven.",
          confirmButtonColor: "#6f2b67"
        });

        location.reload();
      },

      modal: {
        ondismiss: async function () {

          await fetch("/payment-failed", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              orderId: data.orderId
            })
          });

          Swal.fire({
            icon: "error",
            title: "Payment Failed",
            text: "You can retry payment from the Orders page.",
            confirmButtonColor: "#c62828"
          });
        }
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();

  } catch (err) {
    console.log(err);

    Swal.fire({
      icon: "error",
      title: "Something went wrong",
      text: "Please try again."
    });
  }
}

/* ════ CANCEL ════ */
function openCancelModal(orderId,itemId=null){
  pendingAction={type:'cancel',orderId,itemId};
  document.getElementById('cancelTitle').innerHTML=itemId
    ?'<i class="fa-solid fa-circle-xmark" style="color:#c62828"></i> Cancel This Item'
    :'<i class="fa-solid fa-circle-xmark" style="color:#c62828"></i> Cancel Order';
  document.querySelectorAll('#cancelChips .r-chip').forEach(c=>c.classList.remove('sel'));
  document.getElementById('cancelTa').value='';
  document.getElementById('cancelModal').classList.add('open');
}

async function confirmCancel() {
  const reason = getReason('cancel');
  const { orderId, itemId } = pendingAction;

  closeModal('cancelModal');

  try {
    let res;

    if (itemId) {
   
      res = await fetch(`/api/orders/${orderId}/cancel-item/${itemId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ reason })
      });

    } else {
      // 🔹 Full order cancel
      res = await fetch(`/api/orders/${orderId}/cancel-order`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ reason })
      });
    }

    const data = await res.json();

    if (!res.ok) {
      return showToast(data.message || "Cancel failed", "error");
    }

    await showToast(data.message, "success");

    await loadOrders(); 

    if (currentDetailId) openDetail(currentDetailId);

  } catch (err) {
    console.log(err);
    showToast("Something went wrong", "error");
  }
}
/* ════ RETURN ════ */
function openReturnModal(orderId,itemId=null){
  pendingAction={type:'return',orderId,itemId};
  document.getElementById('returnTitle').innerHTML=itemId
    ?'<i class="fa-solid fa-rotate-left" style="color:#6a1b9a"></i> Return This Item'
    :'<i class="fa-solid fa-rotate-left" style="color:#6a1b9a"></i> Return Order';
  document.querySelectorAll('#returnChips .r-chip').forEach(c=>c.classList.remove('sel'));
  document.getElementById('returnTa').value='';
  document.getElementById('returnErr').style.display='none';
  document.getElementById('returnModal').classList.add('open');
}

async function confirmReturn() {
  const reason = getReason('return');
  if (!reason) { 
    document.getElementById('returnErr').style.display = 'block'; 
    return; 
  }
  document.getElementById('returnErr').style.display = 'none';

  const { orderId, itemId } = pendingAction;
  closeModal('returnModal');

  try {
    let res;

    if (itemId) {
  
      res = await fetch(`/api/orders/${orderId}/return-item/${itemId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });
    } else {
    
      res = await fetch(`/api/orders/${orderId}/return-order`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      });
    }

    const data = await res.json();

    if (!res.ok) {
      return showToast(data.message || 'Return failed', 'error');
    }

    await showToast(data.message, 'success');
    await loadOrders();                              
    if (currentDetailId) openDetail(currentDetailId); 

  } catch (err) {
    console.error(err);
    showToast('Something went wrong', 'error');
  }
}

/* ════ HELPERS ════ */
function closeModal(id){document.getElementById(id).classList.remove('open');}
function toggleChip(el,type){
  document.querySelectorAll(`#${type}Chips .r-chip`).forEach(c=>c.classList.remove('sel'));
  el.classList.toggle('sel');
}
function getReason(type){
  const chip=document.querySelector(`#${type}Chips .r-chip.sel`);
  const ta=document.getElementById(`${type}Ta`).value.trim();
  return ta||chip?.textContent||'';
}
function showToast(msg, icon = 'success') {
  return Swal.fire({
    toast: true,
    position: 'top-end',
    icon,
    title: msg,
    showConfirmButton: false,
    timer: 2200,
    timerProgressBar: true,

    customClass: {
      popup: 'my-toast'
    },didOpen: (toast) => {
      toast.style.zIndex = '9999999';  
    }
  });
}
/* ════ INVOICE PDF ════ */
function downloadInvoice(orderId){
  const o=orders.find(x=>x._id===orderId);
  if(!o)return;
  const activeItems = o.items.filter(it => 
    !['Cancelled','Returned','Return Requested'].includes(it.status)
  );

  const activeSubtotal = activeItems.reduce((sum,it)=> sum + (it.price*it.quantity), 0);
  const activeTotal = activeSubtotal + (o.deliveryCharge||0) - (o.discount||0);
  const{jsPDF}=window.jspdf;
  const doc=new jsPDF({unit:'mm',format:'a4'});
  const W=doc.internal.pageSize.getWidth();
  const d=new Date(o.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'});
  doc.setFillColor(111,43,103);doc.rect(0,0,W,32,'F');
  doc.setTextColor(255,255,255);doc.setFontSize(22);doc.setFont('helvetica','bold');doc.text('LitHeaven',15,14);
  doc.setFontSize(8);doc.setFont('helvetica','normal');doc.text('Your Literary Escape',15,20);doc.text('litheaven.com  |  support@litheaven.com',15,26);
  doc.setFontSize(14);doc.setFont('helvetica','bold');doc.text('TAX INVOICE',W-15,14,{align:'right'});
  doc.setFontSize(8);doc.setFont('helvetica','normal');doc.text(`Order: ${o.orderId}`,W-15,20,{align:'right'});doc.text(`Date: ${d}`,W-15,26,{align:'right'});
  doc.setTextColor(50,50,50);doc.setFontSize(9);doc.setFont('helvetica','bold');doc.text('Deliver To:',15,42);
  doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.text(o.address.fullName,15,48);doc.text(`${o.address.addressLine1}, ${o.address.city}`,15,54);doc.text(`${o.address.state} - ${o.address.zip}, ${o.address.country}`,15,60);
  doc.setFont('helvetica','bold');doc.text('Payment:',W/2+5,42);doc.setFont('helvetica','normal');doc.text(o.paymentMethod || 'COD',W/2+5,48);
  doc.setDrawColor(184,138,180);doc.setLineWidth(0.4);doc.line(15,65,W-15,65);
  doc.autoTable({startY:70,head:[['#','Title','Author','Format','Qty','MRP','Price','Amount']],body:activeItems.map((it,i)=>[i+1,it.name,it.author,it.format,it.quantity,`Rs.${it.price}`,`Rs.${it.price}`,`Rs.${it.price*it.quantity}`]),styles:{font:'helvetica',fontSize:8,cellPadding:3,textColor:[50,50,50]},headStyles:{fillColor:[111,43,103],textColor:[255,255,255],fontStyle:'bold',fontSize:8},alternateRowStyles:{fillColor:[249,244,253]},columnStyles:{0:{cellWidth:8,halign:'center'},1:{cellWidth:48},2:{cellWidth:28},3:{cellWidth:20},4:{cellWidth:10,halign:'center'},5:{cellWidth:18,halign:'right'},6:{cellWidth:18,halign:'right'},7:{cellWidth:20,halign:'right'}},margin:{left:15,right:15}});
  const ay=doc.lastAutoTable.finalY+8,bx=W-80;
  doc.setFillColor(250,244,253);doc.roundedRect(bx,ay,65,55,4,4,'F');doc.setDrawColor(184,138,180);doc.roundedRect(bx,ay,65,55,4,4,'S');
  [['Subtotal',`Rs.${activeSubtotal}`],['Discount',`-Rs.${o.discount}`],['Delivery',o.deliveryCharge===0?'FREE':`Rs.${o.deliveryCharge}`]].forEach(([l,v],i)=>{const y=ay+9+i*8;doc.setFont('helvetica','normal');doc.setTextColor(100,100,100);doc.setFontSize(8);doc.text(l,bx+4,y);doc.setFont('helvetica','bold');doc.setTextColor(50,50,50);doc.text(v,bx+61,y,{align:'right'});});
  doc.setDrawColor(111,43,103);doc.line(bx+4,ay+39,bx+61,ay+39);
  doc.setFont('helvetica','bold');doc.setFontSize(10);doc.setTextColor(111,43,103);doc.text('Total',bx+4,ay+46);doc.text(`Rs.${activeTotal}`,bx+61,ay+46,{align:'right'});
  const fy=ay+62;doc.setFillColor(111,43,103);doc.rect(0,fy,W,18,'F');doc.setTextColor(255,255,255);doc.setFontSize(8);doc.setFont('helvetica','normal');
  doc.text('Thank you for shopping with LitHeaven!  |  support@litheaven.com',W/2,fy+7,{align:'center'});
  doc.text('LitHeaven Company, Gandhipuram Road, Coimbatore - 641018',W/2,fy+13,{align:'center'});
  doc.save(`LitHeaven_Invoice_${o.orderId}.pdf`);
  showToast('Invoice downloaded!','success');
}

/* ════ MOBILE MENU + LOGOUT ════ */
const menuToggle=document.getElementById('menuToggle'),mobileMenu=document.getElementById('mobileMenu');
menuToggle?.addEventListener('click',function(){mobileMenu.classList.toggle('open');const ic=this.querySelector('i');ic.classList.toggle('fa-bars');ic.classList.toggle('fa-xmark');});
document.addEventListener('click',function(e){if(mobileMenu&&menuToggle&&!mobileMenu.contains(e.target)&&!menuToggle.contains(e.target)){mobileMenu.classList.remove('open');const ic=menuToggle.querySelector('i');if(ic){ic.classList.add('fa-bars');ic.classList.remove('fa-xmark');}}});
document.getElementById('logoutBtn')?.addEventListener('click',function(e){e.preventDefault();Swal.fire({title:"<span style='color:#6f2b67;font-weight:700'>Logout?</span>",html:`<p style="font-size:14px;color:#555">Sure? 💜</p>`,showCancelButton:true,confirmButtonText:'🚪 Logout',cancelButtonText:'Stay',confirmButtonColor:'#6f2b67',reverseButtons:true,background:'linear-gradient(135deg,#f6eef6,#efe3f0)'}).then(r=>{if(r.isConfirmed)window.location.href='/logout';});});
</script>
