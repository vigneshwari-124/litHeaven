<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
  <title>My Orders – LitHeaven</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,400&family=Playfair+Display:wght@700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
  <style>
    :root{--purple:#6f2b67;--light:#8e4a86;--muted:#6c6c6c;--border:#b88ab4;--sale:#e8412e;--ink:#1a0f18;--success:#2e7d32;}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:"DM Sans",sans-serif;background:linear-gradient(135deg,#f5f0f6 0%,#e8dff0 50%,#f0e5f5 100%);color:#222;min-height:100vh;}
    @keyframes fadeDown{from{opacity:0;transform:translateY(-18px)}to{opacity:1;transform:translateY(0)}}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
    @keyframes modalIn{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

    /* ── TOP BAR ── */
    .top-offer{background:#000;color:#fff;text-align:center;font-weight:600;padding:8px;font-size:14px;}

    /* ── HEADER ── */
    header.navbar-area{background:var(--purple);padding:12px 0;width:100%;}
    .navbar-container{padding:0 20px;}
    .brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#fff;transition:transform .3s;}
    .brand:hover{transform:scale(1.04);}
    .logo-circle{position:relative;width:56px;height:56px;border-radius:50%;border:2px solid #fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;animation:float 3s ease-in-out infinite;}
    .book-logo{width:32px;filter:brightness(0)invert(1);}
    .logo-text{position:absolute;bottom:4px;font-size:6.5px;font-weight:800;color:#fff;letter-spacing:.8px;text-transform:uppercase;}
    .brand .txt{font-weight:800;font-size:20px;letter-spacing:.6px;color:#fff;}
    .main-nav .nav-link{color:#fff;font-weight:600;padding:8px 12px;transition:all .3s;position:relative;text-decoration:none;}
    .main-nav .nav-link::after{content:'';position:absolute;bottom:0;left:50%;width:0;height:2px;background:#fff;transition:all .3s;transform:translateX(-50%);}
    .main-nav .nav-link:hover::after{width:80%;}
    .main-nav .nav-link:hover{color:#f3dff1;}
    .header-icons{display:flex;gap:16px;align-items:center;}
    .icon-btn{color:#fff;font-size:20px;position:relative;cursor:pointer;transition:all .3s;text-decoration:none;}
    .icon-btn:hover{transform:scale(1.2) rotate(5deg);}
    .icon-badge{position:absolute;top:-6px;right:-8px;background:#fff;color:var(--purple);font-weight:700;font-size:11px;width:18px;height:18px;display:flex;align-items:center;justify-content:center;border-radius:50%;animation:pulse 2s infinite;}
    .dropdown-menu{border-radius:12px;border:none;box-shadow:0 10px 30px rgba(111,43,103,.25);padding:8px;}
    .dropdown-item{border-radius:8px;padding:10px 14px;font-weight:600;color:#333;transition:all .25s;}
    .dropdown-item:hover{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;}
    .dropdown-item i{color:#6f2b67;}.dropdown-item:hover i{color:#fff;}
    .hamburger-btn{background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.5);color:#fff;width:42px;height:42px;border-radius:10px;font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .3s;margin-left:10px;}
    .mobile-menu{background:var(--purple);display:none;flex-direction:column;padding:10px 0;border-top:1px solid rgba(255,255,255,.2);}
    .mobile-menu.open{display:flex!important;}
    .mobile-nav-link{color:#fff;text-decoration:none;font-weight:600;font-size:15px;padding:14px 24px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,.1);transition:all .25s;}
    .mobile-nav-link:hover{background:rgba(255,255,255,.15);padding-left:32px;}

    /* ── BREADCRUMB ── */
    .breadcrumb-wrap{background:#fff;padding:12px 20px;border-bottom:1px solid #f0e5f5;}
    .breadcrumb{margin:0;font-size:13px;}
    .breadcrumb-item a{color:var(--purple);text-decoration:none;font-weight:600;}
    .breadcrumb-item.active{color:#999;}

    /* ── PAGE TITLE ── */
    .page-title-strip{background:linear-gradient(135deg,var(--purple) 0%,var(--light) 100%);padding:28px 20px;text-align:center;position:relative;overflow:hidden;}
    .page-title-strip::before{content:'📦';font-size:130px;position:absolute;right:-10px;top:50%;transform:translateY(-50%);opacity:.08;pointer-events:none;}
    .page-title-strip h2{font-family:'Playfair Display',serif;color:#fff;font-size:2rem;font-weight:900;margin:0;animation:fadeDown .8s;}
    .page-title-strip p{color:rgba(255,255,255,.75);font-size:13px;margin:6px 0 0;}

    .my-toast{z-index: 999999 !important;}
    /* ── MAIN WRAP ── */
    .orders-wrap{max-width:1100px;margin:0 auto;padding:32px 20px 60px;}

    /* ── SECTION CARD (same as checkout theme) ── */
    .section-card{position:relative;border-radius:20px;padding:24px;background:radial-gradient(ellipse 55% 45% at 8% 12%,rgba(196,130,210,.18) 0%,transparent 70%),radial-gradient(ellipse 40% 50% at 92% 85%,rgba(111,43,103,.13) 0%,transparent 65%),linear-gradient(145deg,#faf4fd 0%,#f2e8f9 35%,#ede0f5 65%,#f5edfb 100%);border:1.5px solid rgba(184,138,180,.30);box-shadow:0 2px 0 rgba(255,255,255,.85) inset,0 8px 32px rgba(111,43,103,.10);overflow:hidden;margin-bottom:20px;}
    .section-card::before{content:'';position:absolute;inset:0;border-radius:20px;background-image:radial-gradient(circle,rgba(111,43,103,.06) 1px,transparent 1px);background-size:20px 20px;pointer-events:none;z-index:0;}
    .section-card>*{position:relative;z-index:1;}

    /* ── SEARCH + FILTER ── */
    .search-row{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;align-items:center;}
    .search-box{flex:1;min-width:200px;position:relative;}
    .search-box input{width:100%;border:1.5px solid rgba(184,138,180,.5);border-radius:12px;padding:10px 14px 10px 40px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);background:rgba(255,255,255,.9);outline:none;transition:all .3s;}
    .search-box input:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(111,43,103,.08);}
    .search-box i{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--border);font-size:14px;}
    .filter-tabs{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:20px;}
    .filter-tab{border:1.5px solid rgba(184,138,180,.45);background:rgba(255,255,255,.85);color:var(--muted);font-size:12.5px;font-weight:700;padding:7px 18px;border-radius:30px;cursor:pointer;transition:all .25s;white-space:nowrap;}
    .filter-tab:hover:not(.active){border-color:var(--purple);color:var(--purple);background:rgba(243,232,242,.9);}
    .filter-tab.active{background:var(--purple);color:#fff;border-color:var(--purple);box-shadow:0 3px 10px rgba(111,43,103,.25);}

    /* ── TABLE ── */
    .table-wrap{overflow-x:auto;border-radius:14px;border:1.5px solid rgba(184,138,180,.18);}
    table.ord-table{width:100%;border-collapse:collapse;background:rgba(255,255,255,.88);}
    table.ord-table thead tr{background:linear-gradient(135deg,rgba(111,43,103,.07),rgba(142,74,134,.04));}
    table.ord-table thead th{padding:13px 16px;font-size:11.5px;font-weight:800;color:var(--purple);text-transform:uppercase;letter-spacing:.8px;white-space:nowrap;border-bottom:2px solid rgba(184,138,180,.2);}
    table.ord-table tbody tr{border-bottom:1px solid rgba(184,138,180,.1);transition:background .2s;}
    table.ord-table tbody tr:last-child{border-bottom:none;}
    table.ord-table tbody tr:hover{background:rgba(243,232,242,.4);}
    table.ord-table td{padding:14px 16px;vertical-align:middle;}
    .prod-cell{display:flex;align-items:center;gap:11px;}
    .prod-thumb{width:44px;height:56px;border-radius:7px;object-fit:cover;border:1.5px solid rgba(184,138,180,.3);flex-shrink:0;}
    .prod-name{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:14px;color:var(--ink);line-height:1.3;}
    .prod-more{font-size:11px;color:var(--muted);margin-top:2px;}
    .oid-cell{font-weight:700;font-size:12.5px;color:var(--purple);}
    .date-cell{font-size:12px;color:var(--muted);white-space:nowrap;}
    .total-cell{font-weight:800;font-size:14px;color:var(--ink);white-space:nowrap;}

    /* ── STATUS BADGES ── */
    .sbadge{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:700;padding:5px 13px;border-radius:30px;white-space:nowrap;}
    .sb-processing{background:rgba(230,81,0,.11);color:#e65100;}
    .sb-shipped    {background:rgba(21,101,192,.11);color:#1565c0;}
    .sb-delivered  {background:rgba(46,125,50,.11);color:#2e7d32;}
    .sb-cancelled  {background:rgba(198,40,40,.11);color:#c62828;}
    .sb-returned   {background:rgba(106,27,154,.11);color:#6a1b9a;}
    .pbadge{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:700;padding:5px 13px;border-radius:30px;white-space:nowrap;}
    .pb-cod    {background:rgba(46,125,50,.11);color:#2e7d32;}
    .pb-pending{background:rgba(230,81,0,.11);color:#e65100;}
    .pb-paid   {background:rgba(46,125,50,.11);color:#2e7d32;}
    .pb-failed {background:rgba(198,40,40,.11);color:#c62828;}
    .pb-refund {background:rgba(106,27,154,.11);color:#6a1b9a;}

    /* ── DETAILS BUTTON ── */
    .btn-details{background:transparent;color:var(--purple);border:1.5px solid rgba(111,43,103,.35);border-radius:20px;padding:6px 16px;font-size:12px;font-weight:700;cursor:pointer;transition:all .25s;white-space:nowrap;}
    .btn-details:hover{background:var(--purple);color:#fff;border-color:var(--purple);}

    /* ── EMPTY ── */
    .empty-state{text-align:center;padding:48px 20px;}
    .empty-state img{width:95px;opacity:.7;animation:float 3s ease-in-out infinite;margin-bottom:14px;}
    .empty-state h4{font-family:'Playfair Display',serif;color:var(--ink);font-size:1.1rem;margin-bottom:5px;}
    .empty-state p{color:var(--muted);font-size:13px;}
    .btn-shop-now{display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--purple),var(--light));color:#fff;border:none;border-radius:12px;padding:10px 20px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .3s;margin-top:12px;text-decoration:none;}
    .btn-shop-now:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(111,43,103,.3);color:#fff;}

    /* ══════════════════════════════════
       DETAIL MODAL — clean white style
       (like Image 2 & 3)
    ══════════════════════════════════ */
    .detail-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:flex-start;justify-content:center;padding:30px 16px 30px;overflow-y:auto;opacity:0;pointer-events:none;transition:opacity .3s;}
    .detail-overlay.open{opacity:1;pointer-events:all;}

    .detail-modal{
      background:#fff;
      border-radius:16px;
      width:100%;max-width:680px;
      box-shadow:0 20px 60px rgba(0,0,0,.18);
      overflow:hidden;
      animation:modalIn .3s ease;
    }

    /* modal top bar — purple */
    .dm-topbar{
      background:var(--purple);
      padding:14px 20px;
      display:flex;align-items:center;justify-content:space-between;
    }
    .dm-topbar-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:800;color:#fff;}
    .dm-topbar-close{width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,.2);border:none;color:#fff;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .25s;flex-shrink:0;}
    .dm-topbar-close:hover{background:rgba(255,255,255,.35);}

    /* modal scrollable content */
    .dm-content{padding:20px;max-height:calc(90vh - 130px);overflow-y:auto;}

    /* ── Order Info section ── */
    .dm-section{margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid #eee;}
    .dm-section:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
    .dm-section-title{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:800;color:var(--ink);margin-bottom:12px;}
    .dm-section-title-icon{font-size:16px;}

    .dm-info-row{display:flex;padding:5px 0;font-size:13px;}
    .dm-info-label{color:var(--muted);width:140px;flex-shrink:0;font-weight:600;}
    .dm-info-val{color:var(--ink);font-weight:600;}

    /* ── Product rows ── */
    .dm-product{
      display:flex;align-items:center;gap:12px;
      background:#f8f5fb;
      border-radius:12px;
      padding:12px 14px;
      margin-bottom:10px;
    }
    .dm-product:last-child{margin-bottom:0;}
    .dm-prod-img{width:52px;height:64px;border-radius:8px;object-fit:cover;border:1px solid #e0d0e0;flex-shrink:0;}
    .dm-prod-info{flex:1;min-width:0;}
    .dm-prod-name{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:14px;color:var(--ink);}
    .dm-prod-meta{font-size:12px;color:var(--muted);margin-top:2px;}
    .dm-prod-price{font-size:13px;font-weight:800;color:var(--purple);margin-top:3px;}
    .dm-prod-status{display:inline-flex;font-size:10px;font-weight:700;padding:2px 9px;border-radius:10px;margin-top:4px;}

    /* per-product action button */
    .btn-prod-cancel{border:1.5px solid rgba(198,40,40,.4);background:#fff;color:#c62828;border-radius:8px;padding:5px 14px;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap;flex-shrink:0;}
    .btn-prod-cancel:hover{background:#fff0f0;border-color:#c62828;}
    .btn-prod-return{border:1.5px solid rgba(106,27,154,.4);background:#fff;color:#6a1b9a;border-radius:8px;padding:5px 14px;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap;flex-shrink:0;}
    .btn-prod-return:hover{background:#f5eeff;border-color:#6a1b9a;}
    .cancelled-tag{font-size:11px;font-weight:700;color:#c62828;background:rgba(198,40,40,.08);padding:4px 10px;border-radius:8px;white-space:nowrap;flex-shrink:0;}
    .returned-tag{font-size:11px;font-weight:700;color:#6a1b9a;background:rgba(106,27,154,.08);padding:4px 10px;border-radius:8px;white-space:nowrap;flex-shrink:0;}

    /* ── Shipping address ── */
    .dm-addr-name{font-weight:700;font-size:13px;color:var(--ink);}
    .dm-addr-line{font-size:12.5px;color:var(--muted);line-height:1.8;}

    /* ── Modal bottom action bar ── */
    .dm-footer{
      padding:14px 20px;
      border-top:1px solid #eee;
      display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;
      background:#fafafa;
    }
    .btn-dm-invoice{background:#2e7d32;color:#fff;border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:6px;}
    .btn-dm-invoice:hover{background:#1b5e20;transform:translateY(-1px);}
    .btn-dm-close{background:#6c757d;color:#fff;border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;}
    .btn-dm-close:hover{background:#495057;}
    .btn-dm-cancel-order{background:transparent;color:#c62828;border:1.5px solid rgba(198,40,40,.4);border-radius:10px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:6px;}
    .btn-dm-cancel-order:hover{background:#fff0f0;}
    .btn-dm-return-order{background:transparent;color:#6a1b9a;border:1.5px solid rgba(106,27,154,.4);border-radius:10px;padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:6px;}
    .btn-dm-return-order:hover{background:#f5eeff;}

    /* ── CANCEL / RETURN REASON MODALS ── */
    .modal-overlay{position:fixed;inset:0;background:rgba(26,15,24,.5);backdrop-filter:blur(4px);z-index:1100;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;}
    .modal-overlay.open{opacity:1;pointer-events:all;}
    .modal-box{background:linear-gradient(145deg,#faf4fd,#f2e8f9);border-radius:20px;padding:26px;width:90%;max-width:400px;border:1.5px solid rgba(184,138,180,.3);box-shadow:0 20px 60px rgba(111,43,103,.25);transform:scale(.9) translateY(20px);transition:all .35s;position:relative;}
    .modal-overlay.open .modal-box{transform:scale(1) translateY(0);}
    .modal-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:800;color:var(--ink);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
    .modal-x{position:absolute;top:13px;right:13px;width:26px;height:26px;border:none;background:rgba(111,43,103,.1);border-radius:50%;color:var(--purple);font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
    .modal-x:hover{background:var(--purple);color:#fff;}
    .r-label{font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--purple);margin-bottom:7px;display:block;}
    .r-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
    .r-chip{border:1.5px solid rgba(184,138,180,.5);background:rgba(255,255,255,.8);color:var(--muted);font-size:11px;font-weight:600;padding:5px 11px;border-radius:20px;cursor:pointer;transition:all .2s;}
    .r-chip.sel{background:var(--purple);color:#fff;border-color:var(--purple);}
    .r-ta{width:100%;border:1.5px solid rgba(184,138,180,.5);border-radius:10px;padding:9px 13px;font-family:'DM Sans',sans-serif;font-size:12.5px;color:var(--ink);background:rgba(255,255,255,.8);outline:none;resize:vertical;min-height:68px;transition:all .3s;}
    .r-ta:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(111,43,103,.08);}
    .r-err{font-size:11px;color:var(--sale);margin-top:4px;display:none;}
    .modal-btns{display:flex;gap:9px;margin-top:13px;}
    .btn-mc{flex:1;background:linear-gradient(135deg,var(--purple),var(--light));color:#fff;border:none;border-radius:11px;padding:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .3s;}
    .btn-mc:hover{transform:translateY(-1px);box-shadow:0 5px 18px rgba(111,43,103,.3);}
    .btn-mk{flex:1;border:2px solid var(--border);background:rgba(255,255,255,.8);color:var(--purple);border-radius:11px;padding:9px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .3s;}
    .btn-mk:hover{border-color:var(--purple);}

    /* ── FOOTER ── */
    .site-footer{background:var(--purple);color:#fff;padding:40px 20px;}
    .site-footer a{color:#fff;text-decoration:none;}.site-footer a:hover{color:#f3dff1;}

    @media(max-width:680px){
      .main-nav{display:none;}
      .orders-wrap{padding:20px 12px 50px;}
      .dm-footer{justify-content:stretch;}
      .dm-footer button{flex:1;}
    }
  </style>
</head>
<body>

<div class="top-offer">Get 10% off for your first purchase — USE CODE <strong>NEW1</strong></div>

<!-- ═══ HEADER ═══ -->
<header class="navbar-area">
  <div class="navbar-container">
    <div class="row align-items-center g-0">
      <div class="col-6 d-flex align-items-center gap-3">
        <a class="brand" href="/">
          <div class="logo-circle">
            <img src="https://cdn-icons-png.flaticon.com/512/2702/2702134.png" class="book-logo" alt="Book">
            <div class="logo-text">LitHeaven</div>
          </div>
          <div class="txt">LitHeaven</div>
        </a>
        <nav class="main-nav d-none d-lg-flex gap-1">
          <a class="nav-link" href="/">Home</a>
          <a class="nav-link" href="/shop">Shop</a>
         
        </nav>
      </div>
      <div class="col-6 d-flex justify-content-end align-items-center">
        <div class="header-icons">
          <a class="icon-btn position-relative" href="/wishlist" title="Wishlist">
              <i class="fa-solid fa-heart"></i>
              <div class="icon-badge" id="wishlistBadge">0</div>
            </a>
             <a class="icon-btn position-relative" href="/cart" title="Cart">
              <i class="fa-solid fa-cart-shopping"></i>
              <div class="icon-badge" id="cartBadge">0</div>
            </a>
           
          <div class="dropdown">
            <div class="icon-btn dropdown-toggle" id="profileMenu" data-bs-toggle="dropdown"><i class="fa-regular fa-user"></i></div>
