function shareProduct() {
  if (navigator.share) { navigator.share({ title: 'Atomic Habits – LitHeaven', url: window.location.href }); }
  else { navigator.clipboard.writeText(window.location.href); Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Link copied!', showConfirmButton: false, timer: 1600 }); }
}

/* ══ TABS ══ */
function switchTab(w) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + w).classList.add('active');
  document.getElementById('pane-' + w).classList.add('active');
}

/* ══ READ MORE ══ */
function toggleRM(btn) {
  const body = btn.closest('.rc-body'), short = body.querySelector('.rc-short'), full = body.querySelector('.rc-full');
  const open = full.style.display === 'inline';
  short.style.display = open ? 'inline' : 'none';
  full.style.display  = open ? 'none'   : 'inline';
  btn.textContent = open ? 'Read more' : 'Read less';
}

/* ══ SEE ALL REVIEWS ══ */
function toggleSeeAll() {
  const extra = document.getElementById('extraReviews'), btn = document.getElementById('seeAllBtn');
  const open = extra.classList.contains('open');
  if (!open) { extra.classList.add('open'); btn.textContent = 'Show Less ▲'; btn.classList.add('open'); setTimeout(() => extra.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 80); }
  else       { extra.classList.remove('open'); btn.textContent = 'See All Reviews'; btn.classList.remove('open'); }
}

/* ══ HELPFUL ══ */
function markHelpful(btn) { const n = parseInt(btn.textContent.replace('👍 ', '')); btn.textContent = `👍 ${n + 1}`; btn.disabled = true; btn.style.opacity = '.5'; }

/* ══ WRITE REVIEW ══ */
function openWriteReview() {
  if (!STATE.isLoggedIn)   { window.location.href = '/login'; return; }
  if (!STATE.hasPurchased) { openModal('notPurchasedModal'); return; }
  STATE.selectedRating = 0;
  document.querySelectorAll('.sr').forEach(s => s.classList.remove('lit'));
  document.getElementById('reviewText').value  = '';
  document.getElementById('reviewTitle').value = '';
  openModal('writeReviewModal');
}
function openWriteReview() {

if(!STATE.isLoggedIn){

Swal.fire({
icon:"warning",
title:"Login Required",
text:"Please login to write a review",
showCancelButton:true,
confirmButtonText:"Go to Login",
cancelButtonText:"Cancel"
}).then((result)=>{

if(result.isConfirmed){
window.location.href="/login"
}

})

return
}

if(!STATE.hasPurchased){

openModal("notPurchasedModal")
return

}

STATE.selectedRating = 0

document.querySelectorAll(".sr")
.forEach(s=>s.classList.remove("lit"))

document.getElementById("reviewText").value=""
document.getElementById("reviewTitle").value=""

openModal("writeReviewModal")

}


function setRating(val) { STATE.selectedRating = val; document.querySelectorAll('.sr').forEach((s, i) => s.classList.toggle('lit', i < val)); }



async function submitReview(){

if(!STATE.selectedRating ){
Swal.fire({
toast:true,
position:"top-end",
icon:"warning",
title:"Please select rating ⭐",
showConfirmButton:false,
timer:2000
})
return
}

const text = document.getElementById("reviewText").value.trim()
const title = document.getElementById("reviewTitle").value.trim()

if(!text){
  
Swal.fire({
toast:true,
position:"top-end",
icon:"warning",
title:"Please write a review ✍️",
showConfirmButton:false,
timer:2000
})

return
}

try{

const res = await fetch("/review/add",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({
productId: productData._id,
rating: STATE.selectedRating,
title:title,
reviewText:text
})
})

if(res.status === 401){
Swal.fire({
icon:"warning",
title:"Please login first"
}).then(()=>{
window.location.href="/login"
})
return
}

const data = await res.json()

if(data.success){
  Swal.fire({
    toast: true,
    position: "top-end",
    icon: "success",
    title: data.message || "Review submitted successfully ⭐",
    showConfirmButton: false,
    timer: 2000
  })

  setTimeout(() => {
    location.reload()
  }, 2000)
}else{

Swal.fire({
toast:true,
position:"top-end",
icon:"warning",
title:data.message,
showConfirmButton:false,
timer:2000
})

}

}catch(err){

Swal.fire({
icon:"error",
title:"Server error"
})

}

}

/* ══ MODALS ══ */
