<script>

const productData = JSON.parse(
document.getElementById("productData").textContent
);

const DISCOUNT = parseInt(document.getElementById('discountData').dataset.discount) || 0;

function calcOfferPrice(originalPrice) {
  if (DISCOUNT > 0) {
    return Math.round(originalPrice - (originalPrice * DISCOUNT / 100));
  }
  return originalPrice;
}

let currentVariant = 0;
let currentFormat = productData.variants[0].formats[0].format;


function changeLanguage(index, el) {
  index = Number(index);
  currentVariant = index;
  const variant = productData.variants[index];
  document.getElementById("mainImg").src = variant.thumbnail.url;
  let format = variant.formats.find(f => f.format === currentFormat);
  if (!format) {
    currentFormat = variant.formats[0].format;
    format = variant.formats[0];
  }
  const stockEl = document.querySelector(".avail-count");
  if (format.stock === 0) {
    stockEl.innerText = "0 In Stock";
    stockEl.style.color = "red";
  } else {
    stockEl.innerText = format.stock + " In Stock";
    stockEl.style.color = "green";
  }

  const offerPrice = calcOfferPrice(format.price);
  document.querySelector(".new-price").innerText = "₹" + offerPrice;
  const oldPriceEl = document.querySelector(".old-price");
  if (oldPriceEl) {
    if (DISCOUNT > 0) {
      oldPriceEl.innerText = "₹" + format.price;
      oldPriceEl.style.display = "inline";
    } else {
      oldPriceEl.style.display = "none";
    }
  }

  const thumbStrip = document.querySelector(".thumb-strip");
  thumbStrip.innerHTML = "";
  variant.subImages.forEach((img, i) => {
    thumbStrip.innerHTML += `
      <div class="thumb-item ${i === 0 ? 'active' : ''}" onclick="swapImages(this)">
        <img src="${img.url}">
      </div>`;
  });
  const formatGroup = document.getElementById("formatGroup");
  let formatHTML = "";
  ["paperback", "hardcover"].forEach(fmt => {
    const available = variant.formats.find(f => f.format === fmt);
    const notAvailable = !available;
    const isOutOfStock = available && available.stock === 0;
    const isDisabled = notAvailable || isOutOfStock;
    const isSelected = available && fmt === currentFormat;
    formatHTML += `
      <div class="format-item">
        <span
          class="tag-pill ${isSelected ? 'selected' : ''} ${isDisabled ? 'disabled' : ''}"
          data-format="${fmt}"
        >
          ${fmt}
        </span>
        ${isOutOfStock ? `<div class="out-text">Out of Stock</div>` : ''}
      </div>`;
  });
  formatGroup.innerHTML = formatHTML;
  document.querySelectorAll('.tag-group[data-type="language"] .tag-pill')
    .forEach(p => p.classList.remove("selected"));
  el.classList.add("selected");
}

document.addEventListener("click", function(e) {
  const pill = e.target.closest("#formatGroup .tag-pill");
  if (!pill) return;
  if (pill.classList.contains("disabled")) return;
  const fmt = pill.dataset.format;
  changeFormatByName(fmt, pill);
});
//===========================================================================

/* ══ STATE ══ */
const loginEl = document.getElementById("loginStatus")

const isLoggedIn = loginEl ? loginEl.dataset.login === "true" : false

const STATE = {
isLoggedIn,
hasPurchased: true,
cartCount: 0,
wished: false,
selectedRating: 0
};



let currentImgIdx = 0;

/* ══ THUMBNAIL SWAP ══ */
function swapImages(clickedThumb) {
  const mainImg  = document.getElementById("mainImg");
  const thumbImg = clickedThumb.querySelector("img");
  const tempSrc  = mainImg.src;
  mainImg.src    = thumbImg.src;
  thumbImg.src   = tempSrc;
  document.querySelectorAll(".thumb-item").forEach(item => item.classList.remove("active"));
  clickedThumb.classList.add("active");
  const thumbs = [...document.querySelectorAll('.thumb-item')];
  currentImgIdx = thumbs.indexOf(clickedThumb);
}

/* ══ MAIN IMAGE — bracket cursor + hover pan zoom ══ */
const mainZoom = (() => {
  const wrap = document.getElementById('mainImgWrap');
  const img  = document.getElementById('mainImg');
  const cur  = document.getElementById('magCursor');
  const scan = document.getElementById('imgScan');
  const ZOOM = 2.4;
  let active = false;

  function reset() {
    active = false; wrap.classList.remove('zoomed', 'scan-run');
    img.style.transition = 'transform .5s cubic-bezier(.23,1,.32,1)';
    img.style.transform  = 'scale(1) translate(0,0)';
  }
  function enter() {
    active = true; wrap.classList.add('zoomed');
    wrap.classList.remove('scan-run'); void scan.offsetWidth; wrap.classList.add('scan-run');
    img.style.transition = 'transform .3s cubic-bezier(.23,1,.32,1)';
    img.style.transform  = `scale(${ZOOM}) translate(0,0)`;
  }
  function leave() { reset(); }
  function move(e) {
    const r = wrap.getBoundingClientRect();
    const cx = e.clientX - r.left, cy = e.clientY - r.top;
    cur.style.left = cx + 'px'; cur.style.top = cy + 'px';
    if (!active) return;
    const nx = cx / r.width, ny = cy / r.height;
    const maxX = r.width  * (ZOOM - 1) / (2 * ZOOM);
    const maxY = r.height * (ZOOM - 1) / (2 * ZOOM);
    const tx = (0.5 - nx) * maxX * 2, ty = (0.5 - ny) * maxY * 2;
    img.style.transition = 'transform .07s linear';
    img.style.transform  = `scale(${ZOOM}) translate(${tx / ZOOM}px,${ty / ZOOM}px)`;
  }
  wrap.addEventListener('mouseenter', enter);
  wrap.addEventListener('mouseleave', leave);
  wrap.addEventListener('mousemove',  move);
  wrap.addEventListener('click', () => lightbox.open(currentImgIdx));
  let tActive = false;
  wrap.addEventListener('touchstart', e => { tActive = true; enter(); e.preventDefault(); }, { passive: false });
  wrap.addEventListener('touchmove',  e => { if (tActive) move(e.touches[0]); e.preventDefault(); }, { passive: false });
  wrap.addEventListener('touchend',   () => { tActive = false; reset(); setTimeout(() => lightbox.open(currentImgIdx), 100); });
  return { reset };
})();

/* ══ CINEMATIC LIGHTBOX ══ */
const lightbox = (() => {
  const overlay  = document.getElementById('lbOverlay');
  const stage    = document.getElementById('lbStage');
  const img      = document.getElementById('lbImg');
  const cur      = document.getElementById('lbCur');
  const counter  = document.getElementById('lbCounter');
  const dots     = document.getElementById('lbDots');
  const hint     = document.getElementById('lbHint');
  const scan     = document.getElementById('lbScan');
  const zoomFill = document.getElementById('lbZoomFill');
  const BASE = 3, MIN = 1, MAX = 5;
  let wheelScale = 1, tx = 0, ty = 0;
  let dragging = false, dsx = 0, dsy = 0, dtx = 0, dty = 0;
  let hintTimer;

  function buildDots() {
    dots.innerHTML = IMGS.map((_, i) => `<div class="lb-dot ${i === currentImgIdx ? 'active' : ''}" data-i="${i}"></div>`).join('');
    dots.querySelectorAll('.lb-dot').forEach(d => d.addEventListener('click', e => { e.stopPropagation(); setImg(+d.dataset.i); }));
  }
  function syncUI() {
    const n = String(currentImgIdx + 1).padStart(2, '0');
    counter.textContent = `${n} / ${String(IMGS.length).padStart(2, '0')}`;
    dots.querySelectorAll('.lb-dot').forEach((d, i) => d.classList.toggle('active', i === currentImgIdx));
    document.getElementById('mainImg').src = IMGS[currentImgIdx];
    document.querySelectorAll('.thumb-item').forEach((t, i) => t.classList.toggle('active', i === currentImgIdx));
  }
  function runScan() { scan.classList.remove('run'); void scan.offsetWidth; scan.classList.add('run'); setTimeout(() => scan.classList.remove('run'), 700); }
  function resetT(smooth) {
    tx = 0; ty = 0; wheelScale = 1;
    img.style.transition = smooth ? 'transform .4s cubic-bezier(.23,1,.32,1)' : 'none';
    img.style.transform  = `scale(${BASE}) translate(0,0)`;
    zoomFill.style.height = '0%';
  }
  function setImg(idx) {
    currentImgIdx = idx; img.style.opacity = '0'; resetT(false);
    setTimeout(() => { img.src = IMGS[idx]; img.style.transition = 'opacity .2s'; img.style.opacity = '1'; runScan(); syncUI(); }, 100);
  }
  function onMouseMove(e) {
    cur.style.left = e.clientX + 'px'; cur.style.top = e.clientY + 'px';
    if (dragging) return;
    const r = stage.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) return;
    const nx = (e.clientX - r.left) / r.width, ny = (e.clientY - r.top) / r.height;
    const eff = BASE * wheelScale;
    const maxX = r.width * (eff - 1) / (2 * eff), maxY = r.height * (eff - 1) / (2 * eff);
    tx = (0.5 - nx) * maxX * 2; ty = (0.5 - ny) * maxY * 2;
    img.style.transition = 'transform .06s linear';
    img.style.transform  = `scale(${eff}) translate(${tx / eff}px,${ty / eff}px)`;
  }
  function onWheel(e) {
    e.preventDefault();
    wheelScale = Math.min(MAX, Math.max(MIN, wheelScale + (e.deltaY < 0 ? .3 : -.3)));
    const eff = BASE * wheelScale;
    img.style.transition = 'transform .1s ease';
    img.style.transform  = `scale(${eff}) translate(${tx / eff}px,${ty / eff}px)`;
    zoomFill.style.height = ((wheelScale - MIN) / (MAX - MIN) * 100) + '%';
  }
  function onDragStart(e) { if (wheelScale <= 1) return; dragging = true; dsx = e.clientX; dsy = e.clientY; dtx = tx; dty = ty; stage.style.cursor = 'grabbing'; }
  function onDragMove(e) { if (!dragging) return; const eff = BASE * wheelScale; tx = dtx + (e.clientX - dsx) / eff; ty = dty + (e.clientY - dsy) / eff; img.style.transition = 'none'; img.style.transform = `scale(${eff}) translate(${tx}px,${ty}px)`; }
  function onDragEnd() { dragging = false; stage.style.cursor = ''; }
  let t0x = 0;
  stage.addEventListener('touchstart', e => { t0x = e.touches[0].clientX; }, { passive: true });
  stage.addEventListener('touchend', e => { const dx = e.changedTouches[0].clientX - t0x; if (Math.abs(dx) > 50) navigate(dx < 0 ? 1 : -1); }, { passive: true });
  function navigate(dir) { setImg((currentImgIdx + dir + IMGS.length) % IMGS.length); }
  function open(idx) {
    currentImgIdx = idx; img.src = IMGS[idx]; img.style.opacity = '1';
    buildDots(); syncUI(); resetT(false); runScan();
    overlay.classList.add('show'); document.body.style.overflow = 'hidden';
    hint.classList.remove('hide'); clearTimeout(hintTimer);
    hintTimer = setTimeout(() => hint.classList.add('hide'), 3200);
  }
  function close() { overlay.classList.remove('show'); document.body.style.overflow = ''; }

  document.getElementById('lbClose').addEventListener('click', e => { e.stopPropagation(); close(); });
  document.getElementById('lbPrev').addEventListener('click',  e => { e.stopPropagation(); navigate(-1); });
  document.getElementById('lbNext').addEventListener('click',  e => { e.stopPropagation(); navigate(1); });
  overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
  overlay.addEventListener('mousemove', onMouseMove);
  stage.addEventListener('wheel', onWheel, { passive: false });
  stage.addEventListener('mousedown', onDragStart);
  window.addEventListener('mousemove', onDragMove);
  window.addEventListener('mouseup', onDragEnd);
  document.addEventListener('keydown', e => {
    if (!overlay.classList.contains('show')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowRight') navigate(1);
    if (e.key === 'ArrowLeft')  navigate(-1);
  });
  return { open };
})();

