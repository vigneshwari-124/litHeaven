function changeQty(d) { const i = document.getElementById('qtyInput'); i.value = Math.min(24, Math.max(1, parseInt(i.value) + d)); }


/* ══ WISHLIST ══ */
async function toggleWish() {

if(!STATE.isLoggedIn){
Swal.fire({
icon:"warning",
title:"Login Required",
text:"Please login to add product to cart"
}).then(()=>{
window.location.href="/login"
})
return
}

const btn = document.getElementById('wishBtn');

const productId = btn.dataset.product;

const languageEl = document.querySelector('.tag-group[data-type="language"] .selected');
const formatEl = document.querySelector('#formatGroup .selected');

const languageId = languageEl ? languageEl.dataset.language : "<%= defaultVariant.language._id %>";
const format = formatEl ? formatEl.dataset.format : "<%= defaultFormat.format %>";

try{

const res = await fetch("/wishlist/toggle",{
  method:"POST",
  headers:{
    "Content-Type":"application/json"
  },
  body:JSON.stringify({
    productId,
    languageId,
    format
  })
})

const data = await res.json()

STATE.wished = data.status === "added"

btn.classList.toggle('wished', STATE.wished)

btn.innerHTML = '<i class="fa-solid fa-heart"></i>'

Swal.fire({
  toast:true,
  position:'top-end',
  icon: STATE.wished ? 'success' : 'info',
  title: STATE.wished ? '❤️ Added to wishlist' : '💔 Removed',
  showConfirmButton:false,
  timer:1600
})

}catch(err){
console.log(err)
}

}

