  /* ═══════════════════════════════════════════
     ON LOAD — fetch addresses + render items
  ═══════════════════════════════════════════ */
  window.onload = async () => {
    await loadAddresses();
    await loadOrderItems();
    updateSummary();

    await loadCoupons();
  };

  /* ═══════════════════════════════════════════
     FETCH ADDRESSES FROM API
  ═══════════════════════════════════════════ */
  async function loadAddresses() {
    try {
      const res  = await fetch('/api/addresses');
      const data = await res.json();

      if (data.success) {
        addresses = data.addresses;

        /* auto-select primary (or first) address */
        const primary = addresses.find(a => a.isPrimary);
        selectedAddr  = primary ? primary._id : (addresses[0]?._id || null);
      }
    } catch (err) {
      console.error('Failed to load addresses:', err);
    }

    renderAddresses();
  }

  /* ═══════════════════════════════════════════
     RENDER ADDRESS CARDS
     — primary first
     — tick button on top-right to select delivery address
     — clicking tick on non-primary sets it as primary via API
  ═══════════════════════════════════════════ */
  function renderAddresses() {
    const grid = document.getElementById('addrGrid');

    /* primary address always on top */
    const sorted = [...addresses].sort((a, b) => b.isPrimary - a.isPrimary);

    grid.innerHTML = sorted.map(a => {
      const typeIcon = a.type === 'Home' ? '🏠' : a.type === 'Office' ? '🏢' : '📍';
      const typeLabel = a.type || 'Home';
      const isSelected = a._id === selectedAddr;

      /* build address detail line */
      const parts = [
        a.addressLine1,
        a.addressLine2,
        a.city ? `${a.city} - ${a.zip}` : '',
        a.country || 'India'
      ].filter(Boolean);

      return `
        <div class="addr-card ${isSelected ? 'selected' : ''}" onclick="selectAddr('${a._id}')">

          <!-- left: type badge -->
          <div class="addr-type-badge">${typeIcon} ${typeLabel}</div>

          <!-- middle: name + address -->
          <div class="addr-info">
            <div class="addr-name-row">
              <span class="addr-name">${a.fullName}</span>
              ${a.isPrimary ? `<span class="addr-default-badge">Primary</span>` : ''}
            </div>
            <div class="addr-detail">${parts.join('<span>|</span>')}</div>
          </div>

          <!-- right: actions + tick -->
          <div class="addr-actions">
            <button class="btn-edit"   onclick="editAddr(event,'${a._id}')"><i class="fa-solid fa-pen"></i> Edit</button>
            <button class="btn-delete" onclick="deleteAddr(event,'${a._id}')"><i class="fa-solid fa-trash"></i> Delete</button>
            <button
              class="addr-tick-btn"
              title="${isSelected ? 'Selected' : 'Select'}"
              onclick="handleTickClick(event,'${a._id}')">
              <i class="fa-solid fa-check"></i>
            </button>
          </div>

        </div>
      `;
    }).join('');
  }

  /* ─── Select address for delivery (card click) ─── */
  function selectAddr(id) {
    selectedAddr = id;
    renderAddresses();
  }

  /* ─── Tick button click:
       • if already selected  → do nothing
       • if not selected      → select it AND set as primary via API
  ─── */
  async function handleTickClick(e, id) {
    e.stopPropagation();

    if (selectedAddr === id) return; /* already selected, nothing to do */

    selectedAddr = id;

    /* Set as primary (default) via API */
    try {
      const res  = await fetch(`/addresses/set-primary/${id}`, {
       method: 'PATCH'
      });
      const data = await res.json();
      if (data.success) {
        await loadAddresses(); /* reload so isPrimary badge updates */
        return;
      }
    } catch (_) {}

    /* Fallback: update locally if API not ready */
    addresses.forEach(a => a.isPrimary = (a._id === id));
    renderAddresses();
  }

  /* ═══════════════════════════════════════════
     DELETE ADDRESS
  ═══════════════════════════════════════════ */
  async function deleteAddr(e, id) {
    e.stopPropagation();

    const confirm = await Swal.fire({
      title: 'Delete Address?',
      text: 'Are you sure you want to remove this address?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#6f2b67',
      cancelButtonText: 'Cancel',
      confirmButtonText: 'Yes, Delete'
    });

    if (!confirm.isConfirmed) return;

    try {
      const res  = await fetch(`/addresses/delete/${id}`, { method: 'DELETE' });
      const data = await res.json();

      if (data.success) {
  Swal.fire({
    toast: true,
    position: 'top-end',
    icon: 'success',
    title: 'Address deleted successfully',
    showConfirmButton: false,
    timer: 2000
  });

  await loadAddresses();
}
    } catch (err) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Could not delete address.' });
    }
  }

  /* ═══════════════════════════════════════════
     EDIT ADDRESS — pre-fill modal
  ═══════════════════════════════════════════ */
  function editAddr(e, id) {
    e.stopPropagation();
    const a = addresses.find(x => x._id === id);
    if (!a) return;

    editingAddrId = id;

    document.getElementById('fName').value    = a.fullName      || '';
    document.getElementById('fAddr1').value   = a.addressLine1  || '';
    document.getElementById('fAddr2').value   = a.addressLine2  || '';
    document.getElementById('fCity').value    = a.city          || '';
    document.getElementById('fState').value   = a.state         || '';
    document.getElementById('fPin').value     = a.zip           || '';
    document.getElementById('fCountry').value = a.country       || 'India';

    /* set address type radio */
    const typeVal = a.type || 'Home';
    const radios  = document.querySelectorAll('input[name="addrType"]');
    radios.forEach(r => { r.checked = (r.value === typeVal); });

    document.getElementById('modalTitle').innerHTML =
      '<i class="fa-solid fa-pen-to-square" style="color:var(--purple)"></i> Edit Address';

    document.getElementById('addrModalOverlay').classList.add('open');
  }

  /* ═══════════════════════════════════════════
     OPEN MODAL (Add new)
  ═══════════════════════════════════════════ */
  function openAddrModal() {
    editingAddrId = null;

    /* clear fields */
    ['fName','fAddr1','fAddr2','fCity','fState','fPin'].forEach(id => {
      document.getElementById(id).value = '';
    });
    document.getElementById('fCountry').value = 'India';

    /* reset address type to Home */
    document.getElementById('typeHome').checked = true;

    /* clear any previous errors */
    document.querySelectorAll('.error-text').forEach(el  => el.style.display = 'none');
    document.querySelectorAll('.form-ctrl').forEach(el   => el.classList.remove('input-error'));

    document.getElementById('modalTitle').innerHTML =
      '<i class="fa-solid fa-location-dot" style="color:var(--purple)"></i> Add Address';

    document.getElementById('addrModalOverlay').classList.add('open');
  }

  /* ═══════════════════════════════════════════
     CLOSE MODAL
  ═══════════════════════════════════════════ */
  function closeAddrModal(e, force = false) {
    if (force || e?.target === document.getElementById('addrModalOverlay')) {
      document.getElementById('addrModalOverlay').classList.remove('open');
    }
  }

  /* ═══════════════════════════════════════════
     VALIDATION HELPER
  ═══════════════════════════════════════════ */
  function validateField(inputId, errorId, customCheck) {
    const input = document.getElementById(inputId);
    const error = document.getElementById(errorId);
    const val   = input.value.trim();

    const invalid = customCheck ? customCheck(val) : !val;

    if (invalid) {
      input.classList.add('input-error');
      error.style.display = 'block';
      return false;
    } else {
      input.classList.remove('input-error');
      error.style.display = 'none';
      return true;
    }
  }

  /* ═══════════════════════════════════════════
     SAVE ADDRESS (Add + Edit)
  ═══════════════════════════════════════════ */
  async function saveAddress() {
    /* ── Validation ── */
    let valid = true;

    if (!validateField('fName',    'errName'))    valid = false;
    if (!validateField('fAddr1',   'errAddr1'))   valid = false;
    if (!validateField('fCity',    'errCity'))    valid = false;
    if (!validateField('fState',   'errState'))   valid = false;
    if (!validateField('fCountry', 'errCountry')) valid = false;
    if (!validateField('fPin', 'errPin', v => !/^\d{6}$/.test(v))) valid = false;

    if (!valid) return;

    /* ── Get selected address type ── */
    const selectedType = document.querySelector('input[name="addrType"]:checked')?.value || 'Home';

    const body = {
      fullName:     document.getElementById('fName').value.trim(),
      addressLine1: document.getElementById('fAddr1').value.trim(),
      addressLine2: document.getElementById('fAddr2').value.trim(),
      city:         document.getElementById('fCity').value.trim(),
      state:        document.getElementById('fState').value.trim(),
      zip:          document.getElementById('fPin').value.trim(),
      country:      document.getElementById('fCountry').value.trim() || "India",
      type:         selectedType
    };

   let url = '';
let method = '';

if (editingAddrId) {
  url = `/addresses/edit/${editingAddrId}`;   
  method = 'PUT';
} else {
  url = `/addresses/add`;                    
  method = 'POST';
}

    try {
      const res  = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();

       if (data.success) {
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: data.message,
        showConfirmButton: false,
        timer: 2000
      });

      closeAddrModal(null, true);
      loadAddresses();
    } else {
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'error',
        title: data.message,
        showConfirmButton: false,
        timer: 2000
      });
    }

    } catch (err) {
      Swal.fire({ icon: 'error', title: 'Network Error', text: 'Please try again.', confirmButtonColor: '#6f2b67' });
    }
  }

  /* ── Live validation — clear error on input ── */
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.form-ctrl').forEach(input => {
      input.addEventListener('input', () => {
        if (input.value.trim()) {
          input.classList.remove('input-error');
          const err = input.nextElementSibling;
          if (err && err.classList.contains('error-text')) err.style.display = 'none';
        }
      });
    });
  });

  /* ═══════════════════════════════════════════
     RENDER ORDER ITEMS
  ═══════════════════════════════════════════ */
 async function loadOrderItems() {
  try {
    const res = await fetch('/get-cart');
    const data = await res.json();

    const list = document.getElementById('orderItemsList');
    list.innerHTML = '';

    let totalItems = 0;
    subtotal = 0; 

    cartItems = data.items;

    data.items.forEach(item => {
      const product = item.productId;

      const variant = product.variants.find(v =>
        v.language._id.toString() === item.languageId._id.toString()
      );

      const formatData = variant?.formats.find(f =>
        f.format === item.format
      );

      const price = formatData ? formatData.price : 0;
      const total = price * item.quantity;

      const image = variant?.thumbnail?.url || '';

      totalItems += item.quantity;
      subtotal += total;

      list.innerHTML += `
        <div class="order-item">
          <img src="${image}" class="order-item-img"/>
          <div class="order-item-info">
            <div class="order-item-title">${product.title}</div>
            <div class="order-item-meta">
              ${product.author?.name || ''} · ${item.languageId?.name || ''} · ${item.format}
            </div>
            <div class="order-item-qty">Qty: ${item.quantity}</div>
          </div>
          <div style="text-align:right">
            <div class="order-item-price">₹${total}</div>
          </div>
        </div>
      `;
    });

    document.getElementById('itemCountLabel').innerText =
      totalItems + ' items';

    updateSummary(); 

  } catch (err) {
    console.log(err);
  }
}



function updateSummary() {

  let totalItems = 0;

  (cartItems || []).forEach(item => {
    totalItems += item.quantity;
  });

  const delivery = DELIVERY_CHARGE;
  const totalAmount = subtotal + delivery -discountAmount;

  document.getElementById('sumItemCount').innerText = totalItems;
  document.getElementById('sumSubtotal').innerText = `₹${subtotal}`;
  document.getElementById('sumDelivery').innerText = `₹${delivery}`;
  document.getElementById('sumDiscount').innerText = `−₹${discountAmount}`;
  document.getElementById('sumTotal').innerText = `₹${totalAmount}`;

  const hasOut = cartItems.some(i => i.stock === 0)

const btn = document.querySelector(".btn-place-order");

if (btn) {
  btn.disabled = hasOut;
}
}

async function placeOrder() {
  try {

    // loading popup
    Swal.fire({
      title: 'Placing Order...',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });

    const res = await fetch('/place-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        addressId: selectedAddr,
        paymentMethod: selectedPayment
      })
    });

    const data = await res.json();

    Swal.close(); //  close loading

    if (data.success) {

      showSuccessPage(data); // IMPORTANT

    } else {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: data.message || 'Order failed'
      });
    }

  } catch (err) {
    console.log(err);
  }
}

function showSuccessPage(data) {

  //hide checkout
  document.getElementById('checkoutPage').style.display = 'none';

  // show success
  document.getElementById('successPage').style.display = 'block';

  //  Order ID (random / backend irunthu varala na temp)
  document.getElementById('successOrderId').innerText =
    data.orderId || 'LH-' + Math.floor(Math.random() * 100000);

 
  document.getElementById('successDetails').innerHTML = `
    <div class="success-detail-row">
      <span class="sd-label">Items</span>
      <span class="sd-val">${document.getElementById('sumItemCount').innerText}</span>
    </div>

    <div class="success-detail-row">
      <span class="sd-label">Total Paid</span>
      <span class="sd-val">₹${data.total}</span>
    </div>

    <div class="success-detail-row">
      <span class="sd-label">Payment</span>
      <span class="sd-val">Cash on Delivery</span>
    </div>
  `;

 
  launchConfetti();
}

function launchConfetti() {
  const wrap = document.getElementById('confettiWrap');
  wrap.innerHTML = '';

  for (let i = 0; i < 40; i++) {
    const div = document.createElement('div');
    div.className = 'confetti-piece';
    div.style.left = Math.random() * 100 + '%';
    div.style.background = ['#6f2b67','#8e4a86','#c49abf','#ff4081'][Math.floor(Math.random()*4)];
    div.style.animationDelay = Math.random() * 1 + 's';
    wrap.appendChild(div);
  }
}
  

  /* ═══════════════════════════════════════════
     COUPON
  ═══════════════════════════════════════════ */
 async function applyCoupon() {
  const code = document.getElementById('couponInput').value.trim().toUpperCase();
  const msg  = document.getElementById('couponMsg');
  const chip = document.getElementById('couponChip');

  if (!code) {
    msg.innerHTML = `<div class="coupon-error">Enter a coupon code</div>`;
     clearBtn.style.display = 'block';
    return;
  }

  try {
    const res = await fetch('/apply-coupon', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        code,
        cartTotal: subtotal
      })
    });

    const data = await res.json();

    if (data.success) {
      appliedCoupon = code;

      discountAmount = data.discount; 

      msg.innerHTML = `
        <div class="coupon-success">
          ${data.message}
        </div>
      `;

      chip.style.display = 'block';
      document.getElementById('couponChipText').innerText =
        `${code} (−₹${data.discount})`;

      // update discount
      updateSummary(data.discount);

    } else {
      appliedCoupon = null;
      discountAmount = 0; 

      msg.innerHTML = `
        <div class="coupon-error">
          ${data.message}
        </div>
      `;
       document.getElementById('couponChip').style.display = 'none';

      
      
    }
  clearBtn.style.display = 'block'; 

    updateSummary();
  } catch (err) {
    msg.innerHTML = `<div class="coupon-error">Server error</div>`;
  }
}

  function removeCoupon() {
    appliedCoupon = null;
    document.getElementById('couponInput').value  = '';
    document.getElementById('couponMsg').innerHTML = '';
    document.getElementById('couponChip').style.display = 'none';
    updateSummary();
  }

  function fillCoupon(code) {
    document.getElementById('couponInput').value = code;
    applyCoupon();
  }

  /* ═══════════════════════════════════════════
     PAYMENT
  ═══════════════════════════════════════════ */
  function selectPayment(type) {
    selectedPayment = type;
    document.querySelectorAll('.payment-opt').forEach(el => el.classList.remove('selected'));
    document.getElementById('payOpt-' + type)?.classList.add('selected');
  }

  
  /* ═══════════════════════════════════════════
     SUCCESS PAGE
  ═══════════════════════════════════════════ */
  function showSuccess() {
    const prices  = updateSummary();
    const addr    = addresses.find(a => a._id === selectedAddr);
    const orderId = 'LH-' + Date.now().toString().slice(-6);

    document.getElementById('successOrderId').textContent = orderId;
    document.getElementById('successDetails').innerHTML = `
      <div class="success-detail-row"><span class="sd-label">Delivery To</span><span class="sd-val">${addr.fullName}</span></div>
      <div class="success-detail-row"><span class="sd-label">Address</span><span class="sd-val">${addr.addressLine1}, ${addr.city}</span></div>
      <div class="success-detail-row"><span class="sd-label">Payment</span><span class="sd-val">Cash on Delivery</span></div>
      <div class="success-detail-row"><span class="sd-label">Items</span><span class="sd-val">${demoItems.length} books</span></div>
      <div class="success-detail-row"><span class="sd-label">Total Paid</span><span class="sd-val" style="color:var(--purple)">₹${prices.total}</span></div>
      ${appliedCoupon ? `<div class="success-detail-row"><span class="sd-label">Coupon Used</span><span class="sd-val" style="color:var(--success)">${appliedCoupon} (−₹${prices.couponDisc})</span></div>` : ''}
    `;

    document.getElementById('checkoutPage').style.display          = 'none';
    document.getElementById('successPage').style.display           = 'block';
    document.querySelector('.page-title-strip').style.display      = 'none';
    document.querySelector('.breadcrumb-wrap').style.display       = 'none';

    document.getElementById('step3').classList.add('active');
    document.getElementById('step2').classList.remove('active');
    document.getElementById('step2').classList.add('done');
    document.getElementById('step2').innerHTML = '<i class="fa-solid fa-check" style="font-size:12px"></i>';
    document.querySelector('.step-line:last-of-type')?.classList.add('done');

    launchConfetti();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ═══════════════════════════════════════════
     CONFETTI
  ═══════════════════════════════════════════ */
  function launchConfetti() {
    const wrap   = document.getElementById('confettiWrap');
    const colors = ['#6f2b67','#c47ed4','#e0a8f0','#fff','#f3e8f2','#8e4a86'];
    for (let i = 0; i < 60; i++) {
      const piece = document.createElement('div');
      piece.className   = 'confetti-piece';
      piece.style.left  = Math.random() * 100 + '%';
      piece.style.top   = '-20px';
      piece.style.background        = colors[Math.floor(Math.random() * colors.length)];
      piece.style.transform         = `rotate(${Math.random() * 360}deg)`;
      piece.style.animationDelay    = Math.random() * 1.5 + 's';
      piece.style.animationDuration = (1.5 + Math.random() * 1.5) + 's';
      wrap.appendChild(piece);
      piece.addEventListener('animationend', () => piece.remove());
    }
  }

  /* ═══════════════════════════════════════════
     MOBILE MENU
  ═══════════════════════════════════════════ */
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  menuToggle?.addEventListener('click', function () {
    mobileMenu.classList.toggle('open');
    const icon = this.querySelector('i');
    icon.classList.toggle('fa-bars');
    icon.classList.toggle('fa-xmark');
  });
  document.addEventListener('click', function (e) {
    if (mobileMenu && menuToggle && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
      mobileMenu.classList.remove('open');
      const icon = menuToggle.querySelector('i');
      if (icon) { icon.classList.add('fa-bars'); icon.classList.remove('fa-xmark'); }
    }
  });

  document.getElementById('logoutBtn')?.addEventListener('click', function (e) {
    e.preventDefault();
    Swal.fire({
      title: "<span style='color:#6f2b67;font-weight:700'>Logout?</span>",
      html: `<p style="font-size:14px;color:#555;margin-bottom:8px">Are you sure you want to logout? 💜</p>`,
      showCancelButton: true,
      confirmButtonText: '🚪 Logout',
      cancelButtonText: 'Stay Here',
      confirmButtonColor: '#6f2b67',
      cancelButtonColor: '#d6c3d3',
      reverseButtons: true,
      background: 'linear-gradient(135deg,#f6eef6,#efe3f0)',
    }).then(r => { if (r.isConfirmed) window.location.href = '/logout'; });
  });

