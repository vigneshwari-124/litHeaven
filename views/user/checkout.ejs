    .success-check-svg { width: 52px; height: 52px; }
    .success-check-svg .check-path { stroke: #fff; stroke-width: 4; stroke-linecap: round; stroke-linejoin: round; fill: none; stroke-dasharray: 50; stroke-dashoffset: 50; animation: checkDraw .5s ease .7s forwards; }
    .success-card { position: relative; border-radius: 24px; padding: 36px 28px; background: radial-gradient(ellipse 55% 45% at 8% 12%,rgba(196,130,210,.18) 0%,transparent 70%), radial-gradient(ellipse 40% 50% at 92% 85%,rgba(111,43,103,.13) 0%,transparent 65%), linear-gradient(145deg,#faf4fd 0%,#f2e8f9 35%,#ede0f5 65%,#f5edfb 100%); border: 1.5px solid rgba(184,138,180,.30); box-shadow: 0 2px 0 rgba(255,255,255,.85) inset,0 8px 32px rgba(111,43,103,.10); overflow: hidden; }
