<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
  <title>Checkout – LitHeaven</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,400&family=Playfair+Display:wght@700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* ─── ERROR STYLES ─── */
    .error-text {
      color: #e53935;
      font-size: 12px;
      margin-top: 4px;
      display: none;
    }
    .input-error {
      border: 2px solid #e53935 !important;
    }

    .coupon-input-box {
  position: relative;
  width: 100%;
}

.coupon-input {
  width: 100%;
  padding-right: 35px;
}

#clearBtn {
  position: absolute;
  right: 10px;
  top: 50%;
  transform: translateY(-50%);
  cursor: pointer;
  font-size: 14px;
  color: #888;
  display: none;
}

#clearBtn:hover {
  color: red;
}

    :root {
      --purple:  #6f2b67;
      --light:   #8e4a86;
      --muted:   #6c6c6c;
      --pur-lt:  #f3e8f2;
      --pur-mid: #c49abf;
      --border:  #b88ab4;
      --sale:    #e8412e;
      --ink:     #1a0f18;
      --success: #2e7d32;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "DM Sans", "Segoe UI", Roboto, Arial;
      background: linear-gradient(135deg, #f5f0f6 0%, #e8dff0 50%, #f0e5f5 100%);
      color: #222; overflow-x: hidden; max-width: 100vw; min-height: 100vh;
    }

    @keyframes fadeUp    { from { opacity: 0; transform: translateY(30px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes fadeDown  { from { opacity: 0; transform: translateY(-30px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes pulse     { 0%, 100% { transform: scale(1) } 50% { transform: scale(1.05) } }
    @keyframes float     { 0%, 100% { transform: translateY(0) } 50% { transform: translateY(-10px) } }
    @keyframes slideUp   { from { opacity: 0; transform: translateY(24px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes shineSweep{ 0% { transform: translateX(-100%) rotate(25deg) } 100% { transform: translateX(300%) rotate(25deg) } }
    @keyframes popIn     { 0% { opacity: 0; transform: scale(.85) } 60% { transform: scale(1.04) } 100% { opacity: 1; transform: scale(1) } }
    @keyframes checkDraw { 0% { stroke-dashoffset: 50 } 100% { stroke-dashoffset: 0 } }
    @keyframes confettiFall { 0% { transform: translateY(-20px) rotate(0deg); opacity: 1 } 100% { transform: translateY(100px) rotate(720deg); opacity: 0 } }

    /* ─── TOP BAR ─── */
    .top-offer { background: #000; color: #fff; text-align: center; font-weight: 600; padding: 8px; font-size: 14px; animation: fadeDown .6s; }

    /* ─── HEADER ─── */
    header.navbar-area { background: var(--purple); color: #fff; padding: 12px 0; animation: fadeDown .8s; width: 100%; }
    .navbar-container { max-width: 100%; padding: 0 15px; margin: 0 auto; }
    .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #fff; transition: transform .3s; }
    .brand:hover { transform: scale(1.05); }
    .logo-circle { position: relative; width: 60px; height: 60px; border-radius: 50%; border: 2px solid #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; animation: float 3s ease-in-out infinite; }
    .book-logo { width: 35px; filter: brightness(0) invert(1); }
    .logo-text { position: absolute; bottom: 5px; font-size: 7px; font-weight: 800; color: #fff; letter-spacing: .8px; text-transform: uppercase; }
    .brand .txt { font-weight: 800; font-size: 20px; letter-spacing: .6px; }
    .main-nav .nav-link { color: #fff; font-weight: 600; padding: 8px 12px; transition: all .3s; position: relative; }
    .main-nav .nav-link::after { content: ''; position: absolute; bottom: 0; left: 50%; width: 0; height: 2px; background: #fff; transition: all .3s; transform: translateX(-50%); }
    .main-nav .nav-link:hover::after { width: 80%; }
    .main-nav .nav-link:hover { color: #f3dff1; transform: translateY(-2px); }
    .header-icons { display: flex; gap: 16px; align-items: center; }
    .icon-btn { color: #fff; font-size: 20px; position: relative; cursor: pointer; transition: all .3s; text-decoration: none; }
    .icon-btn:hover { transform: scale(1.2) rotate(5deg); color: #fff; }
    .icon-badge { position: absolute; top: -6px; right: -8px; background: #fff; color: var(--purple); font-weight: 700; font-size: 11px; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; border-radius: 50%; animation: pulse 2s infinite; }
    .dropdown-menu { border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(111,43,103,.25); padding: 8px; }
    .dropdown-item { border-radius: 8px; padding: 10px 14px; font-weight: 600; color: #333; transition: all .25s ease; }
    .dropdown-item:hover { background: linear-gradient(135deg,#6f2b67,#8e4a86); color: #fff; transform: translateX(5px); }
    .dropdown-item i { color: #6f2b67; transition: color .25s ease; }
    .dropdown-item:hover i { color: #fff; }
    .hamburger-btn { background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.5); color: #fff; width: 42px; height: 42px; border-radius: 10px; font-size: 18px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all .3s; margin-left: 10px; flex-shrink: 0; }
    .hamburger-btn:hover { background: rgba(255,255,255,.3); transform: scale(1.05); }
    .mobile-menu { background: var(--purple); display: none; flex-direction: column; padding: 10px 0; animation: fadeDown .3s ease; border-top: 1px solid rgba(255,255,255,.2); box-shadow: 0 8px 20px rgba(0,0,0,.2); width: 100%; }
    .mobile-menu.open { display: flex !important; }
    .mobile-nav-link { color: #fff; text-decoration: none; font-weight: 600; font-size: 15px; padding: 14px 24px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(255,255,255,.1); transition: all .25s; }
    .mobile-nav-link:hover { background: rgba(255,255,255,.15); color: #f3dff1; padding-left: 32px; }
    .mobile-nav-link i { width: 20px; text-align: center; opacity: .85; }

    /* ─── BREADCRUMB ─── */
    .breadcrumb-wrap { background: #fff; padding: 13px 20px; border-bottom: 1px solid #f0e5f5; }
    .breadcrumb { margin: 0; font-size: 13px; }
    .breadcrumb-item a { color: var(--purple); text-decoration: none; font-weight: 600; }
    .breadcrumb-item.active { color: #999; font-weight: 500; }
    .breadcrumb-item+.breadcrumb-item::before { color: #d0c0d0; }

    /* ─── PAGE TITLE ─── */
    .page-title-strip { background: linear-gradient(135deg,var(--purple) 0%,var(--light) 100%); padding: 28px 20px; text-align: center; position: relative; overflow: hidden; }
    .page-title-strip::before { content: '🛍️'; font-size: 130px; position: absolute; right: -10px; top: 50%; transform: translateY(-50%); opacity: .08; user-select: none; pointer-events: none; }
    .page-title-strip h2 { font-family: 'Playfair Display',serif; color: #fff; font-size: 2rem; font-weight: 900; margin: 0; animation: fadeDown .8s; }
    .page-title-strip p { color: rgba(255,255,255,.75); font-size: 13px; margin: 6px 0 0; animation: fadeUp 1s; }

    /* ─── STEPPER ─── */
    .stepper-wrap { max-width: 500px; margin: 28px auto 0; display: flex; align-items: center; justify-content: center; gap: 0; animation: fadeUp .9s; }
    .step-item { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; }
    .step-circle { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,.25); border: 2px solid rgba(255,255,255,.5); color: #fff; font-weight: 800; font-size: 13px; display: flex; align-items: center; justify-content: center; transition: all .4s; }
    .step-circle.active { background: #fff; color: var(--purple); }
    .step-circle.done { background: rgba(255,255,255,.85); color: var(--purple); }
    .step-label { font-size: 10px; font-weight: 700; color: rgba(255,255,255,.75); letter-spacing: .8px; text-transform: uppercase; }
    .step-label.active { color: #fff; }
    .step-line { flex: 1; height: 2px; background: rgba(255,255,255,.25); margin-top: -18px; }
    .step-line.done { background: rgba(255,255,255,.7); }

    /* ─── MAIN LAYOUT ─── */
    .checkout-wrap { max-width: 1200px; margin: 0 auto; padding: 36px 20px 60px; display: grid; grid-template-columns: 1fr 420px; gap: 28px; animation: fadeUp .9s; }

    /* ─── SECTION CARDS ─── */
    .section-card {
      position: relative; border-radius: 20px; padding: 24px;
      background:
        radial-gradient(ellipse 55% 45% at 8% 12%, rgba(196,130,210,.18) 0%,transparent 70%),
        radial-gradient(ellipse 40% 50% at 92% 85%, rgba(111,43,103,.13) 0%,transparent 65%),
        linear-gradient(145deg,#faf4fd 0%,#f2e8f9 35%,#ede0f5 65%,#f5edfb 100%);
      border: 1.5px solid rgba(184,138,180,.30);
      box-shadow: 0 2px 0 rgba(255,255,255,.85) inset,0 8px 32px rgba(111,43,103,.10),0 1px 4px rgba(111,43,103,.06);
      overflow: hidden; margin-bottom: 20px;
    }
    .section-card::before { content: ''; position: absolute; inset: 0; border-radius: 20px; background-image: radial-gradient(circle,rgba(111,43,103,.06) 1px,transparent 1px); background-size: 20px 20px; pointer-events: none; z-index: 0; }
    .section-card > * { position: relative; z-index: 1; }

    .section-title { font-family: 'Playfair Display',serif; font-size: 1.1rem; font-weight: 800; color: var(--ink); display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
    .section-title-icon { width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg,var(--purple),var(--light)); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 14px; }

    /* ─── ADDRESS LIST (stacked rows) ─── */
    .addr-grid { display: flex; flex-direction: column; gap: 10px; }

    /* ── each row ── */
    .addr-card {
      border: 2px solid rgba(184,138,180,.35);
      border-radius: 14px;
      padding: 14px 16px;
      cursor: pointer;
      transition: all .3s;
      background: rgba(255,255,255,.75);
      position: relative;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .addr-card:hover { border-color: var(--purple); background: rgba(243,232,242,.9); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(111,43,103,.1); }
    .addr-card.selected { border-color: var(--purple); background: rgba(243,232,242,.95); box-shadow: 0 4px 16px rgba(111,43,103,.15); }

    /* ── tick button (right side) ── */
    .addr-tick-btn {
      width: 26px; height: 26px;
      border-radius: 50%;
      border: 2px solid rgba(184,138,180,.5);
      background: rgba(255,255,255,.8);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: all .3s;
      flex-shrink: 0;
    }
    .addr-tick-btn i { font-size: 11px; color: var(--border); transition: all .3s; }
    .addr-card.selected .addr-tick-btn { background: var(--purple); border-color: var(--purple); }
    .addr-card.selected .addr-tick-btn i { color: #fff; }

    /* ── type badge (left pill) ── */
    .addr-type-badge {
      display: inline-flex; align-items: center; gap: 5px;
      background: rgba(111,43,103,.07);
      border: 1.5px solid rgba(184,138,180,.35);
      color: var(--purple);
      font-size: 11px; font-weight: 700;
      padding: 5px 12px;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
      min-width: 80px;
      justify-content: center;
    }

    /* ── middle info ── */
    .addr-info { flex: 1; min-width: 0; }
    .addr-name-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .addr-name { font-weight: 700; font-size: 13px; color: var(--ink); }
    .addr-default-badge {
      display: inline-flex; align-items: center; gap: 3px;
      background: var(--purple); color: #fff;
      font-size: 9px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase;
      padding: 2px 8px; border-radius: 20px;
    }
    .addr-detail { font-size: 11.5px; color: var(--muted); line-height: 1.6; margin-top: 2px; }
    .addr-detail span { margin: 0 3px; opacity: .4; }

    /* ── action buttons ── */
    .addr-actions { display: flex; gap: 8px; flex-shrink: 0; align-items: center; }
    .btn-edit {
      background: var(--purple); color: #fff; border: none;
      padding: 7px 16px; border-radius: 20px; font-size: 12px; font-weight: 600;
      cursor: pointer; transition: all .2s;
      display: flex; align-items: center; gap: 5px;
    }
    .btn-edit:hover { background: var(--light); transform: translateY(-1px); }
    .btn-delete {
      background: transparent; color: #e53935;
      border: 2px solid rgba(229,57,53,.25);
      padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600;
      cursor: pointer; transition: all .2s;
      display: flex; align-items: center; gap: 5px;
    }
    .btn-delete:hover { background: #ffeaea; border-color: #e53935; transform: translateY(-1px); }

    .btn-add-addr { border: 2px dashed var(--border); background: transparent; color: var(--purple); border-radius: 14px; padding: 14px; width: 100%; font-weight: 700; font-size: 12px; cursor: pointer; transition: all .3s; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .btn-add-addr:hover { border-color: var(--purple); background: rgba(111,43,103,.06); }

    /* ─── ADDRESS MODAL ─── */
    .addr-modal-overlay { position: fixed; inset: 0; background: rgba(26,15,24,.5); backdrop-filter: blur(4px); z-index: 1000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .3s; }
    .addr-modal-overlay.open { opacity: 1; pointer-events: all; }
    .addr-modal { background: linear-gradient(145deg,#faf4fd,#f2e8f9); border-radius: 20px; padding: 28px; width: 90%; max-width: 500px; border: 1.5px solid rgba(184,138,180,.3); box-shadow: 0 20px 60px rgba(111,43,103,.25); transform: scale(.9) translateY(20px); transition: all .35s; max-height: 90vh; overflow-y: auto; }
    .addr-modal-overlay.open .addr-modal { transform: scale(1) translateY(0); }
    .modal-close { position: absolute; top: 16px; right: 16px; width: 28px; height: 28px; border: none; background: rgba(111,43,103,.1); border-radius: 50%; color: var(--purple); font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; }
    .modal-close:hover { background: var(--purple); color: #fff; }
    .modal-heading { font-family: 'Playfair Display',serif; font-size: 1.15rem; font-weight: 800; color: var(--ink); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .modal-heading i { color: var(--purple); }

    /* form fields */
    .form-group { margin-bottom: 14px; }
    .form-label { font-size: 11px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: var(--purple); margin-bottom: 6px; display: block; }
    .form-ctrl { width: 100%; border: 1.5px solid rgba(184,138,180,.5); border-radius: 10px; padding: 10px 14px; font-family: 'DM Sans',sans-serif; font-size: 13px; color: var(--ink); background: rgba(255,255,255,.8); transition: all .3s; outline: none; }
    .form-ctrl:focus { border-color: var(--purple); background: #fff; box-shadow: 0 0 0 3px rgba(111,43,103,.08); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* ── Address Type radio group ── */
    .addr-type-group { display: flex; gap: 10px; flex-wrap: wrap; }
    .addr-type-radio { display: none; }
    .addr-type-label {
      display: flex; align-items: center; gap: 6px;
      border: 2px solid rgba(184,138,180,.5);
      border-radius: 10px;
      padding: 8px 14px;
      font-size: 12px; font-weight: 700; color: var(--muted);
      cursor: pointer;
      transition: all .25s;
      background: rgba(255,255,255,.7);
      user-select: none;
    }
    .addr-type-label .type-radio-dot {
      width: 14px; height: 14px;
      border-radius: 50%;
      border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      transition: all .25s;
      flex-shrink: 0;
    }
    .addr-type-radio:checked + .addr-type-label {
      border-color: var(--purple);
      background: rgba(111,43,103,.08);
      color: var(--purple);
    }
    .addr-type-radio:checked + .addr-type-label .type-radio-dot {
      border-color: var(--purple);
      background: var(--purple);
      box-shadow: inset 0 0 0 2px #fff;
    }
    .addr-type-label:hover { border-color: var(--purple); background: rgba(243,232,242,.9); color: var(--purple); }

    .btn-save-addr { width: 100%; background: linear-gradient(135deg,var(--purple),var(--light)); color: #fff; border: none; border-radius: 12px; padding: 13px; font-family: 'DM Sans',sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; transition: all .3s; margin-top: 8px; }
    .btn-save-addr:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(111,43,103,.3); }

    /* ─── COUPON ─── */
    .coupon-row { display: flex; gap: 10px; }
    .coupon-input { flex: 1; border: 2px solid rgba(184,138,180,.5); border-radius: 12px; padding: 11px 14px; font-family: 'DM Sans',sans-serif; font-size: 13px; color: var(--ink); background: rgba(255,255,255,.8); outline: none; transition: all .3s; }
    .coupon-input:focus { border-color: var(--purple); background: #fff; box-shadow: 0 0 0 3px rgba(111,43,103,.08); }
    .btn-apply-coupon { background: linear-gradient(135deg,var(--purple),var(--light)); color: #fff; border: none; border-radius: 12px; padding: 11px 20px; font-weight: 700; font-size: 13px; cursor: pointer; transition: all .3s; white-space: nowrap; }
    .btn-apply-coupon:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(111,43,103,.3); }
    .coupon-success { display: flex; align-items: center; gap: 8px; background: rgba(46,125,50,.08); border: 1.5px solid rgba(46,125,50,.3); border-radius: 10px; padding: 10px 14px; margin-top: 10px; font-size: 12px; font-weight: 600; color: var(--success); animation: slideUp .4s ease; }
    .coupon-error { display: flex; align-items: center; gap: 8px; background: rgba(232,65,46,.06); border: 1.5px solid rgba(232,65,46,.25); border-radius: 10px; padding: 10px 14px; margin-top: 10px; font-size: 12px; font-weight: 600; color: var(--sale); animation: slideUp .4s ease; }
    .coupon-chip { display: inline-flex; align-items: center; gap: 6px; background: rgba(111,43,103,.1); color: var(--purple); font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 20px; margin-top: 8px; }
    .coupon-chip button { background: none; border: none; cursor: pointer; color: var(--purple); font-size: 12px; padding: 0; line-height: 1; }
    .available-coupons { margin-top: 12px; }
    .avail-title { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .coupon-tag { display: inline-flex; align-items: center; gap: 6px; border: 1.5px dashed var(--border); background: rgba(255,255,255,.7); color: var(--purple); font-size: 11px; font-weight: 700; padding: 5px 10px; border-radius: 8px; margin: 3px; cursor: pointer; transition: all .2s; }
    .coupon-tag:hover { background: var(--pur-lt); border-color: var(--purple); }

    /* ─── ORDER ITEMS ─── */
    .order-item { display: flex; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(184,138,180,.2); }
    .order-item:last-child { border-bottom: none; padding-bottom: 0; }
    .order-item-img { width: 56px; height: 72px; border-radius: 8px; object-fit: cover; border: 1.5px solid rgba(184,138,180,.3); flex-shrink: 0; }
    .order-item-info { flex: 1; }
    .order-item-title { font-family: 'Cormorant Garamond',serif; font-size: 14px; font-weight: 700; color: var(--ink); line-height: 1.3; }
    .order-item-meta { font-size: 10px; color: var(--muted); margin-top: 2px; }
    .order-item-qty { font-size: 11px; color: var(--purple); font-weight: 700; margin-top: 4px; background: rgba(111,43,103,.08); display: inline-block; padding: 2px 8px; border-radius: 6px; }
    .order-item-price { font-size: 14px; font-weight: 800; color: var(--purple); white-space: nowrap; font-family: 'DM Sans',sans-serif; text-align: right; }
    .order-item-orig { font-size: 10px; color: var(--pur-mid); text-decoration: line-through; text-align: right; }

    /* ─── ORDER SUMMARY SIDEBAR ─── */
    .summary-sticky { position: sticky; top: 20px; }
    .summary-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid rgba(184,138,180,.15); font-size: 13px; }
    .summary-row:last-of-type { border-bottom: none; }
    .summary-row .label { color: var(--muted); font-weight: 500; }
    .summary-row .val { font-weight: 700; color: var(--ink); }
    .summary-row.discount .val { color: var(--success); font-weight: 700; }
    .summary-row.coupon-row-sum .val { color: var(--sale); font-weight: 700; }
    .summary-row.free .val { color: var(--success); }
    .summary-divider { height: 1.5px; background: linear-gradient(90deg,var(--border),transparent); margin: 10px 0; }
    .summary-total { display: flex; justify-content: space-between; align-items: center; padding: 12px 0 0; }
    .summary-total .label { font-family: 'Playfair Display',serif; font-size: 1rem; font-weight: 800; color: var(--ink); }
    .summary-total .val { font-size: 1.3rem; font-weight: 800; color: var(--purple); font-family: 'DM Sans',sans-serif; }
    .tax-note { font-size: 10px; color: var(--muted); margin-top: 4px; text-align: right; }

    /* ─── PAYMENT ─── */
