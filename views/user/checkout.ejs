    .success-title { font-family: 'Playfair Display',serif; font-size: 1.8rem; font-weight: 900; color: var(--ink); margin-bottom: 8px; }
    .success-sub { font-size: 14px; color: var(--muted); margin-bottom: 6px; }
    .order-id-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(111,43,103,.08); color: var(--purple); font-weight: 800; font-size: 13px; padding: 6px 16px; border-radius: 20px; margin: 12px 0; border: 1.5px solid rgba(184,138,180,.3); }
    .success-divider { height: 1.5px; background: linear-gradient(90deg,transparent,var(--border),transparent); margin: 20px 0; }
    .success-detail-row { display: flex; justify-content: space-between; font-size: 12.5px; padding: 6px 0; border-bottom: 1px solid rgba(184,138,180,.12); }
