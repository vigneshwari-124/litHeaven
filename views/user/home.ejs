function getBestOffer(product, offers) {

  let productOffer = null;
  let subCategoryOffer = null;
  let categoryOffer = null;

  offers.forEach(o => {

    
    if (
      o.type === "product" &&
      String(o.product) === String(product._id)
    ) {
      productOffer = o;
    }

    if (
      o.type === "subcategory" &&
      String(o.subCategory) === String(product.subCategory?._id)
    ) {
      subCategoryOffer = o;
    }

    // CATEGORY OFFER
    if (
      o.type === "category" &&
      String(o.category) === String(product.category?._id)
    ) {
      categoryOffer = o;
    }

  });

 
  return productOffer || subCategoryOffer || categoryOffer || null;
}


