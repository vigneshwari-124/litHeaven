  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    const track = document.getElementById('track');
    const items = [...track.children];
    items.forEach(i => track.appendChild(i.cloneNode(true)));
    
    let idx = 0, moving = false;
    
    function move(dir) {
      if (moving) return;
      moving = true;
      idx += dir;
      track.style.transform = `translateX(-${idx * 230}px)`;
      
      setTimeout(() => {
        if (idx >= 5) { track.style.transition = 'none'; idx = 0; track.style.transform = 'translateX(0)'; setTimeout(() => track.style.transition = 'transform 0.5s ease', 50); }
        if (idx < 0) { track.style.transition = 'none'; idx = 4; track.style.transform = `translateX(-${idx * 230}px)`; setTimeout(() => track.style.transition = 'transform 0.5s ease', 50); }
        moving = false;
      }, 500);
    }

    document.addEventListener('click', function(e){
      const menu = document.querySelector('.profile-dropdown');
      if(!menu) return;
      const toggle = document.getElementById('profileMenu');
      if(toggle && toggle.contains(e.target)) return;
      const shown = document.querySelector('.dropdown-menu.show');
      if(shown && !shown.contains(e.target)) {
        const bsDropdown = bootstrap.Dropdown.getInstance(toggle);
        if(bsDropdown) bsDropdown.hide();
      }
    });

    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);

    document.querySelectorAll('.product-card, .promo, .feature-item').forEach(el => {
      observer.observe(el);
    });
  </script>
  
