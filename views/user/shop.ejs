<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
  <title>LitHeaven – Shop</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root{--purple:#6f2b67;--light:#8e4a86;--muted:#6c6c6c}
    *{box-sizing:border-box}
    body{font-family:"Inter","Segoe UI",Roboto,Arial;margin:0;background:linear-gradient(135deg,#f5f0f6 0%,#e8dff0 50%,#f0e5f5 100%);color:#222;overflow-x:hidden;max-width:100vw}

   
.bcard-stars i{margin-right:2px;font-size:.75rem;}
.bcard-stars .fa-solid{color:#f59e0b;   }
.bcard-stars .fa-regular{ color:#f59e0b;   -webkit-text-stroke: 1px #f59e0b; opacity:0.6;}

    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeDown{from{opacity:0;transform:translateY(-30px)}to{opacity:1;transform:translateY(0)}}
    @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
    @keyframes droplet{0%{transform:scale(1);border-radius:50%}50%{transform:scale(1.1);border-radius:60% 40% 60% 40%}100%{transform:scale(1);border-radius:50%}}

    .top-offer{background:#000;color:#fff;text-align:center;font-weight:600;padding:8px;font-size:14px;animation:fadeDown .6s}

    header.navbar-area{background:var(--purple);color:#fff;padding:12px 0;animation:fadeDown .8s;width:100%}
    .navbar-container{max-width:100%;padding:0 15px;margin:0 auto}
    .brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#fff;transition:transform .3s}
    .brand:hover{transform:scale(1.05)}
    .logo-circle{position:relative;width:60px;height:60px;border-radius:50%;border:2px solid #fff;background:0 0;display:flex;align-items:center;justify-content:center;flex-shrink:0;animation:float 3s ease-in-out infinite}
    .book-logo{width:35px;filter:brightness(0)invert(1)}
    .logo-text{position:absolute;bottom:5px;font-size:7px;font-weight:800;color:#fff;letter-spacing:.8px;text-transform:uppercase}
    .tagline{position:absolute;bottom:0;font-size:3.5px;font-weight:600;color:#fff;letter-spacing:.5px;text-transform:uppercase;opacity:.85}
    .brand .txt{font-weight:800;font-size:20px;letter-spacing:.6px}
    .main-nav .nav-link{color:#fff;font-weight:600;padding:8px 12px;transition:all .3s;position:relative}
    .main-nav .nav-link::after{content:'';position:absolute;bottom:0;left:50%;width:0;height:2px;background:#fff;transition:all .3s;transform:translateX(-50%)}
    .main-nav .nav-link:hover::after,.main-nav .nav-link.active-link::after{width:80%}
    .main-nav .nav-link:hover,.main-nav .nav-link.active-link{color:#f3dff1;transform:translateY(-2px)}
    .header-icons{display:flex;gap:16px;align-items:center}
    .icon-btn{color:#fff;font-size:20px;position:relative;cursor:pointer;transition:all .3s;text-decoration:none;background:none;border:none;padding:0}
    .icon-btn:hover{transform:scale(1.2) rotate(5deg);color:#fff}
    .icon-badge{position:absolute;top:-6px;right:-8px;background:#fff;color:var(--purple);font-weight:700;font-size:11px;width:18px;height:18px;display:flex;align-items:center;justify-content:center;border-radius:50%;animation:pulse 2s infinite}
    .dropdown-menu{border-radius:12px;border:none;box-shadow:0 10px 30px rgba(111,43,103,.25);padding:8px}
    .dropdown-item{border-radius:8px;padding:10px 14px;font-weight:600;color:#333;transition:all .25s ease;position:relative}
    .dropdown-item:hover{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;transform:translateX(5px)}
    .dropdown-item:focus{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;outline:none}
    .dropdown-item i{color:#6f2b67;transition:color .25s ease}
    .dropdown-item:hover i,.dropdown-item:focus i{color:#fff}
    #profileMenu:hover,#profileMenu:focus{background:rgba(255,255,255,.15);border-radius:50%;padding:6px}

    .search-wrap{display:flex;justify-content:center;padding:18px 15px;background:#fff;animation:fadeUp 1s;width:100%;border-bottom:1px solid #f0e5f5}
    .search-box{width:100%;max-width:600px;background:#fff;border-radius:50px;padding:10px 18px;display:flex;align-items:center;gap:10px;box-shadow:0 3px 14px rgba(111,43,103,.10);border:1.5px solid #d8cfe0;transition:all .3s}
    .search-box:focus-within{border-color:#702767;box-shadow:0 5px 20px rgba(111,43,103,.18)}
    .s-emoji{font-size:1.1rem;flex-shrink:0;line-height:1;user-select:none}
    .search-box input{flex:1;border:0;background:0 0;outline:0;color:#333;font-size:14.5px;font-family:inherit;min-width:0}
    .search-box input::placeholder{color:#aaa;font-size:14px}
    .s-cancel{background:none;border:none;cursor:pointer;color:#aaa;font-size:18px;line-height:1;padding:0;flex-shrink:0;display:none;transition:color .2s}
    .s-cancel:hover{color:#555}
    .s-cancel.show{display:block}

    .shop-wrapper{display:flex;min-height:80vh}

    .sidebar{width:265px;flex-shrink:0;background:#fff;border-right:1px solid #e8dff0;padding:20px 16px;position:sticky;top:0;height:calc(100vh);overflow-y:auto}
    .sidebar::-webkit-scrollbar{width:4px}
    .sidebar::-webkit-scrollbar-thumb{background:#d4b8d0;border-radius:4px}
    .filter-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
    .filter-hdr h5{font-weight:700;color:var(--purple);margin:0;font-size:.95rem}
    .clear-all-btn{font-size:.73rem;color:var(--purple);background:none;border:1px solid var(--purple);border-radius:50px;cursor:pointer;font-weight:600;padding:3px 10px;transition:all .2s}
    .clear-all-btn:hover{background:var(--purple);color:#fff}
    .active-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;min-height:4px}
    .atag{display:inline-flex;align-items:center;gap:4px;background:#f3e8ff;color:var(--purple);padding:3px 10px;border-radius:50px;font-size:.7rem;font-weight:600}
    .atag button{background:none;border:none;cursor:pointer;color:var(--purple);font-size:.8rem;line-height:1;padding:0 0 0 3px}

    .fsec{border-top:1px solid #ebe3f0;padding:10px 0 2px}
    .fsec-title{display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:700;font-size:.82rem;color:#333;padding-bottom:6px;user-select:none}
    .fsec-title .farr{transition:transform .2s;font-size:.62rem;color:#aaa; pointer-events:none;  }
    .fsec-title.open .farr{transform:rotate(180deg)}
    .fsec-body{display:none;flex-direction:column;gap:1px;padding-bottom:4px}
    .fsec-body.open{display:flex}
    .cat-parent{display:flex;align-items:center;justify-content:space-between;padding:5px 8px;border-radius:8px;cursor:pointer;font-size:.81rem;font-weight:600;color:#444;transition:background .15s;user-select:none;margin-bottom:2px}
    .cat-parent:hover{background:#f3e8ff;color:var(--purple)}
    .cat-parent .cp-arr{font-size:.58rem;color:#bbb;transition:transform .2s; pointer-events:none; }
    .cat-parent.open .cp-arr{transform:rotate(90deg);color:var(--purple)}
    .sub-opts{display:none;flex-direction:column;gap:1px;padding-left:8px;border-left:2px solid #ebe3f0;margin:2px 0 4px 8px}
    .sub-opts.open{display:flex}
    .foption{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:7px;cursor:pointer;font-size:.79rem;color:#555;transition:background .15s}
    .foption:hover{background:#f3e8ff;color:var(--purple)}
    .foption input[type=checkbox]{accent-color:var(--purple);width:13px;height:13px;cursor:pointer;flex-shrink:0}

    .price-slider-wrap{padding:4px 2px 2px}
    .price-range-labels{display:flex;justify-content:space-between;align-items:center;font-size:.8rem;font-weight:600;color:#555;margin-bottom:10px}
    .price-range-labels .money-emoji{font-size:1.1rem;letter-spacing:2px}
    .price-range-labels .range-val{color:var(--purple);font-weight:700;font-size:.85rem}
    .price-slider{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:50px;outline:none;cursor:pointer;background:linear-gradient(to right,#6f2b67 0%,#6f2b67 100%,#e2d6ef 100%,#e2d6ef 100%);transition:background .15s}
    .price-slider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:20px;height:20px;border-radius:50%;background:var(--purple);cursor:pointer;box-shadow:0 2px 8px rgba(111,43,103,.4);transition:transform .2s}
    .price-slider::-webkit-slider-thumb:hover{transform:scale(1.15)}
    .price-slider::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--purple);cursor:pointer;border:none;box-shadow:0 2px 8px rgba(111,43,103,.4)}
    .price-apply-btn{width:100%;margin-top:12px;padding:9px;background:#22c55e;color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:.85rem;font-weight:700;letter-spacing:.5px;font-family:inherit;transition:all .2s;box-shadow:0 3px 10px rgba(34,197,94,.3)}
    .price-apply-btn:hover{background:#16a34a;transform:translateY(-1px)}
    .apply-all-btn{width:100%;margin-top:14px;padding:10px;background:var(--purple);color:#fff;border:none;border-radius:10px;cursor:pointer;font-size:.88rem;font-weight:700;letter-spacing:.5px;transition:all .2s;box-shadow:0 4px 12px rgba(111,43,103,.2)}
    .apply-all-btn:hover{background:var(--light);transform:translateY(-1px)}

    .main-area{flex:1;padding:22px 20px 40px}
    .breadcrumb-row{display:flex;align-items:center;gap:6px;font-size:.78rem;color:#aaa;margin-bottom:12px}
    .breadcrumb-row a{color:#aaa;text-decoration:none;transition:color .2s}
    .breadcrumb-row a:hover{color:var(--purple)}
    .breadcrumb-row .cur{color:#555;font-weight:600}
    .shop-h1{font-size:1.9rem;font-weight:800;color:#1a0a28;margin-bottom:14px}

    .toolbar{display:flex;align-items:center;gap:9px;flex-wrap:wrap;background:#fff;padding:10px 14px;border-radius:14px;box-shadow:0 4px 16px rgba(111,43,103,.1);margin-bottom:18px;border:1px solid #ebe3f0}
    .tb-chip{padding:6px 15px;border:1.5px solid #ddd;border-radius:50px;font-size:.8rem;font-weight:600;cursor:pointer;background:#fff;color:#666;transition:all .2s;white-space:nowrap;font-family:inherit}
    .tb-chip:hover{border-color:var(--light);color:var(--purple);background:#f9f0f9}
    .tb-chip.active{background:var(--purple);color:#fff;border-color:var(--purple)}
    .tb-spacer{flex:1}
    .tb-count{font-size:.8rem;color:#999;white-space:nowrap}
    .tb-count strong{color:#222;font-weight:700}

    /* ══ CUSTOM SORT DROPDOWN ══ */
    .sort-wrap{position:relative;min-width:190px}
    .sort-btn{
      width:100%;padding:7px 16px;
      border:1.5px solid #ddd;border-radius:50px;
      font-family:inherit;font-size:.8rem;font-weight:600;
      cursor:pointer;background:#fff;color:#555;
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      transition:all .22s;outline:none;
      box-shadow:0 2px 8px rgba(111,43,103,.06);
    }
    .sort-btn:hover,.sort-btn.open{
      border-color:var(--purple);color:var(--purple);
      background:#faf5fb;
      box-shadow:0 4px 14px rgba(111,43,103,.15);
    }
    .sort-arr{font-size:.6rem;transition:transform .22s;color:#bbb;flex-shrink:0}
    .sort-btn.open .sort-arr{transform:rotate(180deg);color:var(--purple)}
    .sort-menu{
      display:none;
      position:absolute;top:calc(100% + 8px);left:0;right:0;
      background:#fff;
      border-radius:16px;
      box-shadow:0 12px 36px rgba(111,43,103,.2);
      border:1.5px solid #ece3f5;
      overflow:hidden;
      z-index:500;
      animation:fadeUp .15s ease;
    }
    .sort-menu.open{display:block}
    .sort-opt{
      padding:11px 16px;
      font-size:.82rem;font-weight:600;
      color:#555;cursor:pointer;
      display:flex;align-items:center;gap:10px;
      transition:all .18s;
      border-bottom:1px solid #f7f0fb;
    }
    .sort-opt:last-child{border-bottom:none}
    .sort-opt:hover{background:linear-gradient(90deg,#f3e8ff,#fdf5ff);color:var(--purple);padding-left:22px}
    .sort-opt.selected{background:#f0e3f8;color:var(--purple);font-weight:700}
    .sort-opt .s-ico{font-size:.88rem;width:20px;text-align:center;flex-shrink:0}

    /* .books-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:16px} */

    .books-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}

    .bcard{background:#fff;border-radius:18px;overflow:hidden;border:2px solid #f0e5f5;box-shadow:0 5px 18px rgba(111,43,103,.08);transition:all .35s;cursor:pointer;position:relative;animation:fadeUp .5s}
    .bcard:hover{transform:translateY(-6px);box-shadow:0 16px 38px rgba(111,43,103,.2);border-color:var(--purple)}
   .disc-badge{
position:absolute;
top:0;
left:0;
background:linear-gradient(135deg,#ff6b35,#f7931e);
color:#fff;
font-size:.72rem;
font-weight:900;
padding:6px 14px 6px 10px;
z-index:4;
letter-spacing:.5px;
clip-path:polygon(0 0,100% 0,85% 50%,100% 100%,0 100%);
box-shadow:2px 4px 12px rgba(255,107,53,.5);
text-shadow:0 1px 3px rgba(0,0,0,.2);
}
    .wish-btn{position:absolute;top:8px;right:8px;background:#fff;border:none;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.12);font-size:.88rem;z-index:2;transition:transform .2s}
    .wish-btn:hover{transform:scale(1.2)}
 .bcard-ph{
width:100%;
height:180px;
display:flex;
align-items:center;
justify-content:center;
font-size:2.8rem;
position:relative;
overflow:hidden;
background:
  linear-gradient(rgba(111,43,103,0.06) 1px, transparent 1px),
  linear-gradient(90deg, rgba(111,43,103,0.06) 1px, transparent 1px),
  linear-gradient(135deg, #f9f0ff 0%, #f0e4ff 40%, #ede0f7 100%);
background-size: 22px 22px, 22px 22px, 100% 100%;
}
.bcard-ph::before{
content:'📖';
position:absolute;
font-size:4.5rem;
opacity:.13;
bottom:-8px;
right:-5px;
transform:rotate(15deg);
filter:grayscale(1);
}
.bcard-ph::after{
content:'📚';
position:absolute;
font-size:3rem;
opacity:.1;
top:-5px;
left:-5px;
transform:rotate(-20deg);
filter:grayscale(1);
}

.bcard-ph img{
position:relative;
z-index:2;
filter:drop-shadow(0 0 10px rgba(168,85,247,0.6)) drop-shadow(0 0 25px rgba(236,72,153,0.3));
}
.bcard:hover .bcard-ph::before{
animation-duration:1.5s;
}
.bcard:hover .bcard-ph img{
filter:drop-shadow(0 0 16px rgba(168,85,247,0.9)) drop-shadow(0 0 35px rgba(236,72,153,0.5));
transition:filter .3s;
}
    .bcard-body{padding:12px 13px 13px}
    .bcard-title{font-size:.79rem;font-weight:700;line-height:1.3;margin-bottom:3px;display:-webkit-box;-webkit-line-clamp:2;line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;color:#222}
    .bcard-author{font-size:.71rem;color:#999;margin-bottom:4px}
    .bcard-stars{color:#f59e0b;font-size:.73rem}
    .bcard-norev{font-size:.67rem;color:#bbb}
    .bcard-prices{display:flex;align-items:center;gap:6px;margin-top:5px}
    .bcard-new{color:var(--purple);font-weight:800;font-size:.88rem}
    .bcard-old{color:#ccc;text-decoration:line-through;font-size:.72rem}
    .bcard-add{width:100%;margin-top:8px;padding:7px;background:var(--purple);color:#fff;border:none;border-radius:50px;font-size:.77rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
    .bcard-add:hover{background:var(--light)}

.no-res{
grid-column:1/-1;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
text-align:center;
height:100%;
color:#aaa;
}

.no-res .nr-ico{
  font-size:3rem;
  margin-bottom:1rem;
}

.no-res h4{
  font-size:1.1rem;
  color:#777;
  font-weight:700;
}

    .pg-wrap{
display:flex;
justify-content:center;
align-items:center;
gap:12px;
margin-top:40px;
flex-wrap:wrap;
}

.pg-btn{
min-width:42px;
height:42px;
padding:0 14px;
border-radius:30px;
display:flex;
align-items:center;
justify-content:center;
font-weight:700;
text-decoration:none;
font-size:14px;
color:#6f2b67;
background:#fff;
border:2px solid #eee;
transition:all .3s ease;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
}

.pg-btn:hover{
background:linear-gradient(135deg,#6f2b67,#8e4a86);
color:#fff;
border-color:#6f2b67;
transform:translateY(-2px);
box-shadow:0 8px 20px rgba(111,43,103,.25);
}

.pg-btn.active{
background:linear-gradient(135deg,#6f2b67,#8e4a86);
color:#fff;
border:none;
box-shadow:0 6px 20px rgba(111,43,103,.4);
transform:scale(1.05);
}

.pg-btn:disabled{
opacity:.35;
pointer-events:none;
}
    
.pg-dots{
font-weight:700;
font-size:18px;
color:#999;
padding:0 6px;
}

    .site-footer{background:var(--purple);color:#fff;padding:40px 15px;width:100%}
    .site-footer a{color:#fff;text-decoration:none;transition:all .3s}
    .site-footer a:hover{color:#f3dff1;transform:translateX(5px);display:inline-block}
    .site-footer li{margin-bottom:6px}

    .hamburger-btn{background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.5);color:#fff;width:42px;height:42px;border-radius:10px;font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .3s;margin-left:10px;flex-shrink:0}
    .hamburger-btn:hover{background:rgba(255,255,255,.3);transform:scale(1.05)}
    .mobile-menu{background:var(--purple);display:none;flex-direction:column;padding:10px 0;animation:fadeDown .3s ease;border-top:1px solid rgba(255,255,255,.2);box-shadow:0 8px 20px rgba(0,0,0,.2);width:100%}
    .mobile-menu.open{display:flex!important}
    .mobile-nav-link{color:#fff;text-decoration:none;font-weight:600;font-size:15px;padding:14px 24px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,.1);transition:all .25s}
    .mobile-nav-link:hover{background:rgba(255,255,255,.15);color:#f3dff1;padding-left:32px}
    .mobile-nav-link i{width:20px;text-align:center;opacity:.85}

    .filter-fab{display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--purple);color:#fff;border:none;padding:13px 30px;border-radius:50px;font-size:.92rem;font-weight:700;font-family:inherit;cursor:pointer;z-index:1050;align-items:center;gap:9px;box-shadow:0 6px 24px rgba(111,43,103,.45);white-space:nowrap;transition:all .25s}
    .filter-fab:hover{background:var(--light);transform:translateX(-50%) translateY(-2px)}
    .filter-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1060;backdrop-filter:blur(2px)}
    .filter-overlay.show{display:block}
    .filter-drawer{position:fixed;left:0;top:0;bottom:0;width:290px;max-width:88vw;background:#fff;z-index:1070;overflow-y:auto;transform:translateX(-100%);transition:transform .3s cubic-bezier(.4,0,.2,1);padding:0}
    .filter-drawer.open{transform:translateX(0)}
    .filter-drawer::-webkit-scrollbar{width:4px}
    .filter-drawer::-webkit-scrollbar-thumb{background:#d4b8d0;border-radius:4px}
    .drawer-header{background:var(--purple);color:#fff;padding:15px 18px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:2}
    .drawer-header h5{margin:0;font-weight:700;font-size:.98rem}
    .drawer-close{background:rgba(255,255,255,.2);border:none;color:#fff;width:32px;height:32px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
    .drawer-close:hover{background:rgba(255,255,255,.35)}
    .drawer-body{padding:16px}

.out-badge{
position:absolute;
top:0;
left:0;
background:linear-gradient(135deg,#1a1a2e,#e53935);
color:white;
font-size:.7rem;
padding:6px 16px 6px 10px;
font-weight:900;
z-index:4;
letter-spacing:.8px;
text-transform:uppercase;
clip-path:polygon(0 0,100% 0,85% 50%,100% 100%,0 100%);
box-shadow:2px 4px 14px rgba(229,57,53,.55);
text-shadow:0 1px 3px rgba(0,0,0,.3);
}

.bcard.out{
opacity:.65;
pointer-events:none;
}

    @media(max-width:900px){.sidebar{width:220px}}
    @media(max-width:768px){
      .sidebar{display:none}
      .filter-fab{display:flex}
      .main-area{padding-bottom:90px}
      .books-grid{grid-template-columns:repeat(2,1fr)}
      .shop-h1{font-size:1.5rem}
