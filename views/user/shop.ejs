<script>



let cartCount = 0;
let currentSort = '';

// ══ PRICE SLIDER sidebar ══
let sliderMax = document.getElementById("priceSlider")
? parseInt(document.getElementById("priceSlider").value)
: 0;

function onSlider(el){

sliderMax = parseInt(el.value)

const label = document.getElementById("priceLabel")

const min = parseInt(label.dataset.min)

label.textContent = `₹${min} – ₹${sliderMax}`

const max = parseInt(el.dataset.max)

const pct = (sliderMax / max) * 100

el.style.background =
`linear-gradient(to right,
#6f2b67 0%,
#6f2b67 ${pct}%,
#e2d6ef ${pct}%,
#e2d6ef 100%)`

}

function syncSliderAndApply(sliderId){
  const sl = document.getElementById(sliderId);
  sliderMax = parseInt(sl.value);
  applyFilters();
}


//////////////////////////////


window.addEventListener("DOMContentLoaded", loadProducts)

async function loadProducts(){

const params = new URLSearchParams(window.location.search)

const res = await fetch("/api/shop?" + params.toString())

const data = await res.json()

renderProducts(data.products)

renderPagination(data)

renderCategories(data.categories)

renderAuthors(data.authors)

renderLanguages(data.languages)

updatePriceRange(data)   
restoreFromURL()

document.getElementById("totalCount").innerText = data.totalCount

}

function restoreFromURL(){

const params = new URLSearchParams(window.location.search)

const cats  = params.get("category")?.split(",") || []
const auths = params.get("author")?.split(",") || []
const langs = params.get("language")?.split(",") || []
const fmts  = params.get("format")?.split(",") || []

const all = [...cats,...auths,...langs,...fmts]

all.forEach(val=>{
document.querySelectorAll(`[data-f][value="${val}"]`).forEach(el=>{
el.checked = true
})
})



const price = params.get("price")

if(price){

const slider = document.getElementById("priceSlider")

slider.value = price

sliderMax = parseInt(price)

onSlider(slider)

}



renderTags()

}


function renderProducts(products){

const grid = document.getElementById("booksGrid")

if(!products.length){
grid.innerHTML = `
<div class="no-res">
<div class="nr-ico">📭</div>
<h4>No books found</h4>
</div>
`
return
}

grid.innerHTML = products.map(p=>{

const price = p.finalPrice || p.originalPrice
const original = p.originalPrice || price
const discount = p.discount || 0

const hasStock = p.variants.some(v =>
  v.formats.some(f => f.stock > 0)
)

return `
<div class="bcard ${!hasStock ? 'out' : ''}" onclick="viewBook('${p._id}')">

${discount > 0 
  ? `<div class="disc-badge">${discount}% OFF</div>` 
  : ""}  

${!hasStock 
  ? `<span class="out-badge">Out of Stock</span>` 
  : ""}

<div class="bcard-ph">
<img src="${p.variants?.[0]?.thumbnail?.url || '/images/no-image.png'}" style="height:150px">
</div>

<div class="bcard-body">

<div class="bcard-title">${p.title}</div>

<div class="bcard-author">${p.author.name}</div>

<div class="bcard-stars">
  ${p.rating > 0 
    ? renderStars(p.rating)
    : `<span class="empty-stars">${renderEmptyStars()}</span>`
  }
</div>

<div class="bcard-prices">

${discount > 0 ? `
  <span class="bcard-new">₹${price}</span>
  <span class="bcard-old">₹${original}</span>
` : `
  <span class="bcard-new">₹${original}</span>
`}

</div>

<button class="bcard-add"
  ${!hasStock ? 'disabled style="opacity:.5;cursor:not-allowed"' : ''}>
<i class="fa-solid fa-eye"></i> View Product
</button>

</div>
</div>
`

}).join("")
}

function goPage(page){

const params = new URLSearchParams(window.location.search)

params.set("page",page)

window.history.pushState({},'',"/shop?"+params.toString())

loadProducts()

}



function renderCategories(categories){

const sidebar = document.getElementById("categoryFilters")
const drawer = document.getElementById("categoryFiltersDrawer")

// SIDEBAR
if(sidebar){
sidebar.innerHTML = categories.map(cat=>`

<div class="cat-parent" onclick="toggleSub(this,'sub-side-${cat._id}')">
<span>${cat.name}</span>
<span class="cp-arr">▶</span>
</div>

<div class="sub-opts" id="sub-side-${cat._id}">

${cat.subCategories.map(sub=>`

<label class="foption">
<input type="checkbox"
data-f="category"
value="${sub._id}"
onchange="renderTags()">

${sub.name}

</label>

`).join("")}

</div>

`).join("")
}

// DRAWER
if(drawer){
drawer.innerHTML = categories.map(cat=>`

<div class="cat-parent" onclick="toggleSub(this,'sub-drawer-${cat._id}')">
<span>${cat.name}</span>
<span class="cp-arr">▶</span>
</div>

<div class="sub-opts" id="sub-drawer-${cat._id}">

${cat.subCategories.map(sub=>`

<label class="foption">
<input type="checkbox"
data-f="category"
value="${sub._id}"
onchange="renderTags()">

${sub.name}

</label>

`).join("")}

</div>

`).join("")
}

}

function renderAuthors(authors){

const sidebar = document.getElementById("authorFilters")
const drawer = document.getElementById("authorFiltersDrawer")

const html = authors.map(a=>`

<label class="foption">
<input type="checkbox"
data-f="author"
value="${a._id}"
onchange="renderTags()">
${a.name}
</label>

`).join("")

if(sidebar) sidebar.innerHTML = html
if(drawer) drawer.innerHTML = html

}

function renderLanguages(languages){

const sidebar = document.getElementById("languageFilters")
const drawer = document.getElementById("languageFiltersDrawer")

const html = languages.map(l=>`

<label class="foption">
<input type="checkbox"
data-f="language"
value="${l._id}"
onchange="renderTags()">
${l.languageName}
</label>

`).join("")

if(sidebar) sidebar.innerHTML = html
if(drawer) drawer.innerHTML = html

}

function renderPagination(data){

const div = document.getElementById("pagination")

let html = ""

// PREV button
html += `
<a class="pg-btn"
onclick="goPage(${data.currentPage-1})"
${data.currentPage == 1 ? 'style="pointer-events:none;opacity:.4"' : ''}>
‹ 
</a>
`

// PAGE numbers
for(let i=1;i<=data.totalPages;i++){

html += `
<a class="pg-btn ${data.currentPage==i?'active':''}"
onclick="goPage(${i})">
${i}
</a>
`

}

// NEXT button
html += `
<a class="pg-btn"
onclick="goPage(${data.currentPage+1})"
${data.currentPage == data.totalPages ? 'style="pointer-events:none;opacity:.4"' : ''}>
 ›
</a>
`

div.innerHTML = html

}

function updatePriceRange(data){

const slider = document.getElementById("priceSlider")
const label = document.getElementById("priceLabel")

if(!slider || !label) return

slider.min = 0
slider.max = 3000
slider.value = 3000
slider.dataset.max = 3000

label.dataset.min = 0
label.dataset.max = 3000
label.textContent = `₹0 – ₹3000`

sliderMax = 3000

onSlider(slider)

// mobile slider
const drawerSlider = document.getElementById("priceSliderDrawer")

if(drawerSlider){

drawerSlider.min = 0
drawerSlider.max = 3000
drawerSlider.value = 3000
drawerSlider.dataset.max = 3000

document.getElementById("priceLabelDrawer").textContent = `₹0 – ₹3000`

}

}

// ══ PRICE SLIDER drawer ══
function onSliderDrawer(el){

sliderMax = parseInt(el.value)

document.getElementById('priceLabelDrawer').textContent =
`₹0 – ₹${sliderMax.toLocaleString('en-IN')}`

const max = parseInt(el.dataset.max)

const pct = (sliderMax/max)*100

el.style.background =
`linear-gradient(to right,#6f2b67 0%,#6f2b67 ${pct}%,#e2d6ef ${pct}%,#e2d6ef 100%)`

}

(function initSlider(){

const slider = document.getElementById("priceSlider")

if(slider){

sliderMax = parseInt(slider.value)

onSlider(slider)

}

})();

// ══ CUSTOM SORT DROPDOWN ══
function toggleSortMenu(e){
  e.stopPropagation();
  document.getElementById('sortBtn').classList.toggle('open');
  document.getElementById('sortMenu').classList.toggle('open');
}
function selectSort(el, label){
  currentSort = el.dataset.val;
  document.getElementById('sortLabel').textContent = label;
  document.getElementById('sortBtn').classList.remove('open');
  document.getElementById('sortMenu').classList.remove('open');
  document.querySelectorAll('.sort-opt').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  applyFilters();
}
document.addEventListener('click', function(e){
  const wrap = document.getElementById('sortWrap');
  if(wrap && !wrap.contains(e.target)){
    document.getElementById('sortBtn')?.classList.remove('open');
    document.getElementById('sortMenu')?.classList.remove('open');
  }
});

// ══ FILTER DRAWER ══
function openFilterDrawer(){
  document.getElementById('filterDrawer').classList.add('open');
  document.getElementById('filterOverlay').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeFilterDrawer(){
  document.getElementById('filterDrawer').classList.remove('open');
  document.getElementById('filterOverlay').classList.remove('show');
  document.body.style.overflow = '';
}

// ══ SEARCH ══
function onSearchType(inp){
  document.getElementById('cancelBtn').classList.toggle('show', inp.value.length > 0);
}

function cancelSearch(){

  const params = new URLSearchParams(window.location.search)

  params.delete("search")
  params.set("page",1)

  window.location.href = "/shop?" + params.toString()

}


// search backend

function doSearch(){

const search = document.getElementById("searchInput").value.trim()

const params = new URLSearchParams(window.location.search)

if(search){
params.set("search",search)
}else{
params.delete("search")
}

params.set("page",1)

window.location.href = "/shop?" + params.toString()

}

document.getElementById("searchInput").addEventListener("keypress",function(e){

if(e.key === "Enter"){
doSearch()
}

})

// ══ TAGS ══
function renderTags(){
  
  const all = [...document.querySelectorAll('[data-f]:checked')].map(el=>{
    const label = el.closest('label');
    const name  = label ? label.textContent.trim() : el.value;
    return {val: el.value, name};
  });

  // deduplicate by value
  const seen = new Set();
  const unique = all.filter(o=>{ if(seen.has(o.val)) return false; seen.add(o.val); return true; });
  const html = unique.map(o=>`<span class="atag">${o.name}<button onclick="removeTag('${o.val}')">✕</button></span>`).join('');
  document.getElementById('activeTags').innerHTML = html;
  document.getElementById('activeTagsDrawer').innerHTML = html;
}
function removeTag(val){
  document.querySelectorAll(`[data-f][value="${val}"]`).forEach(el=>el.checked=false);
  renderTags();
  applyFilters();
  
}


// ══ CLEAR ALL ══

function clearAll(){
  document.querySelectorAll('[data-f]').forEach(e=>e.checked=false);
  document.getElementById('activeTags').innerHTML='';
  document.getElementById('activeTagsDrawer').innerHTML='';
  currentSort='';
  document.getElementById('sortLabel').textContent='Sort by';
  document.querySelectorAll('.sort-opt').forEach(o=>o.classList.remove('selected'));
  document.querySelector('.sort-opt[data-val=""]')?.classList.add('selected');
  cancelSearch();
  window.location.href = '/shop';
}


// ══ ACCORDION ══
function toggleFsec(el){ el.classList.toggle('open'); el.nextElementSibling.classList.toggle('open'); }
function toggleSub(el,id){ el.classList.toggle('open'); document.getElementById(id).classList.toggle('open'); }

// ══ CHIP ══
let chipFilter = "new";

function toggleChip(name){

  ['popular','ratings','new'].forEach(c=>{
    document.getElementById('chip-'+c)?.classList.remove('active')
  })

  document.getElementById('chip-'+name)?.classList.add('active')

  chipFilter = name

  applyFilters()

}
// ══ WISH / CART ══
function toggleWish(btn){ btn.classList.toggle('wishlisted'); btn.textContent=btn.classList.contains('wishlisted')?'❤️':'🤍'; }
function addToCart(id){
  cartCount++;
  document.getElementById('cartBadge').textContent=cartCount;
  const b=ALL_BOOKS.find(x=>x.id===id);
  Swal.fire({toast:true,position:'top-end',icon:'success',title:'Added to cart! 🛒',
    html:`<small style="color:#555">${b.title.substring(0,40)}…</small>`,
    showConfirmButton:false,timer:2200,timerProgressBar:true,background:'#fff'});
}
function viewBook(id){ window.location.href='/product/'+id; }

// ══ LOGOUT ══
function doLogout(e){
  e.preventDefault();
  Swal.fire({
    title:"<span style='color:#6f2b67;font-weight:700'>Logout?</span>",
    html:`<p style="font-size:14px;color:#555;margin-bottom:8px">Are you sure you want to logout? 💜</p><p style="font-size:13px;color:#888">You can login again anytime.</p>`,
    imageUrl:"/images/go-out-thro-removebg-preview.png",imageWidth:130,imageHeight:130,imageAlt:"Logout illustration",
    showCancelButton:true,confirmButtonText:"🚪 Logout",cancelButtonText:"Stay Here",
    confirmButtonColor:"#6f2b67",cancelButtonColor:"#d6c3d3",reverseButtons:true,
    background:"linear-gradient(135deg,#f6eef6,#efe3f0)",backdrop:"rgba(0,0,0,0.6)",
    showClass:{popup:'animate__animated animate__fadeInUp'},hideClass:{popup:'animate__animated animate__fadeOutDown'}
  }).then(r=>{ if(r.isConfirmed) window.location.href="/logout"; });
}
document.getElementById('logoutBtn')?.addEventListener('click', doLogout);
document.getElementById('footerLogout')?.addEventListener('click', doLogout);

// ══ HAMBURGER ══
const menuToggle = document.getElementById('menuToggle');
const mobileMenu = document.getElementById('mobileMenu');
menuToggle?.addEventListener('click', function(){
  mobileMenu.classList.toggle('open');
  const icon=this.querySelector('i');
  icon.classList.toggle('fa-bars'); icon.classList.toggle('fa-xmark');
});
document.querySelectorAll('.mobile-nav-link').forEach(link=>{
  link.addEventListener('click',()=>{
    mobileMenu.classList.remove('open');
    const icon=menuToggle?.querySelector('i');
    if(icon){icon.classList.add('fa-bars');icon.classList.remove('fa-xmark');}
  });
});
document.addEventListener('click',function(e){
  if(mobileMenu&&menuToggle&&!mobileMenu.contains(e.target)&&!menuToggle.contains(e.target)){
    mobileMenu.classList.remove('open');
    const icon=menuToggle.querySelector('i');
    if(icon){icon.classList.add('fa-bars');icon.classList.remove('fa-xmark');}
  }
});

// ══ SCROLL OBSERVER ══
const observer=new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){entry.target.style.opacity='1';entry.target.style.transform='translateY(0)';}
  });
},{threshold:0.1,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.product-card,.promo,.feature-item').forEach(el=>observer.observe(el));


function applyFilters(){

  const categories =
  [...document.querySelectorAll('[data-f="category"]:checked')]
  .map(el=>el.value)

  const authors =
  [...document.querySelectorAll('[data-f="author"]:checked')]
  .map(el=>el.value)

  const languages =
  [...document.querySelectorAll('[data-f="language"]:checked')]
  .map(el=>el.value)

  const formats =
  [...document.querySelectorAll('[data-f="format"]:checked')]
  .map(el=>el.value)

  const params = new URLSearchParams()

  if(categories.length)
  params.append("category", categories.join(","))

  if(authors.length)
  params.append("author", authors.join(","))

  if(languages.length)
  params.append("language", languages.join(","))

  if(formats.length)
  params.append("format", formats.join(","))

 const max = parseInt(document.getElementById("priceSlider").dataset.max)

if(sliderMax && sliderMax < max){
params.append("price", sliderMax)
}


  if(currentSort)
  params.append("sort", currentSort)

  if(chipFilter && chipFilter !== "new")
  params.append("chip", chipFilter)

  params.append("page",1)

 window.history.pushState({},'',"/shop?"+params.toString())
 loadProducts()
}

function renderStars(rating){
  let stars = '';
  for(let i=1; i<=5; i++){
    if(i <= rating){
      stars += `<i class="fa-solid fa-star"></i>`;
    }else{
      stars += `<i class="fa-regular fa-star"></i>`;
    }
  }
  return stars;
}

function renderEmptyStars(){
  let stars = '';
  for(let i=1; i<=5; i++){
    stars += `<i class="fa-regular fa-star"></i>`;
  }
  return stars;
}

</script>
