async function viewCustomer(userId){
  console.log('Clicked ID:', userId)
  try{
    const res=await fetch(`/admin/customers/${userId}`)
    const data=await res.json()

    console.log(data)    
    if(!data.success){
      alert("User not found")
      return
    }

    const user = data.user
 document.getElementById('customerModal').classList.add('show')

    document.getElementById('modalCustomerName').innerText = user.name || 'User'
    document.getElementById('userFullName').innerText = user.name || '-'
    document.getElementById('userEmail').innerText = user.email || '-'
    document.getElementById('userPhone').innerText = user.phone || '-'
    document.getElementById('userJoined').innerText =
    new Date(user.createdAt).toDateString()
    const infoRows = document.querySelectorAll('#infoTab .info-card:first-child .info-row')

    infoRows[0].querySelector('.info-value').innerText = user.name || '-'  
    infoRows[1].querySelector('.info-value').innerText = user.email || '-'
    infoRows[2].querySelector('.info-value').innerText = user.phone || '-'  
    infoRows[3].querySelector('.info-value').innerText = new Date(user.createdAt).toDateString()  
    infoRows[4].querySelector('.info-value').innerText = user.isBlocked ? 'Blocked' : 'Active' 
    infoRows[4].querySelector('.info-value').style.color = user.isBlocked ? '#dc3545' : '#28a745' 

    if(!data.hasAddress){
    document.getElementById('addressBox').innerHTML = `
      <p style="color:#8e4a86;font-weight:600;">
        Address not added yet
      </p>
    `
  }else{
    const addr = data.address
    document.getElementById('addressBox').innerHTML = `
      <div class="info-row">
        <span class="info-label">City:</span>
        <span class="info-value">${addr.city}</span>
      </div>
      <div class="info-row">
        <span class="info-label">State:</span>
        <span class="info-value">${addr.state}</span>
      </div>
      <div class="info-row">
        <span class="info-label">Pincode:</span>
        <span class="info-value">${addr.pincode}</span>
      </div>
      <div class="info-row">
        <span class="info-label">Country:</span>
        <span class="info-value">${addr.country}</span>
      </div>
    `
  }

    

    

  }catch(err){
    console.log(err)
  }
}

///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
function closeModal() {
  document.getElementById('customerModal').classList.remove('show');
}

function switchTab(tabName, el) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'))
  document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'))

  el.classList.add('active')
  document.getElementById(tabName + 'Tab').classList.add('active')
}


