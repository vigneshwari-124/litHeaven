document.getElementById('adminLogoutBtn').addEventListener('click', () => {
  Swal.fire({
    title: "Are you sure?",
    text: "You will be logged out from admin panel",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#6f2b67",
    cancelButtonColor: "#aaa",
    confirmButtonText: "Yes, Logout"
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const res = await fetch('/admin/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        })

        const data = await res.json()

        if (!res.ok) {
          Swal.fire("Error", data.message, "error")
          return
        }

        Swal.fire({
          icon: "success",
          title: "Logged out",
          timer: 1200,
          showConfirmButton: false
        }).then(() => {
          window.location.replace('/admin/login')
        })

      } catch (err) {
        console.log(err)
        Swal.fire("Error", "Something went wrong", "error")
      }
    }
  })
})


////////////////////////////////////////////////////////////////////////////////////////////

async function toggleBlock(userId, el) {
  try {
    const res = await fetch(`/admin/users/${userId}/block`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json'
      }
    })

    if (!res.ok) {
      if (res.status === 401 || res.status === 403) {
        Swal.fire({
          icon: 'error',
          title: 'Session Expired',
          text: 'Please login again',
          confirmButtonColor: '#6f2b67'
        }).then(() => {
          window.location.replace('/admin/login')
        })
        return
      }

      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'Action failed',
        confirmButtonColor: '#6f2b67'
      })
      return
    }



    const data = await res.json()

    const badge = el.closest('tr').querySelector('.status-badge')

    if (data.isBlocked) {
      badge.textContent = 'UNBLOCK'
      badge.className = 'status-badge status-block'
      el.classList.remove('active')
    } else {
      badge.textContent = 'BLOCK'
      badge.className = 'status-badge status-active'
      el.classList.add('active')
    }

  } catch (err) {
    console.log(err)
    Swal.fire({
      icon: 'error',
      title: 'Something went wrong',
      text: 'Please try again',
      confirmButtonColor: '#6f2b67'
    })
  }
}

