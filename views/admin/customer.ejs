  <script>

const searchInput = document.getElementById('searchInput')
const tbody = document.querySelector('.customers-table tbody')
const pagination = document.getElementById('pagination')
const statusFilter = document.getElementById('statusFilter')
const limitSelect = document.getElementById('limitSelect')

let timer
let currentPage=1
let LIMIT=7

async function loadUsers(page=1) {
    currentPage = page
  const query=searchInput.value.trim()
  const status = statusFilter.value

  try {
      const res = await fetch(`/admin/customer/search?query=${query}&status=${status}&page=${page}&limit=${LIMIT}`)
      const data = await res.json()

      tbody.innerHTML = ''

      if (!data.users || data.users.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="8" style="text-align:center;">
               'No users found'
            </td>
          </tr>
        `
        pagination.innerHTML = '' 
        return
      }

      data.users.forEach((user, index) => {
        tbody.innerHTML += `
          <tr>
            <td>${(page-1)* LIMIT +index + 1}</td>
            <td><strong>${user.name || 'User'}</strong></td>
            <td>${user.email}</td>
            <td>${user.phone || '-'}</td>
            <td>${new Date(user.createdAt).toDateString()}</td>
            <td>
              <span class="status-badge ${
                user.isBlocked ? 'status-block' : 'status-active'
              }">
                ${user.isBlocked ? 'UNBLOCK' : 'BLOCK'}
              </span>
            </td>
            <td>
              <div class="toggle-switch ${
                user.isBlocked ? '' : 'active'
              }" onclick="toggleBlock('${user._id}', this)">
                <div class="toggle-slider"></div>
              </div>
            </td>
            <td>
              <button class="icon-btn" onclick="viewCustomer('${user._id}')">
                <i class="fas fa-eye"></i>
              </button>
            </td>
          </tr>
        `
      })

     
    renderPagination(data.totalPages, page)
    

    } catch (err) {
      console.log(err)
  }
}

//////////////////////

searchInput.addEventListener('input',()=>{
  clearTimeout(timer)
  timer=setTimeout(()=>{
    loadUsers(1)
  },400)
})

//////////////////////

statusFilter.addEventListener('change', () => 
loadUsers(1))

/////////////////////


limitSelect.addEventListener('change', () => {
  LIMIT = Number(limitSelect.value.match(/\d+/)[0])
  loadUsers(1)
})

/////////////////////

function renderPagination(totalPages,page){

  pagination.innerHTML=''

  const MAX_VISIBLE=5
  let start = Math.max(1, page - Math.floor(MAX_VISIBLE / 2))
  let end = start + MAX_VISIBLE - 1

  
  if (end > totalPages) {
    end = totalPages
    start = Math.max(1, end - MAX_VISIBLE + 1)
  }

  
pagination.innerHTML += `
<button class="page-btn"  ${page === 1 ? 'disabled' : ''} 
onclick="loadUsers(${page - 1})">‹</button>
`
  
  for(let i=start; i<=end; i++){
    pagination.innerHTML+=`
      <button class="page-btn ${i === page ? 'active' : ''}"
      onclick="loadUsers(${i})">${i}</button>
    `
  }

 
    pagination.innerHTML+=`
      <button class="page-btn"  ${page === totalPages ? 'disabled' : ''} 
      onclick="loadUsers(${page + 1})">›</button>
    `
  
}


////////////////////////////////////////////////////////////

document.addEventListener('DOMContentLoaded',()=>{
  loadUsers(1)
})



