<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Language - LitHeaven</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f5f3ff;color:#6f2b67;font-family:'Segoe UI',sans-serif;overflow-x:hidden;}
    .swal2-container { z-index: 99999 !important;}
    .sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;transition:0.3s;}
    .sidebar::-webkit-scrollbar{width:5px;}
    .sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}
    
    .table-message {
  color: #6f2b67 !important;
  text-align: center;
  font-weight: 600;
}
    .logo-circle{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#6f2b67,#5a2252);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 8px 25px rgba(111,43,103,0.5);padding:15px;}
    .book-logo{font-size:35px;color:#fff;margin-bottom:8px;}
    .logo-text{font-size:14px;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:1.5px;}
    .tagline{font-size:9px;font-weight:600;color:#6f2b67;text-align:center;margin-top:8px;}
    
    .menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:0.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer;}
    .menu-item:hover,.menu-item.active{background:rgba(111,43,103,0.1);border-left-color:#6f2b67;color:#8a3a7f;}
    .menu-item i{width:20px;font-size:16px;}
    .menu-left{display:flex;align-items:center;gap:12px;}
    
    .submenu{max-height:0;overflow:hidden;transition:0.3s;}
    .submenu.show{max-height:200px;}
    .submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:0.3s;}
    .submenu a:hover{background:rgba(111,43,103,0.05);color:#8a3a7f;}
    
    .logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px);}
    .logout-btn:hover{background:#8a3a7f;}
    
    .main-content{margin-left:250px;padding:20px;transition:0.3s;width:calc(100% - 250px);}
    .top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;}
    
    .user-info{display:flex;align-items:center;gap:12px;cursor:pointer;}
    .user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px;}
    
    .page-title{font-size:28px;font-weight:700;color:#6f2b67;margin-bottom:0;}
    
    .add-btn{background:#6f2b67;color:#fff;border:none;padding:12px 30px;border-radius:8px;font-weight:600;cursor:pointer;box-shadow:0 4px 15px rgba(111,43,103,0.4);display:flex;align-items:center;gap:8px;font-size:14px;}
    .add-btn:hover{background:#8a3a7f;}
    
    .filter-bar{display:flex;gap:10px;margin-bottom:15px;align-items:center;font-size:13px;flex-wrap:wrap;justify-content:space-between;}
    .filter-bar select{background:rgba(111,43,103,0.1);border:1px solid #6f2b67;color:#6f2b67;padding:8px 15px;border-radius:8px;outline:none;cursor:pointer;font-size:13px;}
    
    .table-container{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:20px;overflow-x:auto;}
    .table-wrapper{height:480px;overflow-y:auto;overflow-x:auto;}
    table{width:100%;border-collapse:collapse;}
    th{background:rgba(111,43,103,0.1);padding:12px;text-align:left;font-size:12px;font-weight:700;color:#8a3a7f;border-bottom:2px solid #6f2b67;}
    td{padding:12px;font-size:13px;border-bottom:1px solid rgba(111,43,103,0.2);color:rgba(111,43,103,0.8);vertical-align:middle;}
    tr:hover{background:rgba(111,43,103,0.05);}
    
    .status-btn{border:none;padding:8px 16px;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;transition:0.3s;text-transform:uppercase;min-width:100px;text-align:center;}
    .status-btn.inactive{background:rgba(220,53,69,0.2);color:#dc3545;}
    .status-btn.active{background:rgba(40,167,69,0.2);color:#28a745;}
    
    .action-btn{background:transparent;border:none;cursor:pointer;font-size:18px;transition:0.3s;padding:5px;margin:0 5px;}
    .edit-btn{color:#6f2b67;}
    .edit-btn:hover{color:#5a2252;transform:scale(1.15);}
    .delete-btn{color:#dc3545;}
    .delete-btn:hover{color:#c82333;transform:scale(1.15);}

    .pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;flex-wrap:wrap;}
    .page-btn{width:32px;height:32px;border:1px solid #6f2b67;background:transparent;color:#6f2b67;border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.3s;}
    .page-btn.active{background:#6f2b67;color:#fff;}
    .page-btn:hover:not(.active){background:rgba(111,43,103,0.1);}

    .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(111,43,103,0.15);backdrop-filter:blur(5px);z-index:2000;align-items:center;justify-content:center;padding:20px;overflow-y:auto;}
    .modal.show{display:flex;}
    .modal-content{background:#fff;border:2px solid #6f2b67;border-radius:15px;padding:0;max-width:500px;width:100%;max-height:90vh;overflow:hidden;position:relative;margin:auto;box-shadow:0 10px 40px rgba(111,43,103,0.3);}
    
    .action-wrapper { display: flex; gap: 10px; align-items: center; justify-content: center;}

    .modal-header{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;padding:20px 25px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:2000;}
    .modal-header h2{font-size:20px;font-weight:700;display:flex;align-items:center;gap:10px;margin:0;}
    .close-modal{background:rgba(255,255,255,0.2);border:none;width:35px;height:35px;border-radius:50%;color:#fff;cursor:pointer;font-size:20px;transition:0.3s;}
    .close-modal:hover{background:rgba(255,255,255,0.3);transform:rotate(90deg);}
    
    .modal-body{padding:25px;overflow-y:auto;max-height:calc(90vh - 80px);}
    .modal-body::-webkit-scrollbar{width:8px;}
    .modal-body::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:10px;}
    
    td .action-btn { display: inline-flex; align-items: center;}
    .form-group{margin-bottom:20px;}
    .form-label{display:block;font-size:13px;font-weight:600;color:#6f2b67;margin-bottom:8px;}
    .form-input{width:100%;padding:10px 15px;border:1px solid #6f2b67;border-radius:8px;background:rgba(111,43,103,0.05);color:#333;font-size:14px;outline:none;transition:0.3s;}
    .form-input:focus{border-color:#8e4a86;background:#fff;box-shadow:0 0 0 3px rgba(111,43,103,0.1);}
    
    .modal-footer{display:flex;gap:10px;justify-content:flex-end;padding-top:20px;border-top:1px solid rgba(111,43,103,0.2);}
    .btn{padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:0.3s;border:none;}
    .btn-cancel{background:rgba(111,43,103,0.1);color:#6f2b67;}
    .btn-cancel:hover{background:rgba(111,43,103,0.2);}
    .btn-save{background:#6f2b67;color:#fff;}
    .btn-save:hover{background:#5a2252;}
    
    .mobile-toggle{display:none;position:fixed;top:20px;left:20px;z-index:1100;width:40px;height:40px;background:#6f2b67;border:none;border-radius:8px;color:#fff;font-size:20px;}
    
    @media(max-width:768px){
      .mobile-toggle{display:flex;align-items:center;justify-content:center;}
      .sidebar{transform:translateX(-100%);}
      .sidebar.active{transform:translateX(0);}
      .main-content{margin-left:0;width:100%;padding:15px;}
      .top-bar{flex-direction:column;gap:10px;align-items:flex-start;}
      .filter-bar{flex-direction:column;align-items:stretch;}
      .table-container{padding:10px;}
      th,td{padding:8px;font-size:11px;}
      .modal-content{width:95%;}
    }
  </style>
</head>
<body>

  <button class="mobile-toggle" onclick="document.getElementById('sidebar').classList.toggle('active')">
    <i class="fas fa-bars"></i>
  </button>

<div class="sidebar" id="sidebar">
    <div style="text-align:center;padding:10px 0;">
      <div class="logo-circle">
        <i class="fas fa-book-open book-logo"></i>
        <div class="logo-text">LitHeaven</div>
      </div>
      <div class="tagline">Admin Portal</div>
    </div>
    
    <a href="/admin/dashboard" class="menu-item active">
      <div class="menu-left"><i class="fas fa-chart-line"></i> Dashboard</div>
    </a>
    <a href="/admin/order" class="menu-item">
      <div class="menu-left"><i class="fas fa-shopping-cart"></i> Orders</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('catMenu')">
      <div class="menu-left"><i class="fas fa-layer-group"></i> Categories</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="catMenu">
      <a href="/admin/category">Category</a>
      <a href="/admin/sub-category">Sub-Category</a>
    </div>
    
    <a href="/admin/product" class="menu-item">
      <div class="menu-left"><i class="fas fa-box"></i> Products</div>
    </a>
    <a href="/admin/coupon" class="menu-item">
      <div class="menu-left"><i class="fas fa-ticket-alt"></i> Coupons</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('offerMenu')">
      <div class="menu-left"><i class="fas fa-tags"></i> Offers</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="offerMenu">
      <a href="/admin/categoryOff">Category Offers</a>
    <a href="/admin/subCategoryOff">Sub-Category Offers</a>
    <a href="/admin/productOff">Product Offers</a>
    </div>
    
    <a href="/admin/author" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-tie"></i> Author</div>
    </a>
    <a href="/admin/admin" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-shield"></i> Admin</div>
    </a>
    <a href="/admin/customer" class="menu-item">
      <div class="menu-left"><i class="fas fa-users"></i> Customers</div>
    </a>
    <!-- <a href="/admin/rating" class="menu-item">
      <div class="menu-left"><i class="fas fa-star"></i> Ratings</div>
    </a> -->
    <a href="/admin/salesReport" class="menu-item">
      <div class="menu-left"><i class="fas fa-file-alt"></i> Sales Report</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('settMenu')">
      <div class="menu-left"><i class="fas fa-cog"></i> Settings</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="settMenu">
      <a href="/admin/appSetting">App Settings</a>
      <a href="/admin/language">Language</a>
    </div>
    
    <button  id="adminLogoutBtn"  class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <h1 class="page-title">Language</h1>
      <div class="user-info">
        <div>
          <div style="font-weight:600;font-size:14px;">App Admin</div>
          <div style="font-size:11px;opacity:0.7;">support@litheaven.com</div>
        </div>
        <div class="user-avatar"><i class="fas fa-user"></i></div>
      </div>
    </div>
    
    <div class="filter-bar">
      <select id="statusFilter">
        <option value="all">All Status</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
      </select>
      <button class="add-btn" onclick="openModal()">
        <i class="fas fa-plus"></i> ADD LANGUAGE
      </button>
    </div>
    
    <div class="table-container">
      <div style="font-size:18px;font-weight:700;color:#6f2b67;margin-bottom:20px;">Language List</div>
      
      <div class="table-wrapper">
        <table id="languageTable">
          <thead>
            <tr>
              <th style="width:10%;">S.NO</th>
              <th style="width:20%;">LANGUAGE CODE</th>
              <th style="width:25%;">LANGUAGE</th>
              <th style="width:20%;">STATUS</th>
              <th style="width:20%; text-align:center;">ACTION</th>
            </tr>
          </thead>
          <tbody id="languageBody"></tbody>
        </table>
      </div>
      
      <div class="pagination" id="pagination"></div>
    </div>
  </div>

  <!-- Add/Edit Language Modal -->
  <div class="modal" id="languageModal">
    <div class="modal-content">
      <div class="modal-header">
        <h2><i class="fas fa-language"></i> <span id="modalTitle">Add Language</span></h2>
        <button class="close-modal" onclick="closeModal()">×</button>
      </div>
      
      <div class="modal-body">
        <form id="languageForm">
          <input type="hidden" id="editIndex">
          
          <div class="form-group">
            <label class="form-label">Language Code *</label>
            <input type="text" class="form-input" id="langCode" placeholder="e.g., en, ta, hi" maxlength="5">
            <small id="langCodeError" style="color:#6f2b67;font-size:12px;"></small>
          </div>
          
          <div class="form-group">
            <label class="form-label">Language *</label>
            <input type="text" class="form-input" id="langName" placeholder="e.g., English, Tamil">
            <small id="langNameError" style="color:#6f2b67;font-size:12px;"></small>
          </div>
          
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input" id="langStatus">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
          
          <div class="modal-footer">
            <button type="button" class="btn btn-cancel" onclick="closeModal()">Cancel</button>
            <button type="submit" class="btn btn-save">Save Changes</button>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>

let editingLanguageId = null;

const Toast = Swal.mixin({
  toast: true,
  position: 'top-end',
  showConfirmButton: false,
  timer: 1000,
  timerProgressBar: true,
  didOpen: (toast) => {
      toast.style.zIndex = 9999; 
    toast.addEventListener('mouseenter', Swal.stopTimer);
    toast.addEventListener('mouseleave', Swal.resumeTimer);
  }
});

let currentPage = 1;
let totalPages = 1;

let currentStatus = 'all'
let editingRow = null;

function toggleMenu(id) {
  document.getElementById(id).classList.toggle('show');
}

function openModal() {
  editingLanguageId = null;

  document.getElementById('languageModal').classList.add('show');
  document.getElementById('modalTitle').textContent = 'Add Language';
  document.getElementById('languageForm').reset();

  document.getElementById("langCodeError").textContent = "";
  document.getElementById("langNameError").textContent = "";
}



function closeModal() {
  document.getElementById('languageModal').classList.remove('show');
  document.getElementById('languageForm').reset();
  editingRow = null;
}

document.addEventListener("click", function (e) {
  const btn = e.target.closest(".edit-btn");
  if (!btn) return;

  editingLanguageId = btn.dataset.id;

  document.getElementById("modalTitle").textContent = "Edit Language";
  document.getElementById("langCode").value = btn.dataset.code;
  document.getElementById("langName").value = btn.dataset.name;
  document.getElementById("langStatus").value = btn.dataset.status;

  document.getElementById("langCodeError").textContent = "";
  document.getElementById("langNameError").textContent = "";

  document.getElementById("languageModal").classList.add("show");
});


// Close modal when clicking outside
window.onclick = function(event) {
  const modal = document.getElementById('languageModal');
  if (event.target === modal) {
    closeModal();
  }
}


//////////////////////////////////////////////////////////////////////////////////

// Function to fetch languages from backend
async function fetchLanguages(page = 1) {
  currentPage = page;

  const tbody = document.getElementById('languageBody');
  const pagination = document.getElementById('pagination');

  tbody.innerHTML = '';
  pagination.innerHTML = '';

  try {
    const res = await fetch(
      `/admin/languages?page=${page}&status=${currentStatus}`,
      { credentials: 'include' }
    );

    const result = await res.json();

   
    if (!result.data || result.data.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="5" style="text-align:center;color:#6f2b67;font-weight:600;">
            Language not yet added
          </td>
        </tr>
      `;
      return;
    }

    result.data.forEach((lang, index) => {
      tbody.innerHTML += `
        <tr>
          <td>${(page - 1) * 5 + index + 1}</td>
          <td>${lang.languageCode}</td>
          <td>${lang.languageName}</td>
          <td>
            <button class="status-btn ${lang.status}">
              ${lang.status.toUpperCase()}
            </button>
          </td>
         <td>

  <div class="action-wrapper">
    <button class="action-btn edit-btn"
      data-id="${lang._id}"
      data-code="${lang.languageCode}"
      data-name="${lang.languageName}"
      data-status="${lang.status}">
      <i class="fas fa-edit"></i>
    </button>

    <button class="action-btn delete-btn"
      data-id="${lang._id}">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</td>

        </tr>
      `;
    });

    
    renderPagination(result.totalPages, page);

  } catch (err) {
    tbody.innerHTML = `
      <tr>
        <td colspan="5" style="text-align:center;color:#6f2b67;">
          Failed to load languages
        </td>
      </tr>
    `;
  }
}

function renderPagination(totalPages, page) {
  const pagination = document.getElementById('pagination');
  pagination.innerHTML = '';

  
  pagination.innerHTML += `
    <button class="page-btn"
      ${page === 1 ? 'disabled' : ''}
      onclick="fetchLanguages(${page - 1})">
      ‹
    </button>
  `;

 
  for (let i = 1; i <= totalPages; i++) {
    pagination.innerHTML += `
      <button class="page-btn ${i === page ? 'active' : ''}"
        onclick="fetchLanguages(${i})">
        ${i}
      </button>
    `;
  }

 
  pagination.innerHTML += `
    <button class="page-btn"
      ${page === totalPages ? 'disabled' : ''}
      onclick="fetchLanguages(${page + 1})">
      ›
    </button>
  `;
}


document.getElementById('statusFilter').addEventListener('change', function () {
  currentStatus = this.value;
  fetchLanguages(1); 
});


function changePage(page) {
  currentPage = page;
  fetchLanguages(page);
}

// Page load
fetchLanguages();
//////////////////////////////////////////////////////////////////////////////
document.getElementById("langCode").addEventListener("input", () => {
  document.getElementById("langCodeError").textContent = "";
});

document.getElementById("langName").addEventListener("input", () => {
  document.getElementById("langNameError").textContent = "";
});

document.getElementById("languageForm").addEventListener("submit", async function (e) {
  e.preventDefault();

  const languageCode = document.getElementById("langCode").value.trim();
  const languageName = document.getElementById("langName").value.trim();
  const status = document.getElementById("langStatus").value;

  const codeError = document.getElementById("langCodeError");
  const nameError = document.getElementById("langNameError");

  codeError.textContent = "";
  nameError.textContent = "";

  let isValid = true;

  if (!languageCode) {
    codeError.textContent = "Language code is required";
    isValid = false;
  }

  if (!languageName) {
    nameError.textContent = "Language name is required";
    isValid = false;
  }

  if (!isValid) return;

  try {
    const url = editingLanguageId
      ? `/admin/languages/${editingLanguageId}`   
      : `/admin/languages`;                      

    const method = editingLanguageId ? "PUT" : "POST";

    const res = await fetch(url, {
      method,
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ languageCode, languageName, status }),
    });

    const result = await res.json();

    if (!res.ok) {
      Toast.fire({
        icon: "error",
        title: result.message || "Operation failed",
      });
      return;
    }

    Toast.fire({
      icon: "success",
      title: editingLanguageId
        ? "Language updated successfully"
        : "Language added successfully",
    }).then(() => {
      closeModal();
      fetchLanguages(currentPage);
    });

  } catch (err) {
    Toast.fire({
      icon: "error",
      title: "Something went wrong",
    });
  }
});


document.addEventListener("click", function (e) {
  const deleteBtn = e.target.closest(".delete-btn");
  if (!deleteBtn) return;

  const languageId = deleteBtn.dataset.id;

  Swal.fire({
    title: 'Are you sure?',
    text: 'This language will be permanently deleted',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#6f2b67',
    cancelButtonColor: '#aaa',
    confirmButtonText: 'Yes, delete',
    cancelButtonText: 'No'
  }).then(async (result) => {

    if (!result.isConfirmed) return;

    try {
      const res = await fetch(`/admin/languages/${languageId}`, {
        method: 'DELETE',
        credentials: 'include'
      });

      const data = await res.json();

      if (!res.ok) {
        Swal.fire('Error', data.message || 'Delete failed', 'error');
        return;
      }

      Swal.fire({
        icon: 'success',
        title: 'Deleted!',
        text: 'Language deleted successfully',
        timer: 1200,
        showConfirmButton: false
      });

      fetchLanguages(currentPage); 
    } catch (err) {
      Swal.fire('Error', 'Something went wrong', 'error');
    }
  });
});


document.getElementById('adminLogoutBtn').addEventListener('click', () => {
  Swal.fire({
    title: "Are you sure?",
    text: "You will be logged out from admin panel",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#6f2b67",
    cancelButtonColor: "#aaa",
    confirmButtonText: "Yes, Logout"
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const res = await fetch('/admin/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        })

        const data = await res.json()

        if (!res.ok) {
          Swal.fire("Error", data.message, "error")
          return
        }

        Swal.fire({
          icon: "success",
          title: "Logged out",
          timer: 1200,
          showConfirmButton: false
        }).then(() => {
          window.location.replace('/admin/login')
        })

      } catch (err) {
        console.log(err)
        Swal.fire("Error", "Something went wrong", "error")
      }
    }
  })
})



  </script>
</body>
</html>