<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f5f3ff;color:#333;font-family:'Segoe UI',sans-serif;overflow-x:hidden;max-width:100vw;}
    
    .sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;transition:0.3s;}
    .sidebar::-webkit-scrollbar{width:5px;}
    .sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}
    .dashboard-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
  margin-top:30px;
}

.dashboard-card{
  background:#fff;
  border:1px solid #6f2b67;
  border-radius:14px;
  padding:20px;
}

.dashboard-heading{
  font-size:20px;
  font-weight:700;
  color:#5a2252;
  margin-bottom:20px;
}

.top-product-card{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px;
  border:1px solid rgba(111,43,103,0.1);
  border-radius:16px;
  margin-bottom:14px;
  background:#fff;
  transition:0.3s;
}

.top-product-card:hover{
  transform:translateY(-3px);
  box-shadow:0 8px 25px rgba(111,43,103,0.12);
}

.top-product-left{
  display:flex;
  align-items:center;
  gap:14px;
}

.top-product-image{
  width:75px;
  height:75px;
  object-fit:cover;
  border-radius:14px;
  border:1px solid #eee;
}

.top-product-name{
  font-size:18px;
  font-weight:700;
  color:#5a2252;
  margin-bottom:5px;
  text-transform:capitalize;
}

.top-product-price{
  font-size:14px;
  color:#444;
  margin-bottom:3px;
}

.top-product-variant{
  font-size:13px;
  color:#888;
}

.top-product-right{
  background:rgba(111,43,103,0.1);
  color:#6f2b67;
  padding:10px 16px;
  border-radius:12px;
  font-size:15px;
  font-weight:700;
}

.subcategory-item{
  display:flex;
  justify-content:space-between;
  padding:14px 0;
  border-bottom:1px solid rgba(111,43,103,0.1);
}

.subcategory-name{
  font-size:14px;
  font-weight:600;
  color:#5a2252;
}

.subcategory-count{
  font-size:14px;
  font-weight:700;
  color:#6f2b67;
}

.subcategory-card{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px;
  border:1px solid rgba(111,43,103,0.1);
  border-radius:16px;
  margin-bottom:14px;
  background:#fff;
  transition:0.3s;
}

.subcategory-card:hover{
  transform:translateY(-3px);
  box-shadow:0 8px 25px rgba(111,43,103,0.12);
}

.subcategory-left{
  display:flex;
  align-items:center;
  gap:14px;
}

.subcategory-image{
  width:65px;
  height:65px;
  object-fit:cover;
  border-radius:14px;
  border:1px solid #eee;
}

.subcategory-title{
  font-size:16px;
  font-weight:700;
  color:#5a2252;
  margin-bottom:4px;
  text-transform:capitalize;
}

.subcategory-small{
  font-size:12px;
  color:#888;
}

.subcategory-right{
  background:rgba(111,43,103,0.1);
  color:#6f2b67;
  padding:10px 14px;
  border-radius:12px;
  font-size:14px;
  font-weight:700;
}

    .logo-circle{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#6f2b67,#5a2252);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 8px 25px rgba(111,43,103,0.5);padding:15px;}
    .book-logo{font-size:35px;color:#fff;margin-bottom:8px;}
    .logo-text{font-size:14px;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:1.5px;}
    .tagline{font-size:9px;font-weight:600;color:#6f2b67;text-align:center;margin-top:8px;}

    .menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:0.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer;}
    .menu-item:hover,.menu-item.active{background:rgba(111,43,103,0.1);border-left-color:#6f2b67;color:#5a2252;}
    .menu-item i{width:20px;font-size:16px;}
    .menu-left{display:flex;align-items:center;gap:12px;}
    
    .submenu{max-height:0;overflow:hidden;transition:0.3s;}
    .submenu.show{max-height:200px;}
    .submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:0.3s;}
    .submenu a:hover{background:rgba(111,43,103,0.05);color:#5a2252;}
    
    .logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px);}
    .logout-btn:hover{background:#5a2252;}
    
    .main-content{margin-left:250px;padding:20px;transition:0.3s;width:calc(100% - 250px);overflow-x:hidden;}
    
    .top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:15px;}
    .search-box{flex:1;max-width:500px;background:rgba(111,43,103,0.1);border:1px solid #6f2b67;border-radius:25px;padding:8px 20px;display:flex;gap:10px;}
    .search-box input{flex:1;background:transparent;border:none;outline:none;color:#6f2b67;font-size:14px;}
    .search-box input::placeholder{color:rgba(111,43,103,0.5);}
    
    .user-info{display:flex;align-items:center;gap:12px;cursor:pointer;}
    .user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px;}
    
    .page-title{font-size:28px;font-weight:700;margin-bottom:25px;}
    
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:30px;}
    .stat-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px;transition:0.3s;}
    .stat-card:hover{transform:translateY(-5px);box-shadow:0 10px 30px rgba(111,43,103,0.3);}
    .stat-icon{width:40px;height:40px;border-radius:10px;background:rgba(111,43,103,0.2);display:flex;align-items:center;justify-content:center;font-size:20px;color:#5a2252;margin-bottom:10px;}
    .stat-label{font-size:12px;color:rgba(111,43,103,0.7);margin-bottom:5px;}
    .stat-value{font-size:24px;font-weight:800;color:#5a2252;}
    .stat-subtitle{font-size:10px;color:rgba(111,43,103,0.6);margin-top:5px;}
    
    .charts-row{display:grid;grid-template-columns: 3fr 1fr;gap:20px;margin-bottom:30px;}
    .chart-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:25px;}
    .chart-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;}
    .chart-title{font-size:18px;font-weight:700;}
    .chart-filter{background:rgba(111,43,103,0.1);border:1px solid #6f2b67;border-radius:6px;padding:5px 15px;color:#6f2b67;font-size:12px;cursor:pointer;position:relative;}
    .dropdown-menu{display:none;position:absolute;top:100%;right:0;background:#fff;border:1px solid #6f2b67;border-radius:6px;margin-top:5px;z-index:100;min-width:150px;}
    .dropdown-menu.show{display:block;}
    .dropdown-item{padding:8px 15px;color:#6f2b67;font-size:12px;cursor:pointer;transition:0.2s;}
    .dropdown-item:hover{background:rgba(111,43,103,0.1);color:#5a2252;}
    .chart-placeholder{height:300px;background:rgba(111,43,103,0.05);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(111,43,103,0.3);font-size:14px;}
    
    .donut-chart{width:200px;height:200px;margin:20px auto;}
    .legend-item{display:flex;justify-content:space-between;padding:8px 0;font-size:13px;}
    .legend-dot{width:12px;height:12px;border-radius:50%;margin-right:8px;}
    
    .table-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:25px;}
    .table-wrapper{overflow-x:auto;max-height:400px;overflow-y:auto;margin:15px 0;}
    .table-wrapper::-webkit-scrollbar{height:8px;width:8px;}
    .table-wrapper::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:4px;}
    .orders-table{width:100%;border-collapse:collapse;min-width:700px;}
    .orders-table th{background:rgba(111,43,103,0.1);padding:12px;text-align:left;font-size:12px;font-weight:700;color:#5a2252;border-bottom:2px solid #6f2b67;white-space:nowrap;}
    .orders-table td{padding:12px;font-size:13px;border-bottom:1px solid rgba(111,43,103,0.2);color:rgba(111,43,103,0.8);}
    .orders-table tr:hover{background:rgba(111,43,103,0.05);}
    
    .status-badge{padding:6px 0;border-radius:12px;font-size:11px;font-weight:600;display:inline-block;width:90px;text-align:center;}
    .status-pending{background:rgba(255,193,7,0.2);color:#ffc107;}
    .status-shipped{background:rgba(0,123,255,0.2);color:#007bff;}
    .status-processing{background:rgba(108,117,125,0.2);color:#6c757d;}
    .status-cancel{background:rgba(220,53,69,0.2);color:#dc3545;}
    
    .pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;flex-wrap:wrap;}
    .page-btn{width:32px;height:32px;border:1px solid #6f2b67;background:transparent;color:#6f2b67;border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.3s;}
    .page-btn:hover:not(.active),.page-btn.active{background:#6f2b67;color:#fff;}
    
    .mobile-toggle{display:none;position:fixed;top:20px;left:20px;z-index:1100;width:40px;height:40px;background:#6f2b67;border:none;border-radius:8px;color:#fff;font-size:20px;}
    
    .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:2000;align-items:center;justify-content:center;}
    .modal.show{display:flex;}
    
    .profile-modal .modal-content{max-width:400px;text-align:center;background:#fff;border:2px solid #6f2b67;border-radius:15px;padding:35px;position:relative;}
    .profile-avatar{width:120px;height:120px;border-radius:50%;background:rgba(111,43,103,0.1);margin:0 auto 20px;position:relative;display:flex;align-items:center;justify-content:center;border:3px solid #6f2b67;}
    .profile-avatar i{font-size:50px;color:#6f2b67;}
    .camera-icon{position:absolute;bottom:5px;right:5px;width:35px;height:35px;background:#6f2b67;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid #fff;}
    .camera-icon i{font-size:16px;color:#fff;}
    .profile-input{display:none;}
    .profile-name{font-size:20px;font-weight:700;color:#6f2b67;margin-bottom:5px;}
    .profile-email{font-size:14px;color:rgba(111,43,103,0.7);margin-bottom:20px;}
    .save-btn{background:#6f2b67;color:#fff;border:none;padding:12px;border-radius:20px;font-weight:700;cursor:pointer;width:100%;text-transform:uppercase;}
    .save-btn:hover{background:#5a2252;}
    .close-modal{position:absolute;top:12px;right:15px;background:transparent;border:none;font-size:24px;color:#6f2b67;cursor:pointer;}
    
    @media(max-width:992px){
      .charts-row{grid-template-columns:1fr;}
      .stats-grid{grid-template-columns:repeat(2,1fr);}
    }
    
    @media(max-width:768px){
      .mobile-toggle{display:flex;align-items:center;justify-content:center;}
      .sidebar{transform:translateX(-100%);}
      .sidebar.active{transform:translateX(0);}
      .main-content{margin-left:0;width:100%;padding:15px;}
      .stats-grid{grid-template-columns:1fr;}
      .top-bar{flex-direction:column;}
      .search-box{max-width:100%;}
      .table-wrapper{max-height:350px;}
    }
    
    @media(max-width:480px){
      .main-content{padding:10px;}
      .user-info div:first-child{display:none;}
      .logo-circle{width:100px;height:100px;}
      .book-logo{font-size:28px;}
      .logo-text{font-size:12px;}
      .table-wrapper{max-height:300px;}
      .orders-table{min-width:550px;}
      .orders-table th,.orders-table td{font-size:11px;padding:8px;}
    }
    
    @media(min-width:320px) and (max-width:420px){
      .main-content{padding:8px;}
      .table-card{padding:15px;}
      .table-wrapper{max-height:280px;}
      .orders-table{min-width:500px;}
      .orders-table th,.orders-table td{font-size:10px;padding:6px 4px;}
      .status-badge{font-size:9px;padding:4px 0;width:75px;}
    }
  </style>
</head>
