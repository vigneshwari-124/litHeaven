async function loadDashboardCards() {
  const res  = await fetch('/admin/dashboard/card-data')
  const data = await res.json()

  if (!data.success) return

  document.getElementById('statOrders').textContent  = data.totalOrders.toLocaleString('en-IN')
  document.getElementById('statUsers').textContent   = data.totalUsers.toLocaleString('en-IN')
  document.getElementById('statEarning').textContent = '₹' + data.totalEarning.toLocaleString('en-IN')
  document.getElementById('statSales').textContent   = '₹' + data.totalSales.toLocaleString('en-IN')
}

loadDashboardCards()


document.getElementById('adminLogoutBtn').addEventListener('click', () => {
  Swal.fire({
    title: "Are you sure?",
    text: "You will be logged out from admin panel",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#6f2b67",
    cancelButtonColor: "#aaa",
    confirmButtonText: "Yes, Logout"
  }).then(async (result) => {
    if (result.isConfirmed) {
      try {
        const res = await fetch('/admin/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        })

        const data = await res.json()

        if (!res.ok) {
          Swal.fire("Error", data.message, "error")
          return
        }

        Swal.fire({
          icon: "success",
          title: "Logged out",
          timer: 1200,
          showConfirmButton: false
        }).then(() => {
          window.location.replace('/admin/login')
        })

      } catch (err) {
        console.log(err)
        Swal.fire("Error", "Something went wrong", "error")
      }
    }
  })
})




