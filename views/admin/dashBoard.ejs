let donutInstance = null

async function loadDonut() {
  const res  = await fetch('/admin/dashboard/stats')
  const data = await res.json()

  if (!data.success) return

  const statusMap = data.statusMap

  
  const colors = {
    Processing : '#6c757d',
    Shipped    : '#007bff',
    Delivered  : '#2ecc71',
    Cancelled  : '#e74c3c',
    Returned   : '#6f2b67'
  }

  const labels = Object.keys(statusMap)    
  const values = Object.values(statusMap)  
  const total  = values.reduce((a, b) => a + b, 0)

 
  if (donutInstance) donutInstance.destroy()

  const ctx = document.getElementById('donutChart').getContext('2d')
  donutInstance = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: labels,
      datasets: [{
        data: values,
        backgroundColor: labels.map(l => colors[l]),
        borderWidth: 2,
        borderColor: '#fff'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '70%',        
      plugins: {
        legend: { display: false },  
        tooltip: {
          callbacks: {
            label: ctx => {
              const pct = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : 0
              return ` ${ctx.label}: ${ctx.raw} (${pct}%)`
            }
          }
        }
      }
    }
  })

  const legendEl = document.getElementById('donutLegend')
  legendEl.innerHTML = labels.map((label, i) => {
    const pct = total > 0 ? ((values[i] / total) * 100).toFixed(1) : 0
    return `
      <div style="display:flex; justify-content:space-between; 
                  padding:6px 0; font-size:13px; 
                  border-bottom:1px solid rgba(111,43,103,0.1);">
        <div style="display:flex; align-items:center; gap:8px;">
          <div style="width:12px; height:12px; border-radius:50%; 
                      background:${colors[label]};"></div>
          ${label}
        </div>
        <strong style="color:#5a2252;">${values[i]} (${pct}%)</strong>
      </div>
    `
  }).join('')
}


loadDonut()



async function loadTopDashboard(){

  const res = await fetch('/admin/dashboard/top-data')

  const data = await res.json()

  if(!data.success) return


  // TOP PRODUCTS

  const productContainer = document.getElementById('topProducts')

  productContainer.innerHTML = ''

  data.topProducts.forEach(product=>{

   productContainer.innerHTML += `

  <div class="top-product-card">

    <div class="top-product-left">

      <img 
        src="${product.image}" 
        class="top-product-image"
      >

      <div>

        <div class="top-product-name">

          ${product.productName}

        </div>

        <div class="top-product-price">

          ₹${product.price}

        </div>

        <div class="top-product-variant">

          Variant : ${product.variant}

        </div>

      </div>

    </div>

    <div class="top-product-right">

      ${product.totalSold} Sold

    </div>

  </div>

`
  })


  // SUBCATEGORY

  const subContainer = document.getElementById('topSubcategories')

  subContainer.innerHTML = ''

  data.topSubcategories.forEach((sub,index)=>{

    subContainer.innerHTML += `

  <div class="subcategory-card">

    <div class="subcategory-left">

      <img 
        src="${sub.subcategoryImage}" 
        class="subcategory-image"
      >

      <div>

        <div class="subcategory-title">

          #${index + 1}
          ${sub.subcategoryName}

        </div>

        <div class="subcategory-small">

          Top Selling Subcategory

        </div>

      </div>

    </div>

    <div class="subcategory-right">

      ${sub.totalSold} Sold

    </div>

  </div>

`

  })

}

loadTopDashboard()



