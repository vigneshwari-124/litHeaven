<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sub-Categories</title>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f5f3ff;color:#6f2b67;font-family:'Segoe UI',sans-serif;}
    
    .sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;}
    .sidebar::-webkit-scrollbar{width:5px;}
    .sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}
    
    .logo-circle{position:relative;width:70px;height:70px;border-radius:50%;border:2px solid #6f2b67;display:flex;align-items:center;justify-content:center;margin:0 auto 15px;}
    .book-logo{width:40px;filter:brightness(1.2) sepia(1) hue-rotate(280deg) saturate(5);}
    .logo-text{position:absolute;bottom:5px;font-size:8px;font-weight:800;color:#6f2b67;text-transform:uppercase;}
    .tagline{position:absolute;bottom:0;font-size:4px;font-weight:600;color:#6f2b67;opacity:0.85;}
    
    .menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:0.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer;}
    .menu-item:hover,.menu-item.active{background:rgba(111,43,103,0.1);border-left-color:#6f2b67;color:#8a3a7f;}
    .menu-item i{width:20px;font-size:16px;}
    .menu-left{display:flex;align-items:center;gap:12px;}
    
    .submenu{max-height:0;overflow:hidden;transition:0.3s;}
    .submenu.show{max-height:200px;}
    .submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:0.3s;}
    .submenu a:hover{background:rgba(111,43,103,0.05);color:#8a3a7f;}
    
    .logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px);}
    .logout-btn:hover{background:#8a3a7f;}
    
    .main-content{margin-left:250px;padding:20px;}
    .top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;}
    .search-box{flex:1;max-width:500px;background:rgba(111,43,103,0.1);border:1px solid #6f2b67;border-radius:25px;padding:8px 20px;display:flex;gap:10px;}
    .search-box input{flex:1;background:transparent;border:none;outline:none;color:#6f2b67;}
    .search-box input::placeholder{color:rgba(111,43,103,0.5);}
    
    .user-info{display:flex;align-items:center;gap:12px;cursor:pointer;}
    .user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px;}
    
    .breadcrumb{color:#6f2b67;font-size:13px;margin-bottom:15px;}
    .page-title{font-size:24px;font-weight:700;margin-bottom:20px;}
    
    .add-btn{background:#6f2b67;color:#fff;border:none;padding:10px 25px;border-radius:25px;font-weight:600;cursor:pointer;box-shadow:0 4px 15px rgba(111,43,103,0.4);}
    .add-btn:hover{background:#8a3a7f;}
    
    .filter-bar{display:flex;gap:10px;margin-bottom:15px;align-items:center;font-size:13px;}
    .filter-bar select{background:transparent;border:1px solid #6f2b67;color:#6f2b67;padding:6px 12px;border-radius:6px;}
    
    .table-container{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:20px;overflow-x:auto;}
    table{width:100%;border-collapse:collapse;}
    th{background:rgba(111,43,103,0.1);padding:12px;text-align:left;font-size:12px;font-weight:700;color:#8a3a7f;border-bottom:2px solid #6f2b67;}
    td{padding:12px;font-size:13px;border-bottom:1px solid rgba(111,43,103,0.2);color:rgba(111,43,103,0.8);}
    tr:hover{background:rgba(111,43,103,0.05);}
    
    .status-active{background:rgba(220,53,69,0.2);color:#dc3545;padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600;display:inline-block;min-width:70px;text-align:center;}
    .action-btn{background:transparent;border:none;color:#007bff;font-size:16px;cursor:pointer;}
    
    .pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;}
    .page-btn{width:32px;height:32px;border:1px solid #6f2b67;background:transparent;color:#6f2b67;border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.3s;}
    .page-btn.active{background:#6f2b67;color:#fff;}
    .page-btn:hover:not(.active){background:rgba(111,43,103,0.1);}

    .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:2000;align-items:center;justify-content:center;backdrop-filter:blur(5px);}
    .modal.show{display:flex;}
    .modal-content{background:linear-gradient(145deg,#1a1a1a,#0d0d0d);border:2px solid #6f2b67;border-radius:15px;width:90%;max-width:420px;padding:25px;position:relative;box-shadow:0 20px 60px rgba(111,43,103,0.3);}
    .modal-title{font-size:18px;font-weight:700;color:#6f2b67;margin-bottom:20px;text-align:center;text-shadow:0 0 10px rgba(111,43,103,0.3);}
    .form-group{margin-bottom:14px;}
    .form-group label{display:block;color:#6f2b67;font-size:12px;margin-bottom:6px;font-weight:600;}
    .form-group input,.form-group select,.form-group textarea{width:100%;padding:8px 12px;border:1px solid #6f2b67;border-radius:8px;font-size:13px;background:rgba(111,43,103,0.05);color:#6f2b67;transition:0.3s;}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:#8a3a7f;background:rgba(111,43,103,0.1);box-shadow:0 0 15px rgba(111,43,103,0.2);}
    .form-group input::placeholder,.form-group textarea::placeholder{color:rgba(111,43,103,0.4);}
    .form-group textarea{resize:vertical;min-height:60px;}
    .date-time{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .save-btn{background:linear-gradient(135deg,#6f2b67,#8a3a7f);color:#fff;border:none;padding:10px;border-radius:20px;font-weight:700;cursor:pointer;width:100%;margin-top:12px;box-shadow:0 8px 25px rgba(111,43,103,0.4);text-transform:uppercase;letter-spacing:1px;transition:0.3s;font-size:13px;}
    .save-btn:hover{transform:translateY(-2px);box-shadow:0 12px 35px rgba(111,43,103,0.6);}
    .close-modal{position:absolute;top:12px;right:15px;background:transparent;border:none;font-size:24px;color:#6f2b67;cursor:pointer;transition:0.3s;}
    .close-modal:hover{color:#8a3a7f;transform:rotate(90deg);}
    
    .profile-modal .modal-content{max-width:400px;text-align:center;background:linear-gradient(145deg,#1a1a1a,#0d0d0d);border:2px solid #6f2b67;box-shadow:0 20px 60px rgba(111,43,103,0.3);}
    .profile-avatar{width:120px;height:120px;border-radius:50%;background:rgba(111,43,103,0.1);margin:0 auto 20px;position:relative;display:flex;align-items:center;justify-content:center;border:3px solid #6f2b67;box-shadow:0 0 20px rgba(111,43,103,0.3);}
    .profile-avatar i{font-size:50px;color:#6f2b67;}
    .camera-icon{position:absolute;bottom:5px;right:5px;width:35px;height:35px;background:linear-gradient(135deg,#6f2b67,#8a3a7f);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid #1a1a1a;box-shadow:0 4px 15px rgba(111,43,103,0.5);}
    .camera-icon i{font-size:16px;color:#fff;}
    .profile-input{display:none;}
    .profile-name{font-size:20px;font-weight:700;color:#6f2b67;margin-bottom:5px;}
    .profile-email{font-size:14px;color:rgba(111,43,103,0.7);margin-bottom:20px;}
    
    @media(max-width:768px){
      .main-content{margin-left:0;}
      .sidebar{transform:translateX(-100%);}
    }
  </style>
</head>
<body>

  <div class="sidebar">
    <div class="logo-circle">
      <img src="https://cdn-icons-png.flaticon.com/512/2702/2702134.png" class="book-logo">
      <div class="logo-text">LitHeaven Admin</div>
      <div class="tagline">Your Admin Portal</div>
    </div>
    
    <a href="/dashboard" class="menu-item">
      <div class="menu-left"><i class="fas fa-chart-line"></i> Dashboard</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-shopping-cart"></i> Orders</div>
    </a>
    
    <div class="menu-item active" onclick="toggleMenu('catMenu')">
      <div class="menu-left"><i class="fas fa-layer-group"></i> Categories</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu show" id="catMenu">
      <a href="/category">Category</a>
      <a href="/sub-category">Sub-Category</a>
    </div>
    
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-box"></i> Products</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-ticket-alt"></i> Coupons</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('offerMenu')">
      <div class="menu-left"><i class="fas fa-tags"></i> Offers</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="offerMenu">
      <a href="#">Category Offers</a>
      <a href="#">Sub-Category Offers</a>
    </div>
    
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-tie"></i> Author</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-shield"></i> Admin</div>
    </a>
    <a href="/customer" class="menu-item">
      <div class="menu-left"><i class="fas fa-users"></i> Customers</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-star"></i> Ratings</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-file-alt"></i> Sales Report</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('settMenu')">
      <div class="menu-left"><i class="fas fa-cog"></i> Settings</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="settMenu">
      <a href="#">App Settings</a>
      <a href="#">User Settings</a>
    </div>
    
    <button class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search anything...">
      </div>
      <div class="user-info" onclick="openProfile()">
        <div>
          <div style="font-weight:600;font-size:14px;">App Admin</div>
          <div style="font-size:11px;opacity:0.7;">support@litheaven.com</div>
        </div>
        <div class="user-avatar"><i class="fas fa-user"></i></div>
      </div>
    </div>
    
    <div class="breadcrumb">Dashboard/categories/sub-Categories</div>
    
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h1 class="page-title">Sub-Categories</h1>
      <button class="add-btn" onclick="openModal()">
        <i class="fas fa-plus"></i> ADD SUB-CATEGORY
      </button>
    </div>
    
    <div class="filter-bar">
      <span>Show</span>
      <select><option>9</option><option>25</option><option>50</option></select>
      <span>entries</span>
    </div>
    
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th><input type="checkbox"></th>
            <th>SUB-CATEGORIES</th>
            <th>PARENT CATEGORIES</th>
            <th>DESCRIPTION</th>
            <th>DATE</th>
            <th>STATUS</th>
            <th>ACTION</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><input type="checkbox"></td>
            <td>Romance</td>
            <td>Fiction</td>
            <td>Love</td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td><button class="action-btn" onclick="openModal('Romance')"><i class="fas fa-edit"></i></button></td>
          </tr>
          <tr>
            <td><input type="checkbox"></td>
            <td>Thriller</td>
            <td>Fiction</td>
            <td>Suspense</td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td><button class="action-btn" onclick="openModal('Thriller')"><i class="fas fa-edit"></i></button></td>
          </tr>
          <tr>
            <td><input type="checkbox"></td>
            <td>Self-Help</td>
            <td>Non-Fiction</td>
            <td>Motivation</td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td><button class="action-btn" onclick="openModal('Self-Help')"><i class="fas fa-edit"></i></button></td>
          </tr>
          <tr>
            <td><input type="checkbox"></td>
            <td>Adventure</td>
            <td>Special Interest</td>
            <td>Exploration</td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td><button class="action-btn" onclick="openModal('Adventure')"><i class="fas fa-edit"></i></button></td>
          </tr>
          <tr>
            <td><input type="checkbox"></td>
            <td>Philosophy</td>
            <td>Non-Fiction</td>
            <td>Wisdom</td>
            <td>28 Mar 2025 at 2:50pm</td>
            <td><span class="status-active">Active</span></td>
            <td><button class="action-btn" onclick="openModal('Philosophy')"><i class="fas fa-edit"></i></button></td>
          </tr>
        </tbody>
      </table>
      
      <div class="pagination">
        <span style="font-size:13px;margin-right:10px;">1-10 of 46</span>
        <button class="page-btn" onclick="prevPage()"><i class="fas fa-chevron-left"></i></button>
        <button class="page-btn" onclick="goToPage(1)">1</button>
        <button class="page-btn" onclick="goToPage(2)">2</button>
        <button class="page-btn" onclick="goToPage(3)">3</button>
        <button class="page-btn">...</button>
        <button class="page-btn" onclick="goToPage(5)">5</button>
        <button class="page-btn" onclick="nextPage()"><i class="fas fa-chevron-right"></i></button>
      </div>
    </div>
  </div>


  <!-- CATEGORY MODAL -->
  <div class="modal" id="modal">
    <div class="modal-content">
      <button class="close-modal" onclick="closeModal()">×</button>
      <h2 class="modal-title" id="modalTitle">Add Sub-Category</h2>
      <form>
        <div class="form-group">
          <label>Category Name</label>
          <input type="text" id="catName" placeholder="Category Name">
        </div>
        <div class="form-group">
          <label>Category description</label>
          <textarea placeholder="Category description"></textarea>
        </div>
        <div class="form-group">
          <label>Parent Category</label>
          <select><option>Fiction</option><option>Non-Fiction</option></select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select><option>Active</option><option>Inactive</option></select>
        </div>
        <div class="form-group">
          <label>Date Added</label>
          <div class="date-time">
            <input type="date" value="2020-12-12">
            <input type="time" value="12:00">
          </div>
        </div>
        <button type="button" class="save-btn" onclick="closeModal()">SAVE CHANGES</button>
      </form>
    </div>
  </div>

  <!-- PROFILE MODAL -->
  <div class="modal profile-modal" id="profileModal">
    <div class="modal-content">
      <button class="close-modal" onclick="closeProfile()">×</button>
      <div class="profile-avatar">
        <i class="fas fa-user"></i>
        <div class="camera-icon" onclick="document.getElementById('fileInput').click()">
          <i class="fas fa-camera"></i>
        </div>
      </div>
      <input type="file" id="fileInput" class="profile-input" accept="image/*">
      <div class="profile-name">App Admin</div>
      <div class="profile-email">support@litheaven.com</div>
      <button class="save-btn" onclick="closeProfile()">UPDATE PROFILE</button>
    </div>
  </div>

  <script>
let currentPage = 1;
const totalPages = 5;

function toggleMenu(id){document.getElementById(id).classList.toggle('show');}

function openModal(name){
  document.getElementById('modal').classList.add('show');
  document.getElementById('modalTitle').textContent=name?'Edit Sub-Category':'Add Sub-Category';
  document.getElementById('catName').value=name||'';
}

function closeModal(){document.getElementById('modal').classList.remove('show');}
function openProfile(){document.getElementById('profileModal').classList.add('show');}
function closeProfile(){document.getElementById('profileModal').classList.remove('show');}

function updatePagination() {
  const buttons = document.querySelectorAll('.pagination .page-btn');
  buttons.forEach(btn => {
    if(btn.textContent == currentPage) {
      btn.classList.add('active');
    } else {
      btn.classList.remove('active');
    }
  });
}

function goToPage(page) {
  currentPage = page;
  updatePagination();
  console.log('Current Page:', currentPage);
}

function nextPage() {
  if(currentPage < totalPages) {
    currentPage++;
    updatePagination();
    console.log('Current Page:', currentPage);
  }
}

function prevPage() {
  if(currentPage > 1) {
    currentPage--;
    updatePagination();
    console.log('Current Page:', currentPage);
  }
}

// Initialize first page as active
updatePagination();
  </script>
</body>
</html>