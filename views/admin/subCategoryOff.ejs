async function saveOffer(){
let isValid=true

  let category = document.getElementById("categorySelect").value;
  let subCategory = document.getElementById("subCategorySelect").value; // 🔥 important
  let offerName = document.getElementById("offerName").value;
  let discount = document.getElementById("discountPct").value;
  let startDate = document.getElementById("startDate").value;
  let endDate = document.getElementById("endDate").value;

  if(!category){
    document.getElementById('categoryError').innerText = "Select a category";
    isValid = false;
  }

  if(!subCategory){
    document.getElementById('subCategoryError').innerText = "Select a category";
    isValid = false;
  }
    if(!offerName){
    document.getElementById('nameError').innerText = "Offer name is Required";
    isValid = false;
  }

    if(!discount){
    document.getElementById('discountError').innerText = "discount % is Required";
    isValid = false;
  }

    if(!startDate){
    document.getElementById('startError').innerText = "Start date is Required";
    isValid = false;
  }

    if(!endDate){
    document.getElementById('endError').innerText = "End date is Required";
    isValid = false;
  }


  const today = new Date();
today.setHours(0,0,0,0);

const start = new Date(startDate);
const end = new Date(endDate);

if(start < today){
  document.getElementById('startError').innerText = "Start date cannot be in the past";
  isValid = false;
}


if(end < today){
  document.getElementById('endError').innerText = "End date cannot be in the past";
  isValid = false;
}

if(start.getTime() === end.getTime()){
  document.getElementById('endError').innerText = "End date must be greater than start date";
  isValid = false;
}


if(end < start){
  document.getElementById('endError').innerText = "End date must be after start date";
  isValid = false;
}


 if(!isValid) return;
  const data = {
    category,
    subCategory,
    offerName,
    discount,
    startDate,
    endDate
  };

  let url='/admin/subCategoryOff'
  let method='POST'

  if(editingId){
    url=`/admin/subCategoryOff/${editingId}`
    method='PUT'
  }
  const res=await fetch(url,{
    method,
    headers:{
        "Content-Type":"application/json"
    },
    body:JSON.stringify(data)
  })

  console.log(data)
  let result = await res.json();

  if(!result.success){
      Swal.fire({
        toast:true,
        position:'top-end',
        icon:'error',
        title: result.message, 
        timer:2000,
        showConfirmButton:false
      });
      return;
    }

     Swal.fire({
      toast:true,
      position:'top-end',
      icon:'success',
      title: result.message,
      timer:2000,
      showConfirmButton:false,
      zIndex: 9999
    });

  closeModal();
  fetchSubcateOff();
}


async function toggleStatus(id){
  const confirm = await Swal.fire({
    title: "Change Offer Visibility?",
    text: "Do you want to show or hide this offer?",
    icon: "question",
    showCancelButton: true,
    confirmButtonColor: "#28a745",
    cancelButtonColor: "#6c757d",
    confirmButtonText: "Yes",
    cancelButtonText: "Cancel",
    width: "350px",           
    padding: "1.5em",
  });

  if(!confirm.isConfirmed) return;

  const res = await fetch(`/admin/offer-toggle/${id}`, {
    method: "PATCH"
  });

  const result = await res.json();

  if(result.success){
    Swal.fire({
      toast: true,
      position: 'top-end',
      icon: 'success',
      title: result.isListed ? "Offer Listed" : "Offer Unlisted",
      timer: 2000,
      showConfirmButton: false
    });

    fetchSubcateOff();
  }
}

let editingId = null; 

async function openEditModal(id){
  editingId = id;

  const res = await fetch(`/admin/subOffer/${id}`);
  const result = await res.json();
  const offer = result.offer;

  document.getElementById("modalTitle").innerText = "Edit Sub-Category Offer";

  await loadCategories();

  document.getElementById("categorySelect").value = offer.category?._id;

  await loadSubCategories();

  document.getElementById("subCategorySelect").value = offer.subCategory?._id;

  document.getElementById("offerName").value = offer.offerName;
  document.getElementById("discountPct").value = offer.discount;
  document.getElementById("startDate").value = offer.startDate.split('T')[0];
  document.getElementById("endDate").value = offer.endDate.split('T')[0];

  document.getElementById("offerModal").classList.add("show");
}


//////////////////

async function deleteOffer(id){
  const confirm = await Swal.fire({
    title: "Delete Offer?",
    text: "This action cannot be undone!",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#dc3545",
    cancelButtonColor: "#6c757d",
    confirmButtonText: "Yes, Delete",
    cancelButtonText: "Cancel"
  });

  if(!confirm.isConfirmed) return;

  try{
    const res = await fetch(`/admin/subCategoryOff/${id}`, {
      method: "DELETE"
    });

    const result = await res.json();

    if(result.success){
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: result.message,
        timer: 2000,
        showConfirmButton: false
      });

      fetchSubcateOff();
    }else{
      Swal.fire("Error", result.message, "error");
    }

  }catch(err){
    console.log(err);
  }
}


