async function downloadPDF(){

    const { jsPDF } = window.jspdf

    const doc = new jsPDF()

    // HEADER

    doc.setFontSize(28)

    doc.text("XEMART - SALES REPORT",14,20)

    doc.setFontSize(12)

    doc.text(
        "Report Period: Auto Selected",
        14,
        35
    )

    doc.text(
        `Generated On: ${new Date().toLocaleDateString('en-GB')}`,
        140,
        35
    )

    // SUMMARY TITLE

    doc.setFontSize(18)

    doc.text("SUMMARY",14,55)

    doc.line(14,60,195,60)

    // SUMMARY DATA

    const totalOrders =
    document.getElementById("statOrders").innerText

    const totalRevenue =
    document.getElementById("statRevenue")
    .innerText
    .replace(/[₹,\s]/g,"")

    const totalDiscount =
    document.getElementById("statDiscount")
    .innerText
    .replace(/[₹,\s]/g,"")

    const avgOrderValue = (

        Number(totalRevenue) /

        Number(totalOrders || 1)

    ).toFixed(2)

    // SUMMARY TABLE

    doc.autoTable({

        startY:70,

        body:[

            ["Total Orders", totalOrders],

            ["Total Revenue", "Rs. " + totalRevenue],

            ["Total Discount", "Rs. " + totalDiscount],

            ["Avg. Order Value", "Rs. " + avgOrderValue]

        ],

        theme:"grid",

        styles:{
            fontSize:12
        },

        columnStyles:{
            0:{
                fontStyle:"bold"
            }
        }

    })

    // ORDER DETAILS TITLE

    const finalY =
    doc.lastAutoTable.finalY + 20

    doc.setFontSize(18)

    doc.text("ORDER DETAILS",14,finalY)

    doc.line(14,finalY + 5,195,finalY + 5)

    // TABLE DATA

    const rows = []

    const tableRows =
    document.querySelectorAll("#reportTbody tr")

    tableRows.forEach((row,index)=>{

        const cols = row.querySelectorAll("td")

        if(cols.length === 9){

            rows.push([

                index + 1,

                cols[3].innerText,

                cols[2].innerText,

                cols[4].innerText,

                cols[5].innerText,

                "Rs. " + cols[6]
                .innerText
                .replace(/[₹,\s]/g,""),

                cols[7].innerText

            ])

        }

    })

    // MAIN TABLE

    doc.autoTable({

        startY:finalY + 15,

        head:[[

            "S.NO",
            "NAME",
            "DELIVERY DATE",
            "PRODUCT NAME",
            "QUANTITY",
            "TOTAL",
            "PAYMENT METHOD"

        ]],

        body:rows,

        theme:"grid",

        headStyles:{

            fillColor:[0,0,0],

            textColor:[255,255,255],

            fontStyle:"bold"

        },

        styles:{

            fontSize:10,

            cellPadding:4

        }

    })

    // SAVE PDF

    doc.save("sales-report.pdf")

}

function downloadExcel(){

