<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Report - LitHeaven</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script> 
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f5f3ff;color:#333;font-family:'Segoe UI',sans-serif;overflow-x:hidden;max-width:100vw;}
    html,body{overflow-y:auto;scroll-behavior:smooth;}

    /* ── Sidebar (exact from dashboard) ── */
    .sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;transition:0.3s;}
    .sidebar::-webkit-scrollbar{width:5px;}
    .sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}
    .logo-circle{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#6f2b67,#5a2252);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 8px 25px rgba(111,43,103,0.5);padding:15px;}
    .book-logo{font-size:35px;color:#fff;margin-bottom:8px;}
    .logo-text{font-size:14px;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:1.5px;}
    .tagline{font-size:9px;font-weight:600;color:#6f2b67;text-align:center;margin-top:8px;}
    .menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:0.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer;}
    .menu-item:hover,.menu-item.active{background:rgba(111,43,103,0.1);border-left-color:#6f2b67;color:#5a2252;}
    .menu-item i{width:20px;font-size:16px;}
    .menu-left{display:flex;align-items:center;gap:12px;}
    .submenu{max-height:0;overflow:hidden;transition:0.3s;}
    .submenu.show{max-height:200px;}
    .submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:0.3s;}
    .submenu a:hover{background:rgba(111,43,103,0.05);color:#5a2252;}
    .logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px);}
    .logout-btn:hover{background:#5a2252;}

    /* ── Main (exact from dashboard) ── */
    .main-content{margin-left:250px;padding:20px;transition:0.3s;width:calc(100% - 250px);overflow-x:hidden;min-height:100vh;}
    .top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:15px;}
    .search-box{flex:1;max-width:500px;background:rgba(111,43,103,0.1);border:1px solid #6f2b67;border-radius:25px;padding:8px 20px;display:flex;gap:10px;}
    .search-box input{flex:1;background:transparent;border:none;outline:none;color:#6f2b67;font-size:14px;}
    .search-box input::placeholder{color:rgba(111,43,103,0.5);}
    .page-title{font-size:28px;font-weight:700;color:#6f2b67;margin-bottom:25px;}
    .user-info{display:flex;align-items:center;gap:12px;cursor:pointer;}
    .user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px;}

    /* ── Filter Card ── */
    .filter-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:24px 28px;margin-bottom:25px;}
    .filter-row-top{display:flex;gap:20px;align-items:flex-end;flex-wrap:wrap;margin-bottom:18px;}
    .filter-row-bottom{display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;}
    .filter-group{display:flex;flex-direction:column;gap:6px;flex:1;min-width:160px;}
    .filter-group.shrink{flex:0 0 auto;}
    .filter-label{font-size:12px;font-weight:700;color:#333;}
    .filter-input{background:#fff;border:1.5px solid #d1d5db;border-radius:8px;padding:10px 14px;color:#333;font-size:13px;outline:none;width:100%;transition:border-color 0.2s;}
    .filter-input:focus{border-color:#6f2b67;box-shadow:0 0 0 3px rgba(111,43,103,0.12);}
    .filter-input option{color:#333;}

    .btn{border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:0.25s;white-space:nowrap;}
    .btn-filter{background:#6f2b67;color:#fff;}
    .btn-filter:hover{background:#5a2252;transform:translateY(-1px);box-shadow:0 4px 14px rgba(111,43,103,0.35);}
    .btn-clear{background:#fff;color:#555;border:1.5px solid #d1d5db;}
    .btn-clear:hover{border-color:#6f2b67;color:#6f2b67;background:rgba(111,43,103,0.04);}
    .btn-apply{background:#1a7a4a;color:#fff;}
    .btn-apply:hover{background:#155f3a;transform:translateY(-1px);box-shadow:0 4px 14px rgba(26,122,74,0.35);}
    .btn-green{background:#1a7a4a;color:#fff;}
    .btn-green:hover{background:#155f3a;transform:translateY(-1px);box-shadow:0 4px 14px rgba(26,122,74,0.35);}
    .btn-red{background:#c0392b;color:#fff;}
    .btn-red:hover{background:#96281b;transform:translateY(-1px);box-shadow:0 4px 14px rgba(192,57,43,0.35);}

    /* ── Table Card ── */
    .table-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:25px;overflow:hidden;}
    .table-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:14px;}
    .table-title{font-size:17px;font-weight:700;color:#6f2b67;}
    .table-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
    .table-search-wrapper{display:flex;align-items:center;gap:8px;background:#fff;border:1.5px solid #d1d5db;border-radius:20px;padding:7px 16px;}
    .table-search-wrapper i{color:#aaa;font-size:13px;}
    .table-search{border:none;outline:none;background:transparent;width:200px;font-size:13px;color:#333;}
    .table-search::placeholder{color:#aaa;}

    .table-wrapper{width:100%;overflow-x:auto;}
    .table-wrapper::-webkit-scrollbar{height:5px;}
    .table-wrapper::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}

    .report-table{width:100%;border-collapse:collapse;min-width:900px;}
    .report-table th{background:rgba(111,43,103,0.08);padding:12px 14px;text-align:left;font-size:12px;font-weight:700;color:#6f2b67;border-bottom:2px solid rgba(111,43,103,0.3);white-space:nowrap;letter-spacing:0.5px;}
    .report-table td{padding:11px 14px;font-size:13px;border-bottom:1px solid rgba(111,43,103,0.1);color:#444;vertical-align:middle;}
    .report-table tr:hover td{background:rgba(111,43,103,0.03);}
    .report-table tfoot td{background:rgba(111,43,103,0.08);font-weight:700;color:#6f2b67;border-top:2px solid rgba(111,43,103,0.3);}

    .badge{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;display:inline-block;}
    .badge-delivered {background:rgba(40,167,69,0.14);color:#1e7e34;}
    .badge-shipped   {background:rgba(13,110,253,0.14);color:#0a53be;}
    .badge-processing{background:rgba(255,193,7,0.2);  color:#856404;}
    .badge-cancelled {background:rgba(220,53,69,0.13); color:#b02a37;}
    .badge-returned  {background:rgba(108,117,125,0.15);color:#495057;}
    .badge-pending   {background:rgba(253,126,20,0.14);color:#c96000;}

    .pagination-bar{display:flex;justify-content:space-between;align-items:center;margin-top:18px;flex-wrap:wrap;gap:10px;}
    .showing-info{font-size:13px;color:#666;}
    .pagination{display:flex;justify-content:center;gap:6px;flex-wrap:wrap;}
    .page-btn{min-width:32px;height:32px;border:1px solid #d1d5db;background:#fff;color:#444;border-radius:6px;cursor:pointer;font-size:13px;padding:0 10px;transition:0.2s;}
    .page-btn:hover,.page-btn.active{background:#6f2b67;color:#fff;border-color:#6f2b67;}
    .page-btn:disabled{opacity:0.35;cursor:default;}
    .page-btn.prev-next{font-weight:600;}

    .empty-row td{text-align:center;padding:50px;color:#8e4a86;font-size:14px;font-weight:600;}

    /* ── Stat Cards ── */
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:25px;}
    .stat-card{background:#fff;border:1.5px solid #e8e0f0;border-radius:16px;padding:20px 18px;display:flex;align-items:center;gap:16px;position:relative;overflow:hidden;transition:0.3s;}
    .stat-card:hover{transform:translateY(-4px);box-shadow:0 10px 28px rgba(111,43,103,0.13);}
    .stat-card::after{content:'';position:absolute;right:-18px;top:-18px;width:80px;height:80px;border-radius:50%;opacity:0.08;}
    .stat-card.orders::after{background:#6f2b67;}
    .stat-card.revenue::after{background:#22a06b;}
    .stat-card.discount::after{background:#2d8cf0;}
    .stat-card.returns::after{background:#f7931e;}
    .stat-icon-wrap{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
    .stat-card.orders   .stat-icon-wrap{background:rgba(111,43,103,0.12);color:#6f2b67;}
    .stat-card.revenue  .stat-icon-wrap{background:rgba(34,160,107,0.13);color:#22a06b;}
    .stat-card.discount .stat-icon-wrap{background:rgba(45,140,240,0.13);color:#2d8cf0;}
    .stat-card.returns  .stat-icon-wrap{background:rgba(247,147,30,0.13);color:#f7931e;}
    .stat-info{display:flex;flex-direction:column;gap:4px;}
    .stat-value{font-size:22px;font-weight:800;color:#2d1a4a;line-height:1;}
    .stat-label{font-size:12px;color:#888;font-weight:500;margin-top:2px;}

    .mobile-toggle{display:none;position:fixed;top:20px;left:20px;z-index:1100;width:40px;height:40px;background:#6f2b67;border:none;border-radius:8px;color:#fff;font-size:20px;}
    .swal2-container{z-index:9999!important;}

    @media(max-width:768px){
      .mobile-toggle{display:flex;align-items:center;justify-content:center;}
      .sidebar{transform:translateX(-100%);}
      .sidebar.active{transform:translateX(0);}
      .main-content{margin-left:0;width:100%;padding:15px;}
      .top-bar{flex-direction:column;gap:10px;}
      .search-box{max-width:100%;}
      .filter-row-top,.filter-row-bottom{flex-direction:column;}
      .filter-input{min-width:100%;}
      .table-actions{flex-wrap:wrap;}
      .stats-grid{grid-template-columns:repeat(2,1fr);}
    }
    @media(max-width:480px){
      .main-content{padding:10px;}
      .user-info div:first-child{display:none;}
      .logo-circle{width:100px;height:100px;}
      .book-logo{font-size:28px;}
      .logo-text{font-size:12px;}
      .stats-grid{grid-template-columns:1fr 1fr;}
    }
    @media(min-width:320px) and (max-width:420px){
      .main-content{padding:8px;}
    }
  </style>
</head>
<body>

<button class="mobile-toggle" onclick="document.getElementById('sidebar').classList.toggle('active')">
  <i class="fas fa-bars"></i>
</button>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <div style="text-align:center;padding:10px 0;">
    <div class="logo-circle">
      <i class="fas fa-book-open book-logo"></i>
      <div class="logo-text">LitHeaven</div>
    </div>
    <div class="tagline">Admin Portal</div>
  </div>
  <a href="/admin/dashboard"   class="menu-item"><div class="menu-left"><i class="fas fa-chart-line"></i> Dashboard</div></a>
  <a href="/admin/order"       class="menu-item"><div class="menu-left"><i class="fas fa-shopping-cart"></i> Orders</div></a>
  <div class="menu-item" onclick="toggleMenu('catMenu')">
    <div class="menu-left"><i class="fas fa-layer-group"></i> Categories</div>
    <i class="fas fa-chevron-down"></i>
  </div>
  <div class="submenu" id="catMenu">
    <a href="/admin/category">Category</a>
    <a href="/admin/sub-category">Sub-Category</a>
  </div>
  <a href="/admin/product" class="menu-item"><div class="menu-left"><i class="fas fa-box"></i> Products</div></a>
  <a href="/admin/coupon"  class="menu-item"><div class="menu-left"><i class="fas fa-ticket-alt"></i> Coupons</div></a>
  <div class="menu-item" onclick="toggleMenu('offerMenu')">
    <div class="menu-left"><i class="fas fa-tags"></i> Offers</div>
    <i class="fas fa-chevron-down"></i>
  </div>
  <div class="submenu" id="offerMenu">
    <a href="/admin/categoryOff">Category Offers</a>
    <a href="/admin/subCategoryOff">Sub-Category Offers</a>
    <a href="/admin/productOff">Product Offers</a>
  </div>
  <a href="/admin/author"      class="menu-item"><div class="menu-left"><i class="fas fa-user-tie"></i> Author</div></a>
 
  <a href="/admin/customer"    class="menu-item"><div class="menu-left"><i class="fas fa-users"></i> Customers</div></a>
  <a href="/admin/salesReport" class="menu-item active"><div class="menu-left"><i class="fas fa-file-alt"></i> Sales Report</div></a>
  <div class="menu-item" onclick="toggleMenu('settMenu')">
    <div class="menu-left"><i class="fas fa-cog"></i> Settings</div>
    <i class="fas fa-chevron-down"></i>
  </div>
  <div class="submenu" id="settMenu">
    
    <a href="/admin/language">Language</a>
  </div>
  <button id="adminLogoutBtn" class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
</div>

<!-- MAIN CONTENT -->
<div class="main-content">

  <!-- Top Bar (same as dashboard) -->
  <div class="top-bar">
    <div class="search-box">
      <i class="fas fa-search" style="color:rgba(111,43,103,0.5);"></i>
      <input type="text" placeholder="Search anything...">
    </div>
    <div class="user-info">
      <div>
        <div style="font-weight:600;font-size:14px;">App Admin</div>
        <div style="font-size:11px;opacity:0.7;">support@litheaven.com</div>
      </div>
      <div class="user-avatar"><i class="fas fa-user"></i></div>
    </div>
  </div>

  <h1 class="page-title"><i class="fas fa-chart-bar" style="font-size:22px;margin-right:10px;"></i>Sales Report</h1>

  <!-- ── Stat Cards ── -->
  <div class="stats-grid">
    <!-- Total Orders -->
    <div class="stat-card orders">
      <div class="stat-icon-wrap">
        <i class="fas fa-shopping-bag"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="statOrders">—</div>
        <div class="stat-label">Total Orders</div>
      </div>
    </div>
    <!-- Total Revenue -->
    <div class="stat-card revenue">
      <div class="stat-icon-wrap" style="font-size:17px;font-weight:800;">
        Rs
      </div>
      <div class="stat-info">
        <div class="stat-value" id="statRevenue">—</div>
        <div class="stat-label">Total Revenue</div>
      </div>
    </div>
    <!-- Total Discount -->
    <div class="stat-card discount">
      <div class="stat-icon-wrap">
        <i class="fas fa-ticket-alt"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="statDiscount">—</div>
        <div class="stat-label">Total Discount</div>
      </div>
    </div>
    <!-- Returns / Cancelled -->
    <div class="stat-card returns">
      <div class="stat-icon-wrap">
        <i class="fas fa-undo-alt"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="statReturns">—</div>
        <div class="stat-label">Returns / Cancelled</div>
      </div>
    </div>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">

    <!-- Row 1: From / To date + Apply Date button -->
    <div class="filter-row-top">
      <div class="filter-group">
        <label class="filter-label">From</label>
        <input type="date" class="filter-input" id="startDate">
      </div>
      <div class="filter-group">
        <label class="filter-label">To</label>
        <input type="date" class="filter-input" id="endDate">
      </div>
      <div class="filter-group shrink" style="align-self:flex-end;">
        <button class="btn btn-apply" onclick="applyDateRange()">
          Apply Date
        </button>
      </div>
    </div>

    <!-- Row 2: Time Period dropdown + Filter / Clear Filters -->
    <div class="filter-row-bottom">
      <div class="filter-group" style="max-width:320px;">
        <label class="filter-label">Time Period</label>
        <select class="filter-input" id="quickFilter" onchange="applyQuickFilter()">
          <option value="">-- Select --</option>
          <option value="today">Today</option>
          <option value="yesterday">Yesterday</option>
          <option value="week">Week</option>
          <option value="month">Month</option>
          <option value="year">Year</option>
        </select>
      </div>
      <div class="filter-group shrink" style="align-self:flex-end;">
        <button class="btn btn-filter" onclick="fetchReport()">
          <i class="fas fa-filter"></i> Filter
        </button>
      </div>
      <div class="filter-group shrink" style="align-self:flex-end;">
        <button class="btn btn-clear" onclick="resetFilters()">
          Clear Filters
        </button>
      </div>
    </div>

  </div>

  
  <!-- Table Card -->
  <div class="table-card">
    <div class="table-header">
      <div class="table-title"><i class="fas fa-list" style="margin-right:8px;"></i>Order Details</div>
      <div class="table-actions">
        <div class="table-search-wrapper">
          <i class="fas fa-search"></i>
          <input type="text" class="table-search" placeholder="Search order / customer..." id="searchInput" onkeypress="handleSearch(event)">
        </div>
        <button class="btn btn-red" onclick="downloadPDF()">
          <i class="fas fa-file-pdf"></i> PDF
        </button>
        <button class="btn btn-green" onclick="downloadExcel()">
          <i class="fas fa-file-excel"></i> Excel
        </button>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="report-table" id="reportTable">
        <thead>
          <tr>
            <th>S.NO</th>
            <th>ORDER ID</th>
            <th>DATE</th>
            <th>CUSTOMER</th>
            <th>PRODUCT</th>
            <th>QTY</th>
            <th>AMOUNT</th>
            <th>PAYMENT</th>
            <th>STATUS</th>
          </tr>
        </thead>
        <tbody id="reportTbody">
          <tr class="empty-row"><td colspan="9"><i class="fas fa-chart-line" style="font-size:30px;margin-bottom:10px;display:block;opacity:0.3;"></i>Select a date range and click Filter</td></tr>
        </tbody>
        <tfoot id="reportTfoot" style="display:none;">
          <tr>
            <td colspan="6" style="text-align:right;font-weight:700;">TOTAL</td>
            <td id="footNet" style="font-weight:700;">—</td>
            <td colspan="2"></td>
          </tr>
        </tfoot>
      </table>
    </div>

    
  </div>

</div><!-- end main-content -->

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
 

 async function fetchReport(){

    const startDate =
    document.getElementById("startDate").value

    const endDate =
    document.getElementById("endDate").value

    const period =
    document.getElementById("quickFilter").value

    const search =
    document.getElementById("searchInput").value

    const res = await fetch(

    `/admin/salesReport-data?startDate=${startDate}&endDate=${endDate}&period=${period}&search=${search}`

    )

    const data = await res.json()

    document.getElementById("statOrders").innerText =data.totalOrders
    document.getElementById("statRevenue").innerText ="₹" + data.totalRevenue
    document.getElementById("statDiscount").innerText ="₹" + data.totalDiscount
    document.getElementById("statReturns").innerText =data.totalReturns

    const tbody =document.getElementById("reportTbody")

    tbody.innerHTML = ""

if(data.salesData.length === 0){

    document.getElementById("reportTfoot").style.display = "none";

    tbody.innerHTML = `
    <tr class="empty-row">
    <td colspan="9">
    No Sales Data Found
    </td>
    </tr>
    `

    return
}

    let grandTotal = 0;

data.salesData.forEach(item => {
  grandTotal += Number(item.amount || 0);
});

document.getElementById("reportTfoot").style.display = "";

document.getElementById("footNet").innerText =
  "₹" + grandTotal.toFixed(2);
  
    data.salesData.forEach((item,index)=>{

        tbody.innerHTML += `

        <tr>

        <td>${index+1}</td>

        <td>${item.orderId}</td>

        <td>${new Date(item.date).toLocaleDateString('en-GB')}</td>

        <td>${item.customer}</td>

        <td>${item.product}</td>

        <td>${item.quantity}</td>

        <td>&#8377;${item.amount}</td>

        <td>${item.payment}</td>

        <td>${item.status}</td>

        </tr>

        `

    })

}

function applyDateRange(){

   fetchReport()

}

function resetFilters(){

   document.getElementById("startDate").value = ""

   document.getElementById("endDate").value = ""

   document.getElementById("quickFilter").value = ""

   document.getElementById("searchInput").value = ""

   fetchReport()

}


  window.onload = fetchReport

  document.getElementById('adminLogoutBtn').addEventListener('click', () => {
    Swal.fire({
      title: "Are you sure?",
      text: "You will be logged out from admin panel",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#6f2b67",
      cancelButtonColor: "#aaa",
      confirmButtonText: "Yes, Logout"
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const res = await fetch('/admin/logout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (!res.ok) { Swal.fire("Error", data.message, "error"); return; }
          Swal.fire({
            icon: "success", title: "Logged out",
            timer: 1200, showConfirmButton: false
          }).then(() => { window.location.replace('/admin/login'); });
        } catch(err) {
          console.log(err);
          Swal.fire("Error", "Something went wrong", "error");
        }
      }
    });
  });


