let LANGS = [];

async function loadLanguagesFromDB() {
  try {
    const res = await fetch('/admin/languages/active');
    const data = await res.json();

    if (!data.success) return;

    LANGS = data.languages;

    buildLanguageUI();

  } catch (error) {
    console.error("Language load error:", error);
  }
}

function buildLanguageUI() {

  const sel = document.getElementById('langSelection');
  const sec = document.getElementById('langSections');

  sel.innerHTML = "";
  sec.innerHTML = "";

  LANGS.forEach(langObj => {

    const lang = langObj.languageCode;
    const name = langObj.languageName;

    sel.innerHTML += `
      <div class="lang-checkbox" id="lc_${lang}" onclick="toggleLanguage('${lang}')">
       <input type="checkbox" id="lang_${lang}" value="${langObj._id}">
        <label for="lang_${lang}">${name}</label>
      </div>
    `;

    sec.innerHTML += `
      <div class="lang-section" id="${lang}Section">
        <h3>${name} Book Details</h3>

        <div class="form-group">
          <label class="form-label">Thumbnail *</label>
          <div class="thumb-upload" id="${lang}_thumb"
            onclick="openImageCrop('${lang}','thumb')">
            <i class="fas fa-image"></i>
            <div class="upload-text">Add Thumbnail</div>
          </div>
          <small id="${lang}_thumb_error"></small>
        </div>

        <div class="form-group">
          <label class="form-label">Sub Images *</label>
          <div class="sub-images-grid">
            ${[0,1,2].map(i=>`
              <div class="sub-image-box"
                id="${lang}_sub_${i}"
                onclick="openImageCrop('${lang}','sub',${i})">
                <i class="fas fa-plus"></i>
              </div>
            `).join('')}
          </div>
          <small id="${lang}_sub_error"></small>
        </div>

        <div class="form-group">
          <label class="form-label">Book Format *</label>
          <div class="format-checkboxes">
            <div class="format-checkbox">
              <input type="checkbox" id="${lang}_paperback"
                onchange="toggleFormatFields('${lang}','paperback')">
              <label>Paper Back</label>
            </div>
            <div class="format-checkbox">
              <input type="checkbox" id="${lang}_hardcover"
                onchange="toggleFormatFields('${lang}','hardcover')">
              <label>Hard Cover</label>
            </div>
          </div>
          <small id="${lang}_format_error"></small>
        </div>

        ${['paperback','hardcover'].map(fmt=>`
          <div class="format-fields" id="${lang}_${fmt}Fields">
            <h4>${fmt}</h4>
            <div class="form-group">
              <label>Price *</label>
              <input type="number" class="form-input"
                id="${lang}_${fmt}_price">
              <small id="${lang}_${fmt}_price_error"></small>
            </div>
            <div class="form-group">
              <label>Stock *</label>
              <input type="number" class="form-input"
                id="${lang}_${fmt}_stock">
              <small id="${lang}_${fmt}_stock_error"></small>
            </div>
          </div>
        `).join('')}

      </div>
    `;
  });
}
