const existingVariant = productVariants.find(
 v => v.language === LANGS.find(l => l.languageCode === lang)._id
);

let formats = existingVariant ? [...existingVariant.formats] : [];

if(pb){

  const priceInput = document.getElementById(`${lang}_paperback_price`);
