function openVariantForm(){
  document.getElementById("languageError").textContent = "";
  loadLanguagesFromDB().then(() => {

    // Already added languages-ஐ disable பண்ணு
    const addedLanguageIds = productVariants.map(v => v.language);

    LANGS.forEach(langObj => {
      const lang = langObj.languageCode;
      const cb = document.getElementById(`lang_${lang}`);
      const box = document.getElementById(`lc_${lang}`);

      if (addedLanguageIds.includes(langObj._id)) {
        // Already exists — disable
        if (cb) { cb.disabled = true; cb.checked = false; }
        if (box) {
          box.style.opacity = '0.4';
          box.style.cursor = 'not-allowed';
          box.style.pointerEvents = 'none';
          box.classList.remove('selected');
        }
        // Section hide
        const sec = document.getElementById(`${lang}Section`);
        if (sec) sec.style.display = 'none';
      } else {
        // Available — enable
        if (cb) { cb.disabled = false; cb.checked = false; }
        if (box) {
          box.style.opacity = '1';
          box.style.cursor = 'pointer';
          box.style.pointerEvents = 'auto';
          box.classList.remove('selected');
        }
        const sec = document.getElementById(`${lang}Section`);
        if (sec) sec.style.display = 'none';
      }
    });

    document.getElementById('variantModal').classList.add('show');
  });
}

// ──  Handle List Unlist ─────────────────────────────────────

async function handleListUnlist(productId, btn) {
  const isCurrentlyListed = btn.classList.contains('listed');

  const result = await Swal.fire({
    title: `${isCurrentlyListed ? 'Unlist' : 'List'} this product?`,
    text: isCurrentlyListed
      ? 'This product will be hidden from the store.'
      : 'This product will be visible in the store.',
    icon: isCurrentlyListed ? 'warning' : 'question',
    showCancelButton: true,
    confirmButtonColor: isCurrentlyListed ? '#dc3545' : '#28a745',
    cancelButtonColor: '#aaa',
    confirmButtonText: `Yes, ${isCurrentlyListed ? 'Unlist' : 'List'} it!`,
    cancelButtonText: 'Cancel'
  });

  if (!result.isConfirmed) return;

  try {
    const res = await fetch(`/admin/products/${productId}/toggle-list`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin'
    });

    const data = await res.json();

    if (!res.ok) {
      Toast.fire({ icon: 'error', title: data.message || 'Something went wrong' });
      return;
    }

    if (isCurrentlyListed) {
      btn.classList.replace('listed', 'unlisted');
      btn.innerHTML = '<i class="fas fa-ban"></i> UNLISTED';
    } else {
      btn.classList.replace('unlisted', 'listed');
      btn.innerHTML = '<i class="fas fa-check-circle"></i> LISTED';
    }

    Toast.fire({
      icon: 'success',
      title: `Product ${isCurrentlyListed ? 'unlisted' : 'listed'} successfully!`
    });

  } catch (err) {
    console.error(err);
    Toast.fire({ icon: 'error', title: 'Something went wrong' });
  }
}
