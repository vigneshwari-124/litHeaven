async function openEditModal(productId) {
  try {
    const res = await fetch(`/admin/products/${productId}`);
    const data = await res.json();

    if (!res.ok || !data.success) {
      Toast.fire({ icon: 'error', title: 'Failed to load product' });
      return;
    }

    const p = data.product;

    editingProductId = productId;
    productVariants = [];
    languageImageData = {};

    document.getElementById('modalTitle').textContent = 'Edit Product';

    // Load dropdowns first, then fill values
    await loadCategoriesDropdown();
    await loadAuthors();

    document.getElementById('productTitle').value = p.title || '';
    document.getElementById('shortDescription').value = p.shortDescription || "";
    document.getElementById('productDescription').value = p.description || '';
    document.getElementById('productCategory').value = p.category?._id || '';

    // Trigger subcategory load
    if (p.category?._id) {
      const subRes = await fetch(`/admin/subcategories/${p.category._id}`);
      const subData = await subRes.json();
      const subSelect = document.getElementById('productSubCategory');
      subSelect.innerHTML = '<option value="">Select Sub-Category</option>';
      if (subData.success) {
        subData.subCategories.forEach(sub => {
          const opt = document.createElement('option');
          opt.value = sub._id;
          opt.textContent = sub.name;
          subSelect.appendChild(opt);
        });
      }
      subSelect.value = p.subCategory?._id || '';
    }

    document.getElementById('authorSelect').value = p.author?._id || '';

    // Load existing variants as edit-ready objects
    // We store existing variants with cloudinary URLs (no files — edit will keep existing images unless replaced)
    productVariants = (p.variants || []).map(v => ({
      language: v.language?._id || v.language,
      languageName: v.language?.languageName || '',
      thumbnail: v.thumbnail,           // existing cloudinary data
      thumbnailFile: null,              // null = no new file, keep existing
      subImages: v.subImages || [],     // existing cloudinary data
      subImageFiles: [],                // null slots = keep existing
      formats: v.formats.map(f => ({
        format: f.format,
        price: f.price,
        stock: f.stock,
        sold: f.sold || 0
      }))
    }));

    updateVariantsListEdit();
    document.getElementById('productModal').classList.add('show');

  } catch (err) {
    console.error(err);
    Toast.fire({ icon: 'error', title: 'Something went wrong' });
  }
}

