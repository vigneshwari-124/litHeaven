  if(price && stock){

  const idx = formats.findIndex(f => f.format === "paperback");

  if(idx > -1){

    formats[idx].price = Number(price);
    formats[idx].stock = Number(stock);
  }else{
   
    formats.push({
      format:"paperback",
      price:Number(price),
      stock:Number(stock)
    });
  }

}
}else{
  formats = formats.filter(f => f.format !== "paperback");
}


if(hc){

  const priceInput = document.getElementById(`${lang}_hardcover_price`);
  const stockInput = document.getElementById(`${lang}_hardcover_stock`);

  const price = priceInput.value.trim();
  const stock = stockInput.value.trim();

  if(!price || Number(price) <= 0){
    document.getElementById(`${lang}_hardcover_price_error`).textContent = "Valid price required";
    priceInput.style.border = "1px solid red";
    isValid = false;
  }

  if(!stock || Number(stock) < 0){
    document.getElementById(`${lang}_hardcover_stock_error`).textContent = "Valid stock required";
    stockInput.style.border = "1px solid red";
    isValid = false;
  }

  if(price && stock){

  const idx = formats.findIndex(f => f.format === "hardcover");

  if(idx > -1){
    formats[idx].price = Number(price);
    formats[idx].stock = Number(stock);
  }else{
    formats.push({
      format:"hardcover",
      price:Number(price),
      stock:Number(stock)
    });
  }

}
}else{
 formats = formats.filter(f => f.format !== "hardcover");
}


if(formats.length && languageImageData[lang]){

  all.push({
    language: LANGS.find(l => l.languageCode === lang)._id,
    formats: formats,
    thumbnailFile: languageImageData[lang]?.thumbnailFile,
    subImageFiles: languageImageData[lang]?.subImageFiles
  });

}
     
  }

  if(!isValid) return;

  const selectedLangIds = selected.map(langCode => {
  const found = LANGS.find(l => l.languageCode === langCode);
  return found ? found._id : null;
}).filter(Boolean);

all.forEach(newVar => {

  const idx = productVariants.findIndex(
    v => v.language === newVar.language
  );

  if(idx > -1){
    productVariants[idx] = newVar; // update existing
  }else{
    productVariants.push(newVar); // add new
  }

});

all.forEach(newVar => {

  const idx = productVariants.findIndex(
    v => v.language === newVar.language
  );

  if(idx > -1){
    productVariants[idx] = newVar; // update existing
  }else{
    productVariants.push(newVar); // add new
