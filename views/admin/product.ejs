function closeCropModal(){
  document.getElementById('cropModal').classList.remove('show');
  if(cropper){cropper.destroy();cropper=null}
  currentCropTarget=null;
}

function applyCrop(){
  if(!cropper || !currentCropTarget) return;

  const canvas = cropper.getCroppedCanvas();

  canvas.toBlob(function(blob){
    const file = new File([blob], Date.now()+".jpg", {type:"image/jpeg"});
    const {language, type, index} = currentCropTarget;

    if(!languageImageData[language]) languageImageData[language] = {};

    if(type === 'thumb'){
      languageImageData[language].thumbnailFile = file;
      document.getElementById(`${language}_thumb`).innerHTML =
        `<img src="${URL.createObjectURL(file)}">`;
    } else {
      if(!languageImageData[language].subImageFiles)
        languageImageData[language].subImageFiles = [];
      languageImageData[language].subImageFiles[index] = file;
      document.getElementById(`${language}_sub_${index}`).innerHTML =
        `<img src="${URL.createObjectURL(file)}">`;
    }

    closeCropModal();
    Toast.fire({icon:'success', title:'Image cropped successfully!'});
  }, "image/jpeg", 0.9);
}

