<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Products - LitHeaven</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link href="https://unpkg.com/cropperjs@1.6.1/dist/cropper.min.css" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#f5f3ff;color:#333;font-family:'Segoe UI',sans-serif;overflow-x:hidden}
.sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;transition:.3s}
.sidebar::-webkit-scrollbar{width:5px}
.sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px}
.logo-circle{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#6f2b67,#5a2252);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 8px 25px rgba(111,43,103,.5);padding:15px}
.book-logo{font-size:35px;color:#fff;margin-bottom:8px}
.logo-text{font-size:14px;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:1.5px}
.tagline{font-size:9px;font-weight:600;color:#6f2b67;text-align:center;margin-top:8px}
.menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer}
.menu-item:hover,.menu-item.active{background:rgba(111,43,103,.1);border-left-color:#6f2b67;color:#5a2252}
.menu-item i{width:20px;font-size:16px}
.menu-left{display:flex;align-items:center;gap:12px}
.submenu{max-height:0;overflow:hidden;transition:.3s}
.submenu.show{max-height:200px}
.submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:.3s}
.submenu a:hover{background:rgba(111,43,103,.05);color:#5a2252}
.logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px)}
.logout-btn:hover{background:#5a2252}
.main-content{margin-left:250px;padding:20px;width:calc(100% - 250px)}
.top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center}
.user-info{display:flex;align-items:center;gap:12px;cursor:pointer;margin-left:auto}
.user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px}
.page-title{font-size:28px;font-weight:700;color:#6f2b67}
.filter-row{display:flex;gap:10px;margin-bottom:15px;align-items:center;font-size:13px;flex-wrap:wrap}
.filter-row select{background:rgba(111,43,103,.1);border:1px solid #6f2b67;color:#6f2b67;padding:8px 15px;border-radius:8px;outline:none;cursor:pointer;font-size:13px}
.add-btn{background:#6f2b67;color:#fff;border:none;padding:10px 25px;border-radius:8px;font-weight:600;cursor:pointer;box-shadow:0 4px 15px rgba(111,43,103,.4);display:flex;align-items:center;gap:8px;font-size:13px}
.add-btn:hover{background:#8a3a7f}
.table-card{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:25px}
.table-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:15px}
.table-title{font-size:18px;font-weight:700;color:#6f2b67}
.table-wrapper{height:480px;overflow-y:auto;overflow-x:auto}
.products-table{width:100%;border-collapse:collapse;table-layout:fixed}
.products-table th{background:rgba(111,43,103,.1);padding:12px;text-align:left;font-size:12px;font-weight:700;color:#6f2b67;border-bottom:2px solid #6f2b67}
.products-table td{padding:14px 12px;font-size:13px;border-bottom:1px solid rgba(111,43,103,.2);color:rgba(111,43,103,.8);vertical-align:middle}
.products-table tr:hover{background:rgba(111,43,103,.05)}

/* LIST / UNLIST button */
.list-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  padding:7px 0;
  border-radius:20px;
  font-size:11px;
  font-weight:700;
  letter-spacing:.6px;
  text-transform:uppercase;
  border:none;
  cursor:pointer;
  transition:background .25s, transform .15s, box-shadow .25s;
  width:110px;        
  height:34px;       
  box-sizing:border-box;
  white-space:nowrap; 
}
.list-btn:active{transform:scale(.96)}
.list-btn.listed{
  background:rgba(40,167,69,.12);
  color:#28a745;
  border:1.5px solid rgba(40,167,69,.45);
  box-shadow:0 2px 8px rgba(40,167,69,.15);
}
.list-btn.listed:hover{
  background:#28a745;
  color:#fff;
  box-shadow:0 4px 14px rgba(40,167,69,.4);
}
.list-btn.unlisted{
  background:rgba(220,53,69,.12);
  color:#dc3545;
  border:1.5px solid rgba(220,53,69,.45);
  box-shadow:0 2px 8px rgba(220,53,69,.15);
}
.list-btn.unlisted:hover{
  background:#dc3545;
  color:#fff;
  box-shadow:0 4px 14px rgba(220,53,69,.4);
}
/* Action */
.action-cell{text-align:center;white-space:nowrap}
.icon-btn{background:transparent;border:none;cursor:pointer;color:#6f2b67;font-size:17px;display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;transition:.3s;border-radius:6px}
.icon-btn:hover{background:rgba(111,43,103,.1);color:#5a2252;transform:scale(1.1)}
/* Pagination */
.pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;flex-wrap:wrap}
.page-btn{width:32px;height:32px;border:1px solid #6f2b67;background:transparent;color:#6f2b67;border-radius:6px;cursor:pointer;font-size:13px;transition:.3s}
.page-btn:hover,.page-btn.active{background:#6f2b67;color:#fff}
.mobile-toggle{display:none;position:fixed;top:20px;left:20px;z-index:1100;width:40px;height:40px;background:#6f2b67;border:none;border-radius:8px;color:#fff;font-size:20px}
/* Modal */
.modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(111,43,103,.15);backdrop-filter:blur(5px);z-index:2000;align-items:center;justify-content:center;padding:20px;overflow-y:auto}
.modal.show{display:flex}
.modal-content{background:#fff;border:2px solid #6f2b67;border-radius:15px;max-width:600px;width:100%;max-height:90vh;overflow:hidden;position:relative;margin:auto;box-shadow:0 10px 40px rgba(111,43,103,.3)}
.modal-header{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;padding:20px 25px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.modal-header h2{font-size:20px;font-weight:700;display:flex;align-items:center;gap:10px}
.close-modal{background:rgba(255,255,255,.2);border:none;width:35px;height:35px;border-radius:50%;color:#fff;cursor:pointer;font-size:20px;transition:.3s}
.close-modal:hover{background:rgba(255,255,255,.3);transform:rotate(90deg)}
.modal-body{padding:25px;overflow-y:auto;max-height:calc(90vh - 80px)}
.modal-body::-webkit-scrollbar{width:8px}
.modal-body::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:10px}
.form-group{margin-bottom:20px}
.form-label{display:block;font-size:13px;font-weight:600;color:#6f2b67;margin-bottom:8px}
.form-input{width:100%;padding:10px 15px;border:1px solid #6f2b67;border-radius:8px;background:rgba(111,43,103,.05);color:#333;font-size:14px;outline:none;transition:.3s}
.form-input:focus{border-color:#8e4a86;background:#fff;box-shadow:0 0 0 3px rgba(111,43,103,.1)}
.form-textarea{resize:vertical;min-height:100px}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;padding-top:20px;border-top:1px solid rgba(111,43,103,.2)}
.btn{padding:10px 20px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:.3s;border:none}
.btn-cancel{background:rgba(111,43,103,.1);color:#6f2b67}
.btn-cancel:hover{background:rgba(111,43,103,.2)}
.btn-save{background:#6f2b67;color:#fff}
.btn-save:hover{background:#5a2252}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:15px}
/* Lang checkboxes */
.lang-checkbox{display:flex;align-items:center;gap:8px;padding:10px;border:2px solid #d4d4d4;border-radius:8px;cursor:pointer;transition:.3s}
.lang-checkbox:hover{border-color:#6f2b67;background:rgba(111,43,103,.05)}
.lang-checkbox.selected{border-color:#6f2b67;background:rgba(111,43,103,.1)}
.lang-checkbox input{width:18px;height:18px;cursor:pointer;accent-color:#6f2b67}
.lang-checkbox label{font-size:13px;font-weight:600;color:#6f2b67;cursor:pointer;flex:1}
.language-selection{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
/* Variants list */
.variants-list{background:rgba(111,43,103,.05);border:1px solid #6f2b67;border-radius:8px;padding:15px;margin-bottom:15px;max-height:400px;overflow-y:auto}
.language-group{margin-bottom:15px;border:1px solid rgba(111,43,103,.2);border-radius:10px;overflow:hidden;background:#fff}
.language-header{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;padding:12px 15px;display:flex;align-items:center;gap:10px;font-size:15px;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.language-content{padding:12px}
.variant-item{background:rgba(111,43,103,.02);border:1px solid rgba(111,43,103,.15);border-radius:8px;padding:10px;margin-bottom:8px;display:flex;gap:12px;align-items:center}
.variant-item:last-child{margin-bottom:0}
.variant-thumbnail{width:70px;height:70px;border-radius:6px;border:2px solid rgba(111,43,103,.3);overflow:hidden;flex-shrink:0;background:rgba(111,43,103,.05);display:flex;align-items:center;justify-content:center}
.variant-thumbnail img{width:100%;height:100%;object-fit:cover}
.variant-thumbnail i{font-size:24px;color:rgba(111,43,103,.3)}
.variant-info{flex:1;min-width:0}
.variant-format{font-size:14px;font-weight:700;color:#6f2b67;margin-bottom:4px}
.variant-details{font-size:12px;color:rgba(111,43,103,.7);display:flex;flex-wrap:wrap;gap:12px}
.variant-detail-item{display:flex;align-items:center;gap:4px}
.variant-detail-item i{font-size:11px}
.variant-actions{display:flex;gap:6px;flex-shrink:0}
.variant-btn{padding:6px 12px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;border:none;transition:.3s;display:inline-flex;align-items:center;gap:4px}
.variant-delete{background:rgba(220,53,69,.1);color:#dc3545;border:1px solid #dc3545}
.variant-delete:hover{background:#dc3545;color:#fff}
.swal2-container {z-index: 5000 !important;}
/* Lang section */
.lang-section{display:none;background:rgba(111,43,103,.05);border:1px solid #6f2b67;border-radius:8px;padding:15px;margin-top:15px}
.lang-section h3{color:#6f2b67;font-size:16px;margin-bottom:15px;padding-bottom:10px;border-bottom:2px solid #6f2b67}
.image-upload-grid{display:grid;grid-template-columns:1fr 2fr;gap:15px;margin-bottom:15px}
.thumb-upload{width:100%;height:120px;border:2px dashed #6f2b67;border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;background:rgba(111,43,103,.05);transition:.3s;position:relative;overflow:hidden}
.thumb-upload:hover{border-color:#5a2252;background:rgba(111,43,103,.1)}
.thumb-upload i{font-size:30px;color:#6f2b67}
.thumb-upload .upload-text{font-size:11px;color:#6f2b67;margin-top:8px}
.thumb-upload img{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0}
.sub-images-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.sub-image-box{width:100%;height:80px;border:2px dashed #6f2b67;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;background:rgba(111,43,103,.05);transition:.3s;position:relative;overflow:hidden}
.sub-image-box:hover{border-color:#5a2252;background:rgba(111,43,103,.1)}
.sub-image-box i{font-size:20px;color:#6f2b67}
.sub-image-box img{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0}
.format-checkboxes{display:flex;gap:20px;margin-bottom:15px}
.format-checkbox{display:flex;align-items:center;gap:8px}
.format-checkbox input{width:18px;height:18px;cursor:pointer;accent-color:#6f2b67}
.format-checkbox label{font-size:13px;font-weight:600;color:#6f2b67;cursor:pointer}
.format-fields{display:none;border:1px solid rgba(111,43,103,.3);border-radius:8px;padding:15px;margin-bottom:15px;background:rgba(111,43,103,.02)}
.format-fields h4{font-size:14px;font-weight:700;color:#6f2b67;margin-bottom:12px}
/* Crop modal */
.crop-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);backdrop-filter:blur(8px);z-index:3000;align-items:center;justify-content:center;padding:20px}
.crop-modal.show{display:flex}
.crop-container{background:#fff;border:3px solid #6f2b67;border-radius:20px;max-width:450px;width:100%;overflow:hidden;box-shadow:0 20px 60px rgba(111,43,103,.6);animation:zoomIn .3s ease}
@keyframes zoomIn{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}
.crop-header{background:linear-gradient(135deg,#6f2b67,#8e4a86);color:#fff;padding:15px 20px;display:flex;align-items:center;justify-content:space-between}
.crop-body{padding:20px}
.crop-image-wrapper{max-width:100%;height:280px;background:#f5f3ff;border:2px solid #6f2b67;border-radius:12px;overflow:hidden;margin-bottom:15px}
#cropImage{max-width:100%;display:block}
.crop-footer{display:flex;gap:10px;justify-content:flex-end;padding-top:15px;border-top:2px solid rgba(111,43,103,.2)}
.btn-crop-cancel{background:rgba(220,53,69,.1);color:#dc3545;border:2px solid #dc3545;padding:10px 20px;border-radius:8px;font-weight:600;cursor:pointer;transition:.3s}
.btn-crop-cancel:hover{background:#dc3545;color:#fff}
.btn-crop-done{background:#6f2b67;color:#fff;padding:10px 20px;border-radius:8px;font-weight:600;cursor:pointer;transition:.3s}
.btn-crop-done:hover{background:#5a2252;transform:translateY(-2px)}


/* Detail modal */
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:15px}
.detail-item{background:rgba(111,43,103,.04);border:1px solid rgba(111,43,103,.15);border-radius:8px;padding:12px}
.d-label{font-size:11px;font-weight:600;color:rgba(111,43,103,.55);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.d-value{font-size:14px;font-weight:600;color:#5a2252}
.detail-variants h4{font-size:13px;font-weight:700;color:#6f2b67;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid rgba(111,43,103,.2)}
.dv-lang-group{margin-bottom:12px}
.dv-lang-title{font-size:11px;font-weight:700;color:#fff;background:#6f2b67;padding:4px 10px;border-radius:5px;display:inline-block;margin-bottom:6px;text-transform:uppercase}
.dv-row{display:flex;align-items:center;gap:10px;padding:8px;background:rgba(111,43,103,.04);border-radius:6px;border:1px solid rgba(111,43,103,.1);margin-bottom:4px;font-size:12px;color:#5a2252}
@media(max-width:768px){
  .mobile-toggle{display:flex;align-items:center;justify-content:center}
  .sidebar{transform:translateX(-100%)}
  .sidebar.active{transform:translateX(0)}
  .main-content{margin-left:0;width:100%;padding:15px}
  .top-bar{flex-direction:column;align-items:flex-start}
  .products-table{min-width:900px}
  .modal-body{padding:15px}
  .form-row{grid-template-columns:1fr}
  .language-selection{grid-template-columns:repeat(2,1fr)}
  .image-upload-grid{grid-template-columns:1fr}
  .variant-item{flex-direction:column;align-items:flex-start}
}
@media(max-width:480px){
  .main-content{padding:10px}
  .language-selection{grid-template-columns:1fr}
}
</style>
</head>
<body>

<button class="mobile-toggle" onclick="document.getElementById('sidebar').classList.toggle('active')">
  <i class="fas fa-bars"></i>
</button>

<div class="sidebar" id="sidebar">
    <div style="text-align:center;padding:10px 0;">
      <div class="logo-circle">
        <i class="fas fa-book-open book-logo"></i>
        <div class="logo-text">LitHeaven</div>
      </div>
      <div class="tagline">Admin Portal</div>
    </div>
    
    <a href="/admin/dashboard" class="menu-item active">
      <div class="menu-left"><i class="fas fa-chart-line"></i> Dashboard</div>
    </a>
    <a href="/admin/order" class="menu-item">
      <div class="menu-left"><i class="fas fa-shopping-cart"></i> Orders</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('catMenu')">
      <div class="menu-left"><i class="fas fa-layer-group"></i> Categories</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="catMenu">
      <a href="/admin/category">Category</a>
      <a href="/admin/sub-category">Sub-Category</a>
    </div>
    
    <a href="/admin/product" class="menu-item">
      <div class="menu-left"><i class="fas fa-box"></i> Products</div>
    </a>
    <a href="/admin/coupon" class="menu-item">
      <div class="menu-left"><i class="fas fa-ticket-alt"></i> Coupons</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('offerMenu')">
      <div class="menu-left"><i class="fas fa-tags"></i> Offers</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="offerMenu">
      <a href="/admin/categoryOff">Category Offers</a>
    <a href="/admin/subCategoryOff">Sub-Category Offers</a>
    <a href="/admin/productOff">Product Offers</a>
    </div>
    
    <a href="/admin/author" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-tie"></i> Author</div>
    </a>
    <a href="/admin/admin" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-shield"></i> Admin</div>
    </a>
    <a href="/admin/customer" class="menu-item">
      <div class="menu-left"><i class="fas fa-users"></i> Customers</div>
    </a>
    <!-- <a href="/admin/rating" class="menu-item">
      <div class="menu-left"><i class="fas fa-star"></i> Ratings</div>
    </a> -->
    <a href="/admin/salesReport" class="menu-item">
      <div class="menu-left"><i class="fas fa-file-alt"></i> Sales Report</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('settMenu')">
      <div class="menu-left"><i class="fas fa-cog"></i> Settings</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="settMenu">
      <a href="/admin/appSetting">App Settings</a>
      <a href="/admin/language">Language</a>
    </div>
    
    <button  id="adminLogoutBtn"  class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
  </div>
<div class="main-content">
  <div class="top-bar">
    <h1 class="page-title">Products</h1>
    <div class="user-info" onclick="document.getElementById('profileModal').classList.add('show')">
      <div>
        <div style="font-weight:600;font-size:14px">App Admin</div>
        <div style="font-size:11px;opacity:.7">admin@litheaven.com</div>
      </div>
      <div class="user-avatar"><i class="fas fa-user"></i></div>
    </div>
  </div>

  <div class="filter-row">
    <select id="limitSelect">
      <option value="7">Show 7 entries</option>
      <option value="15">Show 15 entries</option>
      <option value="25">Show 25 entries</option>
    </select>
    <button class="add-btn" onclick="openAddModal()" style="margin-left:auto"><i class="fas fa-plus"></i> ADD PRODUCT</button>
  </div>

  <div class="table-card">
    <div class="table-header">
      <div class="table-title">Product List</div>
      <div style="position:relative;flex:1;max-width:350px;margin-left:auto">
        <i class="fas fa-search" style="position:absolute;left:15px;top:50%;transform:translateY(-50%);color:#6f2b67;font-size:14px"></i>
        <input type="text" id="searchInput" class="form-input" placeholder="Search products..." style="padding-left:40px;width:100%;border-radius:20px">
      </div>
    </div>
    <div class="table-wrapper">
      <table class="products-table">
        <thead>
          <tr>
            <th style="width:5%">S.NO</th>
            <th style="width:19%">BOOK NAME</th>
            <th style="width:8%">STOCK</th>
            <th style="width:7%">SOLD</th>
            <th style="width:12%">CATEGORY</th>
            <th style="width:12%">AUTHOR</th>
            <th style="width:17%">LIST/UNLIST</th>
            <th style="width:8%">ACTION</th>
          </tr>
        </thead>
        <tbody id="productTableBody"></tbody>
    
      </table>
    </div>
    <div class="pagination" id="pagination"></div>
    <h3>total Price: <span id="hello"></span></h3>
  </div>
</div>

<!-- ADD/EDIT PRODUCT MODAL -->
<div class="modal" id="productModal">
  <div class="modal-content">
    <div class="modal-header">
      <h2><i class="fas fa-box"></i> <span id="modalTitle">Add Product</span></h2>
      <button class="close-modal" onclick="closeModal('productModal')">×</button>
    </div>
    <div class="modal-body">
