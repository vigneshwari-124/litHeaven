function updateVariantsList(){
  const list = document.getElementById('variantsList');

  if(!productVariants.length){
    list.innerHTML = '<p style="text-align:center;color:#888">No variants added yet</p>';
    return;
  }

  const grouped = {};
  productVariants.forEach((v, idx) => {
    if(!grouped[v.language]) grouped[v.language] = [];
    grouped[v.language].push({...v, _idx: idx});
  });

  list.innerHTML = Object.keys(grouped).map(langId => {

    const langObj = LANGS.find(l => l._id === langId);
    const languageName = langObj ? langObj.languageName : "Unknown";

    return `
      <div class="language-group">
        <div class="language-header" style="justify-content:space-between">
          <span>${languageName}</span>
          <button type="button" onclick="openEditVariantForm(${grouped[langId][0]._idx})"
            style="background:rgba(255,255,255,.25);border:1px solid rgba(255,255,255,.5);
                   color:#fff;padding:4px 12px;border-radius:6px;font-size:11px;
                   font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px">
            <i class="fas fa-edit"></i> EDIT VARIANT
          </button>
        </div>
        <div class="language-content">
          ${grouped[langId].map(v => {

            // ── thumbnail: new file இருந்தா blob, இல்லன்னா cloudinary url ──
            const thumbSrc = v.thumbnailFile
              ? URL.createObjectURL(v.thumbnailFile)
              : (v.thumbnail?.url || '');

            return `
              <div class="variant-item">
                <div class="variant-thumbnail">
                  ${thumbSrc
                    ? `<img src="${thumbSrc}" style="width:100%;height:100%;object-fit:cover">`
                    : '<i class="fas fa-image"></i>'}
                </div>
                <div class="variant-info">
                  <div class="variant-format">${v.formats[0].format}</div>
                  <div class="variant-details">
                    <span class="variant-detail-item"><i class="fas fa-tag"></i> ₹${v.formats[0].price}</span>
                    <span class="variant-detail-item"><i class="fas fa-box"></i> Stock: ${v.formats[0].stock}</span>
                  </div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      </div>
    `;
  }).join('');
}
