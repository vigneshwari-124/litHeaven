// ── Load product  ───────────────────────────────────────────────────

let currentPage = 1;
let currentLimit = 7;
let currentSearch = "";

async function loadProducts(){

  try{

  const res = await fetch(
  `/admin/products?page=${currentPage}&limit=${currentLimit}&search=${currentSearch}`,
  { credentials: "same-origin" }
   );
     if (!res.ok) {
      console.error("Failed to fetch products");
      return;
    }

    const data = await res.json();

    const tbody = document.getElementById("productTableBody");

    tbody.innerHTML = ""; 

    if(!data.products || data.products.length === 0){
      tbody.innerHTML = `
        <tr>
          <td colspan="9" style="text-align:center;font-weight:600;color:#888;padding:20px">
            Product not yet
          </td>
        </tr>
      `;
       renderPagination(0);
      return;
    }

   data.products.forEach((product,index)=>{

 const totalStock = (product.variants || []).reduce((sum,v)=>{
  return sum + (v.formats || []).reduce((s,f)=> s + f.stock ,0);
},0);


const row = `
  <tr id="row_${product._id}">
    <td>${index+1}</td>
    <td><strong>${product.title}</strong></td>
    <td>${totalStock}</td>
    <td>${(product.variants || []).reduce((sum,v)=> sum + (v.formats||[]).reduce((s,f)=> s+f.sold ,0),0)}</td>
    <td>${product.category?.name || "-"}</td>
    <td>${product.author?.name || "-"}</td>

    <td style="text-align:center">
  <button
    id="listBtn_${product._id}"
    class="list-btn ${!product.isDeleted ? 'listed' : 'unlisted'}"
    onclick="handleListUnlist('${product._id}', this)">
    <i class="fas fa-${!product.isDeleted ? 'check-circle' : 'ban'}"></i>
    ${!product.isDeleted ? 'LISTED' : 'UNLISTED'}
  </button>
</td>
    <td class="action-cell">
      <button class="icon-btn" onclick="openDetailModal('${product._id}')" title="View">
        <i class="fas fa-eye"></i>
      </button>
      <button class="icon-btn" onclick="openEditModal('${product._id}')" title="Edit">
        <i class="fas fa-edit"></i>
      </button>
    </td>
  </tr>
`;

    
      tbody.innerHTML += row;

    });
    renderPagination(data.totalPages);

  }catch(err){
    console.log(err);
  }
}

window.addEventListener("DOMContentLoaded", loadProducts);

document.getElementById("searchInput")
