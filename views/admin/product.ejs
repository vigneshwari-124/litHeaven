const variantError = document.getElementById("variantError");
const shortDescError = document.getElementById("shortDescError");


   shortDescField.addEventListener("input", () => {

      if (shortDescField.value.trim() !== "") {
             shortDescError.textContent = "";
      }

    });

function clearErrorOnInput(field, errorElement, isSelect = false) {
  field.addEventListener(isSelect ? "change" : "input", () => {
    if (field.value.trim() !== "") {
      errorElement.textContent = "";
    }
  });
}

clearErrorOnInput(titleField, titleError);
clearErrorOnInput(descriptionField, descriptionError);
clearErrorOnInput(categoryField, categoryError, true);
clearErrorOnInput(subCategoryField, subCategoryError, true);
clearErrorOnInput(authorField, authorError, true);


productForm.addEventListener("submit", async function (e) {
  e.preventDefault();

  if (saveBtn.disabled) return; 

  saveBtn.disabled = true;
  saveBtn.textContent = "Saving...";

  let isValid = true;


  titleError.textContent = "";
  descriptionError.textContent = "";
  shortDescError.textContent = "";
  categoryError.textContent = "";
  subCategoryError.textContent = "";
  authorError.textContent = "";
  variantError.textContent = "";

  const title = titleField.value.trim();
  const shortDescription = shortDescField.value.trim();
  const description = descriptionField.value.trim();
  const category = categoryField.value;
  const subCategory = subCategoryField.value;
  const author = authorField.value;

  if (!title) {
    titleError.textContent = "Product name is required";
    isValid = false;
  }

  if (!shortDescription) {
    shortDescError.textContent ="Short description is required";
    isValid = false;
  }else if(shortDescription.length < 10){
    shortDescError.textContent = "Minimum 10 characters required";
    isValid = false;
  }

  if (!description) {
    descriptionError.textContent = "Description is required";
    isValid = false;
  }

  if (!category) {
    categoryError.textContent = "Category is required";
    isValid = false;
  }

  if (!subCategory) {
    subCategoryError.textContent = "Sub-category is required";
    isValid = false;
  }

  if (!author) {
    authorError.textContent = "Author is required";
    isValid = false;
  }

  if (productVariants.length === 0) {
    variantError.textContent = "At least one variant required";
    isValid = false;
  }

  if (!isValid) {
    saveBtn.disabled = false;
    saveBtn.textContent = "Save Product";
    return;
  }

  try {

    const formData = new FormData();
    formData.append("title", title);
    formData.append("shortDescription", shortDescription);
    formData.append("description", description);
    formData.append("category", category);
    formData.append("subCategory", subCategory);
    formData.append("author", author);
    formData.append("variants", JSON.stringify(productVariants));

    productVariants.forEach((variant) => {
      if (variant.thumbnailFile) {
        formData.append("thumbnails", variant.thumbnailFile);
      }

      if (variant.subImageFiles) {
        variant.subImageFiles.forEach(file => {
          formData.append("subImages", file);
        });
      }
    });


    const url = editingProductId
  ? `/admin/products/${editingProductId}`
  : "/admin/products";

const method = editingProductId ? "PUT" : "POST";

if (editingProductId) {
 const variantsForServer = productVariants.map(v => ({
  language: v.language,
  formats: v.formats,
  existingThumbnail: v.thumbnail,
  existingSubImages: v.subImages,
  newThumbIndex: !!v.thumbnailFile,
  subImageCount: v.subImageFiles ? v.subImageFiles.length : 0
}));
  formData.set("variants", JSON.stringify(variantsForServer));
}

const res = await fetch(url, {
  method: method,
  body: formData
});

    const result = await res.json();

    if (!res.ok) {
      Toast.fire({
        icon: "error",
        title: result.message
      });
      return;
    }

    Toast.fire({icon:'success',title:'Product saved successfully!'});
    
   closeModal('productModal');
   loadProducts();

  } catch (err) {
    console.log(err);
    Toast.fire({
      icon: "error",
      title: "Something went wrong"
    });
  } finally {
    saveBtn.disabled = false;
    saveBtn.textContent = "Save Product";
  }

});
