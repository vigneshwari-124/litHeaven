//----openEditVariantForm -------------------------------------------------

async function openEditVariantForm(variantIdx) {
  const variant = productVariants[variantIdx];
  if (!variant) return;

  await loadLanguagesFromDB();

  document.querySelector('#variantModal .modal-header h2').innerHTML =
    '<i class="fas fa-edit"></i> Edit Variant';

  const langObj = LANGS.find(l => l._id === variant.language);
  if (!langObj) return;

  const lang = langObj.languageCode;

  // Checkbox check + section show
  const cb = document.getElementById(`lang_${lang}`);
  const box = document.getElementById(`lc_${lang}`);
  const sec = document.getElementById(`${lang}Section`);
  if (cb) { cb.checked = true; cb.disabled = false; }
  if (box) { box.classList.add('selected'); box.style.opacity='1'; box.style.pointerEvents='auto'; }
  if (sec) sec.style.display = 'block';

  // ── languageImageData ல் existing data set ──
  if (!languageImageData[lang]) languageImageData[lang] = {};

  if (variant.thumbnailFile) {
    // New file already crop 
    languageImageData[lang].thumbnailFile = variant.thumbnailFile;
    document.getElementById(`${lang}_thumb`).innerHTML =
      `<img src="${URL.createObjectURL(variant.thumbnailFile)}" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0">`;
  } else if (variant.thumbnail?.url) {
    // Existing cloudinary image — fetch  File object 
    try {
      const blob = await fetch(variant.thumbnail.url).then(r => r.blob());
      const file = new File([blob], 'thumb.jpg', { type: 'image/jpeg' });
      languageImageData[lang].thumbnailFile = file;
      document.getElementById(`${lang}_thumb`).innerHTML =
        `<img src="${variant.thumbnail.url}" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0">`;
    } catch(e) {
      // fetch fail ஆனா — dummy file வை, validation skip பண்ண
      languageImageData[lang].thumbnailFile = new File([''], 'existing.jpg', { type: 'image/jpeg' });
      document.getElementById(`${lang}_thumb`).innerHTML =
        `<img src="${variant.thumbnail.url}" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0">`;
    }
  }

  // Sub images
  const subFiles = [];
  for (let i = 0; i < 3; i++) {
    const existingFile = variant.subImageFiles?.[i];
    const existingUrl = variant.subImages?.[i]?.url;

    if (existingFile) {
      subFiles[i] = existingFile;
      document.getElementById(`${lang}_sub_${i}`).innerHTML =
        `<img src="${URL.createObjectURL(existingFile)}" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0">`;
    } else if (existingUrl) {
      try {
        const blob = await fetch(existingUrl).then(r => r.blob());
        const file = new File([blob], `sub_${i}.jpg`, { type: 'image/jpeg' });
        subFiles[i] = file;
      } catch(e) {
        subFiles[i] = new File([''], `existing_sub_${i}.jpg`, { type: 'image/jpeg' });
      }
      document.getElementById(`${lang}_sub_${i}`).innerHTML =
        `<img src="${existingUrl}" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0">`;
    }
  }
  languageImageData[lang].subImageFiles = subFiles;

  // Formats pre-fill
  // First uncheck both
  ['paperback','hardcover'].forEach(fmt => {
    const fmtCb = document.getElementById(`${lang}_${fmt}`);
    if (fmtCb) { fmtCb.checked = false; }
    document.getElementById(`${lang}_${fmt}Fields`).style.display = 'none';
  });

  variant.formats.forEach(f => {
    const fmt = f.format;
    const fmtCb = document.getElementById(`${lang}_${fmt}`);
    if (fmtCb) {
      fmtCb.checked = true;
      toggleFormatFields(lang, fmt);
      document.getElementById(`${lang}_${fmt}_price`).value = f.price;
      document.getElementById(`${lang}_${fmt}_stock`).value = f.stock;
    }
  });

  document.getElementById('variantModal').classList.add('show');
}
