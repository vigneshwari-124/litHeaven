    select.innerHTML = `<option value="">Select Author</option>`;

    if(data.success){

      data.authors.forEach(author=>{
        select.innerHTML += `
        <option value="${author._id}">
        ${author.name}
        </option>`;
      });

    }

  }catch(err){
    console.log(err);
  }

}

