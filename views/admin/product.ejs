function resetVariantForm() {
  document.getElementById('variantForm').reset();
  // Title reset
  document.querySelector('#variantModal .modal-header h2').innerHTML =
    '<i class="fas fa-language"></i> Add Variants';
  // All sections hide
  LANGS.forEach(l => {
    const sec = document.getElementById(`${l.languageCode}Section`);
    const box = document.getElementById(`lc_${l.languageCode}`);
    if (sec) sec.style.display = 'none';
    if (box) box.classList.remove('selected');
  });
}


//---- pagination ------------------------------------------------------------

function renderPagination(totalPages) {
  const pagination = document.getElementById("pagination");
  pagination.innerHTML = "";

  if (totalPages < 1) return;

  const MAX_VISIBLE = 5;
  let start = Math.max(1, currentPage - Math.floor(MAX_VISIBLE / 2));
  let end   = start + MAX_VISIBLE - 1;

  if (end > totalPages) {
    end   = totalPages;
    start = Math.max(1, end - MAX_VISIBLE + 1);
  }

  // ← Prev arrow
  const prevBtn = document.createElement("button");
  prevBtn.className  = "page-btn";
  prevBtn.textContent = "‹";
  prevBtn.disabled   = currentPage === 1;
  prevBtn.addEventListener("click", () => {
    if (currentPage > 1) { currentPage--; loadProducts(); }
  });
  pagination.appendChild(prevBtn);

  // numbered buttons
  for (let i = start; i <= end; i++) {
    const btn = document.createElement("button");
    btn.className   = `page-btn ${i === currentPage ? "active" : ""}`;
    btn.textContent = i;
    btn.addEventListener("click", () => { currentPage = i; loadProducts(); });
    pagination.appendChild(btn);
  }

  // → Next arrow
  const nextBtn = document.createElement("button");
  nextBtn.className  = "page-btn";
  nextBtn.textContent = "›";
  nextBtn.disabled   = currentPage === totalPages;
  nextBtn.addEventListener("click", () => {
    if (currentPage < totalPages) { currentPage++; loadProducts(); }
  });
  pagination.appendChild(nextBtn);
}
// ── Logout ────────────────────────────────────────────────────────────────
document.getElementById('adminLogoutBtn').addEventListener('click',()=>{
  Swal.fire({
    title:"Are you sure?",
    text:"You will be logged out from admin panel",
    icon:"warning",
    showCancelButton:true,
    confirmButtonColor:"#6f2b67",
    cancelButtonColor:"#aaa",
    confirmButtonText:"Yes, Logout"
  })
  .then(async r=>{
    if(r.isConfirmed){
      try{
        const res = await fetch('/admin/logout',{
          method:'POST',
          headers:{'Content-Type':'application/json'}
        });

        const data = await res.json();

        if(!res.ok){
          Swal.fire("Error",data.message,"error");
          return;
        }

        Swal.fire({
          icon:"success",
          title:"Logged out",
          timer:1200,
          showConfirmButton:false
        })
        .then(()=>window.location.href=data.redirect);

      }catch(err){
        console.log(err);
        Swal.fire("Error","Something went wrong","error")
      }
    }
  });
});

function deleteVariant(index){

  Swal.fire({
    title:"Delete this variant?",
    text:"This language variant will be removed",
    icon:"warning",
    showCancelButton:true,
    confirmButtonColor:"#dc3545",
    confirmButtonText:"Delete"
  }).then(result=>{

    if(result.isConfirmed){

      productVariants.splice(index,1);

      updateVariantsListEdit();

      Toast.fire({
        icon:"success",
        title:"Variant removed"
      });

    }

  });

}

