async function toggleStatus(id){
  try{
     const confirm = await Swal.fire({
    title: "Change Offer Visibility?",
    text: "Do you want to show or hide this offer?",
    icon: "question",
    showCancelButton: true,
    confirmButtonColor: "#28a745",
    cancelButtonColor: "#6c757d",
    confirmButtonText: "Yes",
    cancelButtonText: "Cancel",
    width: "350px",           
    padding: "1.5em",
  });

    const res = await fetch(`/admin/offer-toggle/${id}`, {
      method: "PATCH",
      headers: {
        "Content-Type": "application/json"
      }
    });

    const data = await res.json();

    if(data.success){

      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "success",
        title: "Status updated",
        timer: 1500,
        showConfirmButton: false
      });

      // table refresh
      fetchProductOff();

    }else{

      Swal.fire({
        icon: "error",
        title: data.message || "Update failed"
      });

    }

  }catch(err){
    console.log("TOGGLE ERROR:", err);

    Swal.fire({
      icon: "error",
      title: "Something went wrong"
    });
  }
}

async function openEditModal(id){
  try{

    editingId = id;

    const res = await fetch(`/admin/productOffer/${id}`);
    const data = await res.json();

    if(!data.success) return;

    const offer = data.offer;

    document.getElementById('offerModal').classList.add('show');

    await loadProducts();

    document.getElementById('productSelect').value = offer.product._id;

    onProductChange();

    setTimeout(() => {

      document.getElementById('languageSelect').value = offer.language;

      onLanguageChange();

      setTimeout(() => {

        document.getElementById('chkPaperback').checked = false;
        document.getElementById('chkHardcover').checked = false;

        if(Array.isArray(offer.format)){
          if(offer.format.includes("paperback")){
            document.getElementById('chkPaperback').checked = true;
          }
          if(offer.format.includes("hardcover")){
            document.getElementById('chkHardcover').checked = true;
          }
        }else{
          if(offer.format === "paperback"){
            document.getElementById('chkPaperback').checked = true;
          }
          if(offer.format === "hardcover"){
            document.getElementById('chkHardcover').checked = true;
          }
        }

        onFormatChange();

      }, 200);

    }, 200);

    document.getElementById('offerName').value = offer.offerName;
    document.getElementById('discountPct').value = offer.discount;

    document.getElementById('startDate').value = offer.startDate.split('T')[0];
    document.getElementById('endDate').value = offer.endDate.split('T')[0];

  }catch(err){
    console.log(err);
  }
}

async function deleteOffer(id){
  const confirm = await Swal.fire({
    title: "Delete Offer?",
    text: "This action cannot be undone!",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#dc3545",
    cancelButtonColor: "#6c757d",
    confirmButtonText: "Yes, Delete",
    cancelButtonText: "Cancel"
  });

  if(!confirm.isConfirmed) return;

  try{

    const res = await fetch(`/admin/productOffer/${id}`, { 
      method: "DELETE"
    });

    const result = await res.json();

    if(result.success){
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: result.message,
        timer: 2000,
        showConfirmButton: false
      });

      fetchProductOff(); 
    }else{
      Swal.fire("Error", result.message, "error");
    }

  }catch(err){
    console.log(err);
  }
}

