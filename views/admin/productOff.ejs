async function saveProductOffer(){
  let isValid = true;

  let product = document.getElementById("productSelect").value;
  let language = document.getElementById("languageSelect").value;
  let isPaperback = document.getElementById('chkPaperback').checked;
  let isHardcover = document.getElementById('chkHardcover').checked;

  let format = [];

if(isPaperback) format.push("paperback");
if(isHardcover) format.push("hardcover");


  let offerName = document.getElementById("offerName").value;
  let discount = document.getElementById("discountPct").value;
  let startDate = document.getElementById("startDate").value;
  let endDate = document.getElementById("endDate").value;

  
  if(!product){
    document.getElementById('productError').innerText = "Select a product";
    isValid = false;
  }

  if(!language){
    document.getElementById('languageError').innerText = "Select language";
    isValid = false;
  }

 if(!isPaperback && !isHardcover){
  document.getElementById('formatError').innerText = "Select at least one format";
  isValid = false;
}

  if(!offerName){
    document.getElementById('nameError').innerText = "Offer name is required";
    isValid = false;
  }

  if(!discount){
    document.getElementById('discountError').innerText = "Discount % is required";
    isValid = false;
  }

  if(!startDate){
    document.getElementById('startError').innerText = "Start date is required";
    isValid = false;
  }

  if(!endDate){
    document.getElementById('endError').innerText = "End date is required";
    isValid = false;
  }

  const today = new Date();
  today.setHours(0,0,0,0);

  const start = new Date(startDate);
  const end = new Date(endDate);

  if(start < today){
    document.getElementById('startError').innerText = "Start date cannot be in the past";
    isValid = false;
  }

  if(end < today){
    document.getElementById('endError').innerText = "End date cannot be in the past";
    isValid = false;
  }

  if(start.getTime() === end.getTime()){
    document.getElementById('endError').innerText = "End date must be greater than start date";
    isValid = false;
  }

  if(end < start){
    document.getElementById('endError').innerText = "End date must be after start date";
    isValid = false;
  }

  if(!isValid) return;

 
  const data = {
    product,
    language,
    format,
    offerName,
    discount,
    startDate,
    endDate
  };

  let url = '/admin/productOff';
  let method = 'POST';

  if(editingId){
    url = `/admin/productOffer/${editingId}`;
    method = 'PUT';
  }

  const res = await fetch(url, {
    method,
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(data)
  });

  console.log(data);

  let result = await res.json();

  if(!result.success){
    Swal.fire({
      toast:true,
      position:'top-end',
      icon:'error',
      title: result.message,
      timer:2000,
      showConfirmButton:false
    });
    return;
  }

  Swal.fire({
    toast:true,
    position:'top-end',
    icon:'success',
    title: result.message,
    timer:2000,
    showConfirmButton:false
  });

  closeModal();
 fetchProductOff();
}



function updatePricePreview(){

  let discount = document.getElementById('discountPct').value;

  let priceDiv = document.getElementById('priceInfo');

  if(!discount || discount <= 0){
    return;
  }

  let lines = priceDiv.innerHTML.split('</div>');

  let updatedHTML = "";

  lines.forEach(line=>{
    if(line.includes('₹')){
      
      let priceMatch = line.match(/₹(\d+)/);
      if(!priceMatch) return;

      let original = parseInt(priceMatch[1]);

      let offerPrice = Math.round(original - (original * discount / 100));

      updatedHTML += `
        <div>
          ${line.replace(/₹\d+/, `₹${original}`)} 
          → <strong>₹${offerPrice}</strong>
        </div>
      `;
    }
  });

  if(updatedHTML){
    priceDiv.innerHTML = updatedHTML;
  }
}

function renderPagination(totalPages){
  const container = document.getElementById('pagination');
  container.innerHTML = '';


  container.innerHTML += `
    <button class="page-btn"
      onclick="changePage(${currentPage - 1})"
      ${currentPage === 1 ? 'disabled' : ''}>
      ←
    </button>
  `;

  
  for(let i = 1; i <= totalPages; i++){
    container.innerHTML += `
      <button class="page-btn ${i === currentPage ? 'active' : ''}"
        onclick="changePage(${i})">
        ${i}
      </button>
    `;
  }

  
  container.innerHTML += `
    <button class="page-btn"
      onclick="changePage(${currentPage + 1})"
      ${currentPage === totalPages ? 'disabled' : ''}>
      →
    </button>
  `;
}


