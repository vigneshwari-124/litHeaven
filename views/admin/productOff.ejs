async function loadProducts(){
  try{
    let res = await fetch('/admin/products-for-offer');
    let data = await res.json();

    console.log("PRODUCT DATA:", data);

    let select = document.getElementById('productSelect');

    select.innerHTML = '<option value="">-- Select Product --</option>';

    data.products.forEach(p=>{
      select.innerHTML += `<option value="${p._id}">${p.title}</option>`;
    });

   productCache = data.products;   
  }catch(err){
    console.log(err);
  }
}

function onProductChange(){

  let productId = document.getElementById('productSelect').value;

 let product = productCache.find(p => String(p._id) === String(productId));
  if(!product){
    console.log("NO PRODUCT");
    return;
  }

  console.log("CACHE:", productCache);
console.log("SELECTED ID:", productId);

  console.log("FOUND PRODUCT:", product);

  let langSelect = document.getElementById('languageSelect');

  langSelect.innerHTML = `<option value="">-- Select Language --</option>`;
  langSelect.disabled = true;

  if(!product || !product.variants){
    console.log("NO PRODUCT");
    return;
  }

  console.log("PRODUCT:", product);

  let languages = product.variants
  .map(v => v.language?.languageName || v.language)
  .filter(Boolean);

  languages = [...new Set(languages)];

  console.log("LANGUAGES:", languages);

  languages.forEach(lang=>{
    langSelect.innerHTML += `<option value="${lang}">${lang}</option>`;
  });

  if(languages.length > 0){
    langSelect.disabled = false;
  }
}


function onLanguageChange(){

  let productId = document.getElementById('productSelect').value;
  let language = document.getElementById('languageSelect').value;

  let product = productCache.find(p => String(p._id) === String(productId));

  let paperback = document.getElementById('chkPaperback');
  let hardcover = document.getElementById('chkHardcover');

  // reset
  paperback.checked = false;
  hardcover.checked = false;

  if(!product) return;

  let formats = [];

  product.variants.forEach(v=>{
    if(v.language?.languageName === language){
      v.formats.forEach(f=>{
        if(f.format){
          formats.push(f.format);
        }
      });
    }
  });

  formats = [...new Set(formats)];

  document.getElementById('formatGroup').style.display = 'block';

 
  if(formats.includes("paperback")){
    paperback.disabled = false;
    paperback.parentElement.style.opacity = "1";
    paperback.parentElement.style.pointerEvents = "auto";
  }else{
    paperback.disabled = true;
    paperback.parentElement.style.opacity = "0.4";
    paperback.parentElement.style.pointerEvents = "none";
  }

  if(formats.includes("hardcover")){
    hardcover.disabled = false;
    hardcover.parentElement.style.opacity = "1";
    hardcover.parentElement.style.pointerEvents = "auto";
  }else{
    hardcover.disabled = true;
    hardcover.parentElement.style.opacity = "0.4";
    hardcover.parentElement.style.pointerEvents = "none";
  }
}

function onFormatChange(){
  let productId = document.getElementById('productSelect').value;
  let language = document.getElementById('languageSelect').value;

  let isPaperback = document.getElementById('chkPaperback').checked;
  let isHardcover = document.getElementById('chkHardcover').checked;

 let product = productCache.find(p => String(p._id) === String(productId));

  if(!product) return;

  let selectedFormats = [];

  if(isPaperback) selectedFormats.push("paperback");
  if(isHardcover) selectedFormats.push("hardcover");

  let variants = [];

product.variants.forEach(v=>{
  if(v.language?.languageName === language){
    v.formats.forEach(f=>{
      if(selectedFormats.includes(f.format)){
        variants.push({
          format: f.format,
          price: f.price
        });
      }
    });
  }
});

  let priceDiv = document.getElementById('priceInfo');

  if(variants.length === 0){
    priceDiv.classList.remove('show');
    return;
  }

  let html = "";

  variants.forEach(v=>{
    html += `<div><strong>${v.format}</strong>: ₹${v.price}</div>`;
  });

  priceDiv.innerHTML = html;
  priceDiv.classList.add('show');
}


