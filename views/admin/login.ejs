stroke-width='1.5' opacity='0.5'/%3E%3Crect x='3' y='3' width='19' height='5' fill='white' opacity='0.3' rx='1'/%3E%3C/g%3E%3C/g%3E%3Cg transform='translate(260,270) rotate(12)'%3E%3Cpath d='M0,0 Q25,-10 50,0 L50,60 Q25,50 0,60 Z' fill='url(%23book5)' stroke='%23c284b9' stroke-width='1.5'/%3E%3Cpath d='M50,0 Q75,-10 100,0 L100,60 Q75,50 50,60 Z' fill='url(%23book3)' stroke='%23ff9a76' stroke-width='1.5'/%3E%3Cline x1='50' y1='0' x2='50' y2='60' stroke='%23a569bd' stroke-width='2'/%3E%3Cpath d='M10,15 L40,15 M10,25 L40,25 M10,35 L38,35 M10,45 L40,45' stroke='%23c284b9' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3Cpath d='M60,15 L90,15 M60,25 L90,25 M60,35 L88,35 M60,45 L90,45' stroke='%23ff9a76' stroke-width='0.8' stroke-linecap='round' opacity='0.5'/%3E%3C/g%3E%3Cg transform='translate(180,150) rotate(-8)'%3E%3Crect x='0' y='0' width='60' height='45' rx='3' fill='url(%23book2)' stroke='%23a8d8ea' stroke-width='1.5'/%3E%3Crect x='5' y='5' width='50' height='35' rx='2' fill='white' opacity='0.2'/%3E%3Cpath d='M30,5 L30,40' stroke='%237ec8e3' stroke-width='2' opacity='0.6'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  background-size: 450px 450px;
  pointer-events: none;
  z-index: 0;
}

.logo-circle{
  position:relative;
  width:50px;
  height:50px;
  border-radius:50%;
  border:2px solid #6f2b67;
  background:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  margin:0 auto 8px;
  animation:float 3s ease-in-out infinite;
  box-shadow:0 3px 12px rgba(111,43,103,0.2);
}

.book-logo{
  width:28px;
  filter:brightness(0) saturate(100%) invert(21%) sepia(47%) saturate(1789%) hue-rotate(285deg) brightness(85%) contrast(92%);
}

.logo-text{
  position:absolute;
  bottom:3px;
  font-size:6px;
  font-weight:800;
  color:#6f2b67;
  letter-spacing:0.6px;
  text-transform:uppercase;
}

.tagline{
  position:absolute;
  bottom:0px;
  font-size:3px;
  font-weight:600;
  color:#6f2b67;
  letter-spacing:0.4px;
  text-transform:uppercase;
  opacity:0.85;
}

.container-box{
  max-width:480px;
  width:100%;
  border:2px solid #6f2b67;
  border-radius:16px;
  padding:20px 24px;
  box-shadow:0 8px 30px rgba(111,43,103,0.18);
  background:#fff;
  position:relative;
  z-index:1;
}

.admin-badge{
  display:inline-block;
  background:#6f2b67;
  color:#fff;
  padding:2px 10px;
  border-radius:12px;
  font-size:9px;
  font-weight:700;
  letter-spacing:0.5px;
  margin-bottom:5px;
}

.title{
  font-size:18px;
  font-weight:700;
  margin-bottom:12px;
  text-align:center;
  margin-top:3px;
  color:#6f2b67;
}

.title-animated{
  display:inline-block;
  opacity:0;
  animation:fadeIn 0.5s forwards;
}

.form-control{
  background:#fff;
  border:2px solid #d8b5d8;
  color:#6f2b67;
  border-radius:50px;
  padding:6px 16px;
  height:32px;
  font-size:12px;
  transition:all 0.3s;
}

.form-control::placeholder{
  color:#b89eb8;
}

.form-control:focus{
  box-shadow:0 0 0 0.25rem rgba(111,43,103,0.12);
  border-color:#6f2b67;
  background:#fff;
  color:#6f2b67;
  outline:none;
}

.error{
  font-size:10px;
  color:#dc3545;
  min-height:14px;
  margin-top:2px;
  margin-left:10px;
  display:block;
}

.password-wrapper{
  position:relative;
  margin-bottom:8px;
}

.eye-icon{
  position:absolute;
  right:16px;
  top:8px;
  cursor:pointer;
  color:#6f2b67;
  font-size:14px;
  transition:all 0.3s;
  z-index:10;
}

.eye-icon:hover{
  color:#8e4a86;
  transform:scale(1.1);
}

.btn-purple{
  background:#6f2b67;
  color:#fff;
  border:none;
  font-weight:600;
  border-radius:50px;
  height:38px;
  font-size:13px;
  box-shadow:0 4px 12px rgba(111,43,103,0.25);
  transition:all 0.3s;
  animation:droplet 3s infinite;
}

.btn-purple:hover{
  background:#8e4a86;
  transform:translateY(-2px);
  box-shadow:0 5px 16px rgba(111,43,103,0.35);
}

.right-img{
  display:flex;
  justify-content:center;
  align-items:center;
}

.right-img img{
  width:180px;
  max-width:100%;
  filter:drop-shadow(0 3px 12px rgba(111,43,103,0.2));
}

.mb-2{
  margin-bottom:8px!important;
}

@media(max-width:768px){
  .right-img{
    display:none;
  }
  .container-box{
    padding:18px 20px;
    max-width:420px;
  }
}

@media(max-width:480px){
  .container-box{
    max-width:360px;
    padding:16px 18px;
  }
  .logo-circle{
    width:45px;
    height:45px;
  }
  .book-logo{
    width:25px;
  }
}
</style>
</head>

<body>

<div class="container-box">
  <div class="row align-items-center g-0">

    <div class="col-md-6">
      <div class="logo-circle">
        <img src="https://cdn-icons-png.flaticon.com/512/2702/2702134.png" class="book-logo" alt="Book">
        <div class="logo-text">LitHeaven</div>
        <div class="tagline">Your Literary Escape</div>
      </div>

      <div class="text-center">
        <span class="admin-badge">👑 ADMIN PANEL</span>
      </div>
      
      <div class="title mb-1" id="animatedTitle"></div>
      
      <form id="formSubmit" autocomplete="off">
        <div class="mb-2">
          <input type="text" id="email" name="email" class="form-control" placeholder="Admin Email" autocomplete="off">
          <div class="error" id="emailErr"></div>
        </div>

        <div class="password-wrapper">
          <input type="password" id="password" class="form-control" placeholder="Password" autocomplete="new-password">
          <i class="fas fa-eye eye-icon" id="togglePassword"></i>
        </div>
        <div class="error" id="passwordErr"></div>

        <button type="submit" class="btn btn-purple w-100 mt-3">ADMIN LOGIN</button>
      </form>
    </div>

    <div class="col-md-6 right-img">
      <img src="/images/adminSignIn.png" alt="Admin">
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
const titleText = "Admin Login";
const titleEl = document.getElementById("animatedTitle");
titleText.split("").forEach((char, i) => {
  const span = document.createElement("span");
  span.className = "title-animated";
  span.style.animationDelay = `${i * 0.1}s`;
  span.textContent = char === " " ? "\u00A0" : char;
  titleEl.appendChild(span);
});

const form = document.getElementById('formSubmit');
const emailField = document.getElementById("email");
const passwordField = document.getElementById("password");
const emailErr = document.getElementById("emailErr");
const passwordErr = document.getElementById("passwordErr");

emailField.addEventListener("input", () => {
  const emailRegex = /^[a-z0-9._%*+-]+@[a-z0-9.-]+\.[a-z]{2,}$/;
  if (emailField.value.trim() === "") {
    emailErr.textContent = "Email is required";
  } else if (!emailRegex.test(emailField.value)) {
    emailErr.textContent = "Email must be lowercase & valid format";
  } else {
    emailErr.textContent = "";
  }
});

passwordField.addEventListener("input", () => {
  const passwordRegex = /^(?=.*[A-Z])(?=.*[@%*_\-$#^!])[a-zA-Z0-9!@#$%^&*]{8,}$/;
  if (passwordField.value.trim() === "") {
    passwordErr.textContent = "Password is required";
  } else if (!passwordRegex.test(passwordField.value)) {
    passwordErr.textContent = "Min 8 chars, 1 uppercase & 1 symbol required";
  } else {
    passwordErr.textContent = "";
  }
});

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  let isValid = true;

  const emailRegex = /^[a-z0-9._%*+-]+@[a-z0-9.-]+\.[a-z]{2,}$/;
  if (emailField.value.trim() === "") {
    emailErr.textContent = "Email is required";
    isValid = false;
  } else if (!emailRegex.test(emailField.value)) {
    emailErr.textContent = "Email must be lowercase & valid format";
    isValid = false;
  } else {
    emailErr.textContent = "";
  }

  const passRegex = /^(?=.*[A-Z])(?=.*[@%*_\-$#^!])[a-zA-Z0-9!@#$%^&*]{8,}$/;
  if (passwordField.value.trim() === "") {
    passwordErr.textContent = "Password is required";
    isValid = false;
  } else if (!passRegex.test(passwordField.value)) {
    passwordErr.textContent = "Min 8 chars, 1 uppercase & 1 symbol required";
    isValid = false;
  } else {
    passwordErr.textContent = "";
  }

  if (!isValid) return;

  const data = {
    email: emailField.value,
    password: passwordField.value
  };

  try {
    const res = await fetch('/admin/login', {
      method: "POST",
      credentials:"include",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(data)
    });

    const result = await res.json();

    if (!res.ok) {
      Swal.fire({
        icon: "error",
        title: "Admin Login Failed",
        text: result.message,
        confirmButtonColor: "#6f2b67"
      });
      return;
    }
    window.location.href = result.redirect;

  } catch (err) {
    console.log(err);
    Swal.fire({
      icon: "error",
      title: "Error",
      text: "Something went wrong",
      confirmButtonColor: "#6f2b67"
    });
  }
});

const togglePassword = document.getElementById("togglePassword");
togglePassword.addEventListener("click", () => {
  const type = passwordField.type === "password" ? "text" : "password";
  passwordField.type = type;
  togglePassword.classList.toggle("fa-eye");
  togglePassword.classList.toggle("fa-eye-slash");
});
</script>

</body>
</html>