  background: linear-gradient(135deg, #f5f0f6 0%, #e8dff0 50%, #f0e5f5 100%);
  background-attachment: fixed;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Segoe UI',sans-serif;
  color:#6f2b67;
  padding:20px;
  position: relative;
  overflow: hidden;
}

