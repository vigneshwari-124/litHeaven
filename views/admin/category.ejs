<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category</title>
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f5f3ff;color:#333;font-family:'Segoe UI',sans-serif;overflow-x:hidden;width:100%;max-width:100vw;}
    
    .sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#fff;border-right:1px solid #6f2b67;padding:20px 0;overflow-y:auto;z-index:1000;}
    .sidebar::-webkit-scrollbar{width:5px;}
    .sidebar::-webkit-scrollbar-thumb{background:#6f2b67;border-radius:5px;}
    
    .logo-circle{position:relative;width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#6f2b67,#5a2252);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 8px 25px rgba(111,43,103,0.5),inset 0 -3px 10px rgba(0,0,0,0.2);padding:15px;}
    .book-logo{font-size:35px;color:#fff;margin-bottom:8px;text-shadow:0 3px 8px rgba(0,0,0,0.3);}
    .logo-text{font-size:14px;font-weight:900;color:#fff;text-transform:uppercase;text-align:center;letter-spacing:1.5px;text-shadow:0 2px 6px rgba(0,0,0,0.4);line-height:1.2;}
    .tagline{font-size:9px;font-weight:600;color:#6f2b67;opacity:0.7;text-align:center;margin-top:8px;letter-spacing:0.5px;}
    
    .menu-item{padding:12px 20px;color:#6f2b67;text-decoration:none;display:flex;align-items:center;justify-content:space-between;transition:0.3s;border-left:3px solid transparent;font-size:14px;font-weight:500;cursor:pointer;}
    .menu-item:hover,.menu-item.active{background:rgba(111,43,103,0.1);border-left-color:#6f2b67;color:#5a2252;}
    .menu-item i{width:20px;font-size:16px;}
    .menu-left{display:flex;align-items:center;gap:12px;}
    
    .submenu{max-height:0;overflow:hidden;transition:0.3s;}
    .submenu.show{max-height:200px;}
    .submenu a{padding:10px 20px 10px 52px;color:#6f2b67;text-decoration:none;display:block;font-size:13px;transition:0.3s;}
    .submenu a:hover{background:rgba(111,43,103,0.05);color:#5a2252;}
    
    .logout-btn{margin:20px;background:#6f2b67;color:#fff;border:none;padding:10px;border-radius:8px;font-weight:700;text-transform:uppercase;cursor:pointer;width:calc(100% - 40px);}
    .logout-btn:hover{background:#5a2252;}
    
    .main-content{margin-left:250px;padding:20px;width:calc(100% - 250px);max-width:100%;overflow-x:hidden;}
    .top-bar{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;width:100%;max-width:100%;box-sizing:border-box;}
    .search-box{flex:1;max-width:500px;background:rgba(111,43,103,0.1);border:1px solid #6f2b67;border-radius:25px;padding:8px 20px;display:flex;gap:10px;}
    .search-box input{flex:1;background:transparent;border:none;outline:none;color:#6f2b67;}
    .search-box input::placeholder{color:rgba(111,43,103,0.5);}
    
    .user-info{display:flex;align-items:center;gap:12px;cursor:pointer;}
    .user-avatar{width:45px;height:45px;border-radius:50%;border:2px solid #6f2b67;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:18px;}
    
    .breadcrumb{color:#6f2b67;font-size:13px;margin-bottom:15px;}
    .page-title{font-size:24px;font-weight:700;margin-bottom:20px;}
    
    .add-btn{background:#6f2b67;color:#fff;border:none;padding:10px 25px;border-radius:25px;font-weight:600;cursor:pointer;box-shadow:0 4px 15px rgba(111,43,103,0.4);}
    .add-btn:hover{background:#5a2252;}
    
    .filter-bar{display:flex;gap:10px;margin-bottom:15px;align-items:center;justify-content:space-between;width:100%;max-width:100%;box-sizing:border-box;flex-wrap:wrap;}
    .filter-left{display:flex;gap:10px;align-items:center;font-size:13px;}
    .filter-right{display:flex;gap:10px;align-items:center;font-size:13px;}
    .filter-bar select{background:transparent;border:1px solid #6f2b67;color:#6f2b67;padding:6px 12px;border-radius:6px;}
    
    .table-container{background:#fff;border:1px solid #6f2b67;border-radius:12px;padding:20px;overflow-x:auto;-webkit-overflow-scrolling:touch;width:100%;max-width:100%;box-sizing:border-box;}
    .table-wrapper{overflow-x:auto;width:100%;max-width:100%;}
    table{width:100%;border-collapse:collapse;min-width:800px;}
    th{background:rgba(111,43,103,0.1);padding:12px;text-align:left;font-size:12px;font-weight:700;color:#5a2252;border-bottom:2px solid #6f2b67;white-space:nowrap;}
    td{padding:12px;font-size:13px;border-bottom:1px solid rgba(111,43,103,0.2);color:rgba(111,43,103,0.8);vertical-align:middle;}
    tr:hover{background:rgba(111,43,103,0.05);}
    
    .status-active{background:rgba(220,53,69,0.2);color:#dc3545;padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600;display:inline-block;min-width:70px;text-align:center;}
    .action-btn{background:transparent;border:none;color:#007bff;font-size:16px;cursor:pointer;margin:0 5px;}
    .action-btn.delete{color:#dc3545;}
    
    .featured-icon{color:#5a2252;font-size:18px;}
    
    .pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;}
    .page-btn{width:32px;height:32px;border:1px solid #6f2b67;background:transparent;color:#6f2b67;border-radius:6px;cursor:pointer;font-size:13px;}
    .page-btn.active{background:#6f2b67;color:#fff;}
    
    .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:2000;align-items:center;justify-content:center;backdrop-filter:blur(5px);}
    .modal.show{display:flex;}
    .modal-content{background:linear-gradient(145deg,#ffffff,#f5f3ff);border:2px solid #6f2b67;border-radius:15px;width:90%;max-width:400px;padding:20px;position:relative;box-shadow:0 20px 60px rgba(111,43,103,0.3);}
    .modal-title{font-size:16px;font-weight:700;color:#6f2b67;margin-bottom:18px;text-align:center;text-shadow:0 0 10px rgba(111,43,103,0.3);}
    .form-group{margin-bottom:12px;}
    .form-group label{display:block;color:#6f2b67;font-size:11px;margin-bottom:5px;font-weight:600;}
    .form-group input,.form-group select,.form-group textarea{width:100%;padding:7px 10px;border:1px solid #6f2b67;border-radius:8px;font-size:12px;background:rgba(111,43,103,0.05);color:#6f2b67;transition:0.3s;}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:#5a2252;background:rgba(111,43,103,0.1);box-shadow:0 0 15px rgba(111,43,103,0.2);}
    .form-group input::placeholder,.form-group textarea::placeholder{color:rgba(111,43,103,0.4);}
    .form-group textarea{resize:vertical;min-height:50px;}
    
    .image-upload{width:80px;height:80px;border:2px dashed #6f2b67;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:0.3s;background:rgba(111,43,103,0.05);}
    .image-upload:hover{border-color:#5a2252;background:rgba(111,43,103,0.1);}
    .image-upload i{font-size:20px;color:#6f2b67;margin-bottom:5px;}
    .image-upload-text{font-size:9px;color:rgba(111,43,103,0.7);}
    .upload-input{display:none;}
    
    .checkbox-group{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
    .checkbox-group input{width:16px;height:16px;cursor:pointer;}
    .checkbox-group label{margin:0;font-size:12px;font-weight:normal;cursor:pointer;}
    
    .date-time{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .save-btn{background:linear-gradient(135deg,#6f2b67,#5a2252);color:#fff;border:none;padding:9px;border-radius:20px;font-weight:700;cursor:pointer;width:100%;margin-top:10px;box-shadow:0 8px 25px rgba(111,43,103,0.4);text-transform:uppercase;letter-spacing:1px;transition:0.3s;font-size:12px;}
    .save-btn:hover{transform:translateY(-2px);box-shadow:0 12px 35px rgba(111,43,103,0.6);}
    .close-modal{position:absolute;top:10px;right:12px;background:transparent;border:none;font-size:22px;color:#6f2b67;cursor:pointer;transition:0.3s;}
    .close-modal:hover{color:#5a2252;transform:rotate(90deg);}
    
    .profile-modal .modal-content{max-width:400px;text-align:center;background:linear-gradient(145deg,#ffffff,#f5f3ff);border:2px solid #6f2b67;box-shadow:0 20px 60px rgba(111,43,103,0.3);}
    .profile-avatar{width:120px;height:120px;border-radius:50%;background:rgba(111,43,103,0.1);margin:0 auto 20px;position:relative;display:flex;align-items:center;justify-content:center;border:3px solid #6f2b67;box-shadow:0 0 20px rgba(111,43,103,0.3);}
    .profile-avatar i{font-size:50px;color:#6f2b67;}
    .camera-icon{position:absolute;bottom:5px;right:5px;width:35px;height:35px;background:linear-gradient(135deg,#6f2b67,#5a2252);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid #ffffff;box-shadow:0 4px 15px rgba(111,43,103,0.5);}
    .camera-icon i{font-size:16px;color:#fff;}
    .profile-input{display:none;}
    .profile-name{font-size:20px;font-weight:700;color:#6f2b67;margin-bottom:5px;}
    .profile-email{font-size:14px;color:rgba(111,43,103,0.7);margin-bottom:20px;}
    
    @media(max-width:768px){
      .sidebar{
        position:fixed;
        left:-250px;
        transition:left 0.3s ease;
        z-index:9999;
      }
      .sidebar.show{
        left:0;
      }
      .main-content{
        margin-left:0;
        padding:10px;
        width:100%;
      }
      .top-bar{
        flex-direction:column;
        gap:10px;
        padding:12px;
        width:100%;
      }
      .search-box{
        max-width:100%;
        width:100%;
      }
      .page-header{
        flex-direction:column;
        gap:10px;
        align-items:flex-start;
        width:100%;
      }
      .filter-bar{
        flex-direction:column;
        align-items:flex-start;
        gap:8px;
        width:100%;
      }
      .filter-left,.filter-right{
        width:100%;
        flex-wrap:wrap;
      }
      .table-container{
        overflow-x:auto;
        padding:10px;
        width:100%;
      }
      .table-wrapper{
        width:100%;
        overflow-x:auto;
      }
      table{
        min-width:700px;
      }
      th{
        white-space:nowrap;
        padding:10px 8px;
        font-size:11px;
      }
      td{
        padding:10px 8px;
        font-size:12px;
      }
      .modal-content{
        width:95%;
        max-width:95%;
        padding:20px;
      }
      .page-title{
        font-size:20px;
      }
      .menu-toggle{
        display:block;
        position:fixed;
        top:15px;
        left:10px;
        z-index:10000;
        background:#6f2b67;
        color:#fff;
        border:none;
        width:40px;
        height:40px;
        border-radius:8px;
        font-size:18px;
        cursor:pointer;
        box-shadow:0 4px 15px rgba(111,43,103,0.4);
      }
      .overlay{
        display:none;
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.5);
        z-index:9998;
      }
      .overlay.show{
        display:block;
      }
    }
    
    @media(max-width:480px){
      .user-info div:first-child{
        display:none;
      }
      .pagination{
        flex-wrap:wrap;
        gap:5px;
      }
      .page-btn{
        width:28px;
        height:28px;
        font-size:11px;
      }
      .add-btn{
        padding:8px 20px;
        font-size:13px;
      }
      .logo-circle{
        width:100px;
        height:100px;
      }
      .book-logo{
        font-size:28px;
        margin-bottom:5px;
      }
      .logo-text{
        font-size:12px;
      }
      th,td{
        font-size:11px;
        padding:8px 6px;
      }
      .page-title{
        font-size:18px;
      }
      .status-active{
        font-size:10px;
        padding:3px 8px;
      }
      .main-content{
        padding:8px;
      }
    }
    
    @media(min-width:344px) and (max-width:400px){
      .table-container{
        padding:8px;
      }
      th,td{
        font-size:10px;
        padding:8px 5px;
      }
      .add-btn{
        font-size:11px;
        padding:6px 15px;
      }
    }
    
    .menu-toggle{
      display:none;
    }
  </style>
</head>
<body>
  <button class="menu-toggle" onclick="toggleSidebar()">
    <i class="fas fa-bars"></i>
  </button>
  
  <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

  <div class="sidebar" id="sidebar">
    <div style="text-align:center;padding:10px 0;">
      <div class="logo-circle">
        <i class="fas fa-book-open book-logo"></i>
        <div class="logo-text">LitHeaven</div>
      </div>
      <div class="tagline">Admin Portal</div>
    </div>
    
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-chart-line"></i> Dashboard</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-shopping-cart"></i> Orders</div>
    </a>
    
    <div class="menu-item active" onclick="toggleMenu('catMenu')">
      <div class="menu-left"><i class="fas fa-layer-group"></i> Categories</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu show" id="catMenu">
      <a href="#">Category</a>
      <a href="#">Sub-Category</a>
    </div>
    
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-box"></i> Products</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-ticket-alt"></i> Coupons</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('offerMenu')">
      <div class="menu-left"><i class="fas fa-tags"></i> Offers</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="offerMenu">
      <a href="#">Category Offers</a>
      <a href="#">Sub-Category Offers</a>
    </div>
    
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-tie"></i> Author</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-user-shield"></i> Admin</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-users"></i> Customers</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-star"></i> Ratings</div>
    </a>
    <a href="#" class="menu-item">
      <div class="menu-left"><i class="fas fa-file-alt"></i> Sales Report</div>
    </a>
    
    <div class="menu-item" onclick="toggleMenu('settMenu')">
      <div class="menu-left"><i class="fas fa-cog"></i> Settings</div>
      <i class="fas fa-chevron-down"></i>
    </div>
    <div class="submenu" id="settMenu">
      <a href="#">App Settings</a>
      <a href="#">User Settings</a>
    </div>
    
    <button class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search anything...">
      </div>
      <div class="user-info" onclick="openProfile()">
        <div>
          <div style="font-weight:600;font-size:14px;">App Admin</div>
          <div style="font-size:11px;opacity:0.7;">support@litheaven.com</div>
        </div>
        <div class="user-avatar"><i class="fas fa-user"></i></div>
      </div>
    </div>
    
    <div class="breadcrumb">Dashboard/categories</div>
    
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h1 class="page-title">Category</h1>
      <button class="add-btn" onclick="openModal()">
        <i class="fas fa-plus"></i> ADD CATEGORY
      </button>
    </div>
    
    <div class="filter-bar">
      <div class="filter-left">
        <span>Show</span>
        <select><option>9</option><option>25</option><option>50</option></select>
        <span>entries</span>
      </div>
      <div class="filter-right">
        <span>Filter By :</span>
        <select><option>All Status</option><option>Active</option><option>Inactive</option></select>
      </div>
    </div>
    
    <div class="table-container">
      <div class="table-wrapper">
        <table>
        <thead>
          <tr>
            <th>CATEGORY</th>
            <th>DESCRIPTION</th>
            <th>FEATURED</th>
            <th>DATE</th>
            <th>STATUS</th>
            <th>ACTION</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Fiction</td>
            <td>Stories that come from imagination</td>
            <td><i class="fas fa-heart featured-icon toggle-heart" onclick="toggleFeatured(this)"></i></i></td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td>
              <button class="action-btn" onclick="openModal('Fiction')"><i class="fas fa-edit"></i></button>
             
            </td>
          </tr>
          <tr>
            <td>Non-Fiction</td>
            <td>Books based on real people and real events</td>
            <td><i class="fas fa-heart featured-icon toggle-heart" onclick="toggleFeatured(this)"></i></i></td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td>
              <button class="action-btn" onclick="openModal('Non-Fiction')"><i class="fas fa-edit"></i></button>
             
            </td>
          </tr>
          <tr>
            <td>Children's Book</td>
            <td>Books written especially for kids</td>
            <td><i class="fas fa-heart featured-icon toggle-heart" onclick="toggleFeatured(this)"></i></i></td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td>
              <button class="action-btn" onclick="openModal('Children Book')"><i class="fas fa-edit"></i></button>
              
            </td>
          </tr>
          <tr>
            <td>Special Interest</td>
            <td>Books written for readers who like specific hobby or topic</td>
            <td><i class="fas fa-heart featured-icon toggle-heart" onclick="toggleFeatured(this)"></i></td>
            <td>28 Mar 2025 at 2:00pm</td>
            <td><span class="status-active">Active</span></td>
            <td>
              <button class="action-btn" onclick="openModal('Special Interest')"><i class="fas fa-edit"></i></button>
              
            </td>
          </tr>
          <tr>
            <td>Academic/Economics</td>
            <td>Books used for studying or learning</td>
            <td><i class="fas fa-heart featured-icon toggle-heart" onclick="toggleFeatured(this)"></i></td>
            <td>28 Mar 2025 at 2:50pm</td>
            <td><span class="status-active">Active</span></td>
            <td>
              <button class="action-btn" onclick="openModal('Academic')"><i class="fas fa-edit"></i></button>
            
            </td>
          </tr>
        </tbody>
        </table>
      </div>
      
      <div class="pagination">
        <span style="font-size:13px;margin-right:10px;">1-10 of 46</span>
        <button class="page-btn"><i class="fas fa-chevron-left"></i></button>
        <button class="page-btn active">1</button>
        <button class="page-btn">2</button>
        <button class="page-btn">3</button>
        <button class="page-btn">...</button>
        <button class="page-btn">5</button>
        <button class="page-btn"><i class="fas fa-chevron-right"></i></button>
      </div>
    </div>
  </div>

  <!-- CATEGORY MODAL -->
  <div class="modal" id="modal">
    <div class="modal-content">
      <button class="close-modal" onclick="closeModal()">×</button>
      <h2 class="modal-title" id="modalTitle">Add Category</h2>
      <form>
        <div class="form-group">
          <label>Category Name</label>
          <input type="text" id="catName" placeholder="Category Name">
        </div>
        <div class="form-group">
          <label>Category description</label>
          <textarea placeholder="Category description"></textarea>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select><option>Active</option><option>Inactive</option></select>
        </div>
        <div class="form-group">
          <label style="margin-bottom:8px;">Upload Image</label>
          <div class="image-upload" onclick="document.getElementById('imageInput').click()">
            <i class="fas fa-image"></i>
            <div class="image-upload-text">Choose Image</div>
          </div>
          <input type="file" id="imageInput" class="upload-input" accept="image/*">
        </div>
        <div class="checkbox-group">
          <input type="checkbox" id="featured">
          <label for="featured">Featured</label>
        </div>
        <div class="form-group">
          <label>Date Added</label>
          <div class="date-time">
            <input type="date" value="2020-12-12">
            <input type="time" value="12:00">
          </div>
        </div>
        <button type="button" class="save-btn" onclick="closeModal()">SAVE CHANGES</button>
      </form>
    </div>
  </div>

  <!-- PROFILE MODAL -->
  <div class="modal profile-modal" id="profileModal">
    <div class="modal-content">
      <button class="close-modal" onclick="closeProfile()">×</button>
      <div class="profile-avatar">
        <i class="fas fa-user"></i>
        <div class="camera-icon" onclick="document.getElementById('fileInput').click()">
          <i class="fas fa-camera"></i>
        </div>
      </div>
      <input type="file" id="fileInput" class="profile-input" accept="image/*">
      <div class="profile-name">App Admin</div>
      <div class="profile-email">support@litheaven.com</div>
      <button class="save-btn" onclick="closeProfile()">UPDATE PROFILE</button>
    </div>
  </div>

  <script>
function toggleMenu(id){document.getElementById(id).classList.toggle('show');}
function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('show');
  document.getElementById('overlay').classList.toggle('show');
}
function openModal(name){
  document.getElementById('modal').classList.add('show');
  document.getElementById('modalTitle').textContent=name?'Edit Category':'Add Category';
  document.getElementById('catName').value=name||'';
}
function toggleFeatured(el){el.classList.toggle('fas');el.classList.toggle('far');el.style.color = el.classList.contains('fas') ? '#5a2252' : '#666';}
function closeModal(){document.getElementById('modal').classList.remove('show');}
function openProfile(){document.getElementById('profileModal').classList.add('show');}
function closeProfile(){document.getElementById('profileModal').classList.remove('show');}
  </script>
</body>
</html>