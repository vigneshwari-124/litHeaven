async function openEditModal(id){

  const res = await fetch(`/admin/coupon/${id}`);
  const c = await res.json();

  editingId = id;

  document.getElementById('modalTitle').innerText = "Edit Coupon";

  
  document.getElementById('couponCode').value = c.code;
  document.getElementById('discountPct').value = c.discountPct;
  document.getElementById('minPurchase').value = c.minPurchase;
  document.getElementById('maxDiscount').value = c.maxDiscount;

  document.getElementById('startDate').value = c.startDate.split('T')[0];
  document.getElementById('expiryDate').value = c.endDate.split('T')[0];

  document.getElementById('couponStatus').value = c.status;

  document.getElementById('couponModal').classList.add('show');
}

function closeModal() {
  document.getElementById('couponModal').classList.remove('show');
}

document.getElementById('couponModal').addEventListener('click', function(e){
  if(e.target === this){
    closeModal();
  }
});


async function deleteCoupon(id){
  const confirmDelete= await Swal.fire({
     title: "Are you sure?",
    text: "You won't be able to revert this!",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#d33",
    cancelButtonColor: "#6f2b67",
    confirmButtonText: "Yes, delete it!"
  })

  if(!confirmDelete.isConfirmed) return;

  const res=await fetch(`/admin/coupon/${id}`,{
    method:'DELETE'
  })
  const result=await res.json()

  if(!res.ok){
    Swal.fire("Error",result.message,"error")
    return
  }

   Swal.fire({
    toast:true,
    position:'top-end',
    icon:'success',
    title: result.message,
    timer:2000,
    showConfirmButton:false
  });

  fetchCoupons();

}
