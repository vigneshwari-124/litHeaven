async function saveCoupon(){

  let isValid=true;

   const code= document.getElementById('couponCode').value
   const discountPct =document.getElementById('discountPct').value
   const minPurchase= document.getElementById('minPurchase').value
   const maxDiscount= document.getElementById('maxDiscount').value
   const startDate= document.getElementById('startDate').value
   const endDate=document.getElementById('expiryDate').value
   const status= document.getElementById('couponStatus').value

    if(!code){
    document.getElementById('codeError').innerText = "coupon code is Required";
    isValid = false;
  }

  if(!discountPct){
    document.getElementById('discountError').innerText = "discount % is Required";
    isValid = false;
  }

  if(!minPurchase){
    document.getElementById('minError').innerText = "discount % is Required";
    isValid = false;
  }

  if(!maxDiscount){
    document.getElementById('maxError').innerText = "discount % is Required";
    isValid = false;
  }

  if(!startDate){
    document.getElementById('startError').innerText = "discount % is Required";
    isValid = false;
  }

  if(!endDate){
    document.getElementById('endError').innerText = "discount % is Required";
    isValid = false;
  }

  if(discountPct > 99){
  document.getElementById('discountError').innerText = "Discount must be between 1% and 99%";
  isValid = false;
  }


  const today = new Date();
  today.setHours(0,0,0,0);

const start = new Date(startDate);
const end = new Date(endDate);

 if(start < today){
  document.getElementById('startError').innerText = "Start date cannot be in the past";
  isValid = false;
}

if(end < today){
  document.getElementById('endError').innerText = "End date cannot be in the past";
  isValid = false;
}

if(end.getTime() === today.getTime()){
  document.getElementById('endError').innerText = "End date cannot be today";
  isValid = false;
}

if(start.getTime() === end.getTime()){
  document.getElementById('endError').innerText = "End date must be greater than start date";
  isValid = false;
}

if(end < start){
  document.getElementById('endError').innerText = "End date must be after start date";
  isValid = false;
}

   if(!isValid) return;
 
  const data = {
    code,
    discountPct,
    minPurchase,
    maxDiscount,
    startDate,
    endDate,
    status
  };

  let url='/admin/coupon'
  let method='POST'

  if(editingId){
    url=`/admin/coupon/${editingId}`;
    method='PUT'
  }

  const res= await fetch(url, {
    method: method,
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(data)
  });

  const result = await res.json();
  if(!res.ok){
      Swal.fire({
        toast:true,
        position:'top-end',
        icon:'error',
        title: result.message, 
        timer:2000,
        showConfirmButton:false
      });
      return;
    }

     Swal.fire({
      toast:true,
      position:'top-end',
      icon:'success',
      title: result.message,
      timer:2000,
      showConfirmButton:false,
      zIndex: 9999
    });




  document.getElementById('couponModal').classList.remove('show');

  fetchCoupons(); // refresh table
}

