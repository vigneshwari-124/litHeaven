<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>404 - Page Not Found</title>
  <style>
    body{
      background:#f4f6f9;
      font-family:'Segoe UI',sans-serif;
      display:flex;
      align-items:center;
      justify-content:center;
      height:100vh;
      margin:0;
    }
    .card{
      background:#fff;
      padding:50px;
      border-radius:20px;
      text-align:center;
      box-shadow:0 10px 40px rgba(0,0,0,0.1);
      max-width:500px;
      width:90%;
    }
    h1{
      font-size:90px;
      color:#ff4d4f;
      margin:0;
    }
    h2{
      margin:15px 0;
      color:#333;
    }
    p{
      color:#777;
      margin-bottom:30px;
    }
    .btns{
      display:flex;
      justify-content:center;
      gap:15px;
      flex-wrap:wrap;
    }
    a{
      text-decoration:none;
      padding:12px 22px;
      border-radius:8px;
      font-weight:600;
      color:#fff;
    }
    .home{background:#28a745;}
    .back{background:#6c757d;}
  </style>
</head>
<body>

  <div class="card">
    <h1>404</h1>
    <h2>Oops! Page Not Found 😕</h2>
    <p>The page you are looking for does not exist or has been moved.</p>

    <div class="btns">
      <a href="/" class="home">🏠 Go Home</a>
      <a href="javascript:history.back()" class="back">⬅ Go Back</a>
    </div>
  </div>

</body>
</html>
